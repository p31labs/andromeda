{
  "name": "epcp-command-center-tests",
  "version": "1.0.0",
  "description": "EPCP Command Center — End-to-End Test Suite",
  "scripts": {
    "test": "jest --testPathPattern=unit",
    "test:e2e": "playwright test",
    "test:integration": "jest --testPathPattern=integration",
    "test:security": "jest --testPathPattern=security",
    "test:perf": "jest --testPathPattern=performance",
    "test:all": "npm run test && npm run test:integration && npm run test:security && npm run test:perf && npm run test:e2e",
    "test:d1-schema": "jest --testPathPattern=d1-schema",
    "test:r2": "jest --testPathPattern=r2",
    "test:iam": "jest --testPathPattern=iam",
    "dev": "wrangler dev src/index.js --port 8787 --local",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/ai": "^1.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "artillery": "^2.0.26",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "supertest": "^6.3.4",
    "wrangler": "^4.85.0"
  }
}
