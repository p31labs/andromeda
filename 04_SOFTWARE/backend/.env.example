# P31 Buffer Agent Environment Variables
# Copy this file to .env and fill in your values

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password-here

# LiteLLM Proxy (for AI routing)
LITELLM_KEY=sk-your-litellm-key
LITELLM_URL=http://localhost:4000/v1

# IPFS (optional - falls back to local-only mode)
IPFS_API_URL=http://localhost:5001

# Arweave (optional - for permanent storage)
ARWEAVE_WALLET_PATH=/path/to/arweave-wallet.json

# --- Auto-synced from .env.canonical CONSTANTS ---
IMAP_PORT=993
BOT_PREFIX=p31
ENABLE_FAWN_DETECTION=true
MAX_SPOON_DISPLAY=12
NODE_ONE_WEBHOOK_PORT=3000
RESPONSE_TIMEOUT_MS=5000
TURBO_TEAM=p31labs
HCB_ORG_SLUG=p31-labs
GITHUB_REPO=p31labs/andromeda
NODE_ENV=production
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
CORS_ORIGIN=https://p31ca.org
BONDING_API_URL=https://bonding.p31ca.org/api
SPOON_API_URL=https://phosphorus31.org/api/spoons
