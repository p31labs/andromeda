# ═══════════════════════════════════════════════════════════════
# P31 EDE — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# AI Model API Keys
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Email Shield (IMAP)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Thick Click Hardware
THICK_CLICK_SECRET=

# Integrations
WAKATIME_API_KEY=
GITHUB_TOKEN=
SLACK_WEBHOOK_URL=

# HCB Fiscal Sponsor (P31 Labs)
HCB_ORG_SLUG=p31-labs

# Sentry Error Tracking
VITE_SENTRY_DSN=
TURBO_TOKEN=
TURBO_TEAM=

# --- Auto-synced from .env.canonical CONSTANTS ---
BOT_PREFIX=p31
ENABLE_FAWN_DETECTION=true
MAX_SPOON_DISPLAY=12
NODE_ONE_WEBHOOK_PORT=3000
RESPONSE_TIMEOUT_MS=5000
GITHUB_REPO=p31labs/andromeda
NODE_ENV=production
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
CORS_ORIGIN=https://p31ca.org
BONDING_API_URL=https://bonding.p31ca.org/api
SPOON_API_URL=https://phosphorus31.org/api/spoons
