# P31 Discord Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Required - Discord Bot
# ============================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_token_here

# Bot command prefix
BOT_PREFIX=p31

# ============================================
# Required - API Endpoints
# ============================================

# BONDING game API URL
BONDING_API_URL=https://bonding.p31ca.org/api

# Node One (Quantum Edge) API URL
NODE_ONE_API_URL=http://localhost:3001/api

# Spoon Economy API URL
SPOON_API_URL=https://phosphorus31.org/api/spoons

# Telemetry API URL (optional)
TELEMETRY_API_URL=https://your-telemetry-api.com

# ============================================
# Optional - Webhook Server Configuration
# ============================================

# Port for webhook server (Express)
NODE_ONE_WEBHOOK_PORT=3000

# Response timeout for API health checks (ms)
RESPONSE_TIMEOUT_MS=5000

# ============================================
# Optional - Feature Toggles
# ============================================

# Enable Fawn detection (true/false)
ENABLE_FAWN_DETECTION=true

# Enable telemetry reporting (true/false)
ENABLE_TELEMETRY=true

# Bot version for telemetry
BOT_VERSION=1.0.0

# ============================================
# Optional - Discord Channel IDs
# ============================================

# Channel ID for BONDING match notifications
BONDING_CHANNEL_ID=your_channel_id_here

# Channel ID for Node One hardware alerts
NODE_ONE_CHANNEL_ID=your_channel_id_here

# Channel ID for announcements (Ko-fi, etc.)
ANNOUNCEMENTS_CHANNEL_ID=your_channel_id_here

# ============================================
# Optional - Display Configuration
# ============================================

# Maximum spoons to display in UI
MAX_SPOON_DISPLAY=12

# Maximum LOVE to display in UI
MAX_LOVE_DISPLAY=12
