{
  "name": "p31ca",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "passport:verify": "node scripts/verify-passport.mjs",
    "passport:sync": "node ../../../scripts/sync-passport-to-p31ca.mjs",
    "predeploy": "npm run passport:verify",
    "deploy": "npm run predeploy && npm run build && wrangler pages deploy dist --project-name p31ca --branch=main --commit-dirty=true",
