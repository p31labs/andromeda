    "hub:about:enrich": "node scripts/enrich-mvp-about-pages.mjs",
    "hub:about:fix-hrefs": "node scripts/fix-about-enriched-hrefs.mjs"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.17.1",
    "tailwindcss": "^3.4.19",
    "three": "^0.183.0"
  },
  "devDependencies": {
    "wrangler": "^4.85.0"
  }
}
