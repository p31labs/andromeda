---
export interface Props {
  className?: string
}

const { className = '' } = Astro.props
---

<div id="orchestrator-dashboard" class={`orchestrator-dashboard ${className}`}>
  <div class="dashboard-header">
    <h2 class="dashboard-title">Orchestrator Control Panel</h2>
    <div class="status-badge status-online">
      <span class="status-dot"></span>
      System Online
    </div>
  </div>

  <!-- System Status Card -->
  <div class="card status-card">
    <h3>Biological State</h3>
    <div class="status-grid">
      <div class="metric">
        <div class="metric-label">Spoons Available</div>
        <div class="metric-value" id="spoons-value">--</div>
        <div class="metric-bar">
          <div class="metric-bar-fill" id="spoons-bar"></div>
        </div>
      </div>
      <div class="metric">
        <div class="metric-label">Guardrail Level</div>
        <div class="metric-value" id="guardrail-level">--</div>
        <div class="level-indicator" id="level-indicator">
          <div class="level-dot"></div>
          <div class="level-dot"></div>
          <div class="level-dot"></div>
          <div class="level-dot"></div>
          <div class="level-dot"></div>
        </div>
      </div>
      <div class="metric">
        <div class="metric-label">Time Dilation</div>
        <div class="metric-value" id="dilation-factor">x1.0</div>
      </div>
      <div class="metric">
        <div class="metric-label">Fawn Guard</div>
        <div class="metric-value status" id="fawn-status">Inactive</div>
      </div>
    </div>
  </div>

  <!-- Pending Queue Card -->
  <div class="card queue-card">
    <h3>Pending Action Queue</h3>
    <div class="queue-list" id="queue-list">
      <div class="empty-state">No pending actions</div>
    </div>
  </div>

  <!-- Manual Review Card -->
  <div class="card review-card">
    <h3>Manual Review Required</h3>
    <div class="review-list" id="review-list">
      <div class="empty-state">No actions pending review</div>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="card activity-card">
    <h3>Recent Activity</h3>
    <div class="activity-list" id="activity-list">
      <div class="empty-state">No recent activity</div>
    </div>
  </div>
</div>

<script>
  class OrchestratorDashboard {
    constructor() {
      this.refreshInterval = 10000
      this.init()
    }

    async init() {
      await this.refresh()
      setInterval(() => this.refresh(), this.refreshInterval)
    }

    async refresh() {
      await Promise.all([
        this.refreshStatus(),
        this.refreshQueue(),
        this.refreshManualReview(),
        this.refreshActivity()
      ])
    }

    async refreshStatus() {
      try {
        const res = await fetch('https://p31-orchestrator.trimtab-signal.workers.dev/api/orchestrator/status')
        const data = await res.json()

        document.getElementById('spoons-value').textContent = data.currentSpoons
        document.getElementById('spoons-bar').style.width = `${(data.currentSpoons / 20) * 100}%`
        
        const levelNames = ['Fawn Guard', 'Constrained', 'Supervised', 'Assisted', 'Full Autonomy']
        document.getElementById('guardrail-level').textContent = `${data.guardrailLevel} - ${levelNames[data.guardrailLevel]}`
        
        // Calculate dilation factor
        const k = [0, 0.25, 0.5, 0.75, 1.0]
        const dilation = data.guardrailLevel === 0 ? '∞' : `x${(1 / k[data.guardrailLevel]).toFixed(2)}`
        document.getElementById('dilation-factor').textContent = dilation

        // Update level indicator
        const dots = document.querySelectorAll('#level-indicator .level-dot')
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i <= data.guardrailLevel)
        })

        document.getElementById('fawn-status').textContent = data.fawnGuardActive ? 'ACTIVE' : 'Inactive'
        document.getElementById('fawn-status').classList.toggle('status-danger', data.fawnGuardActive)
        document.getElementById('fawn-status').classList.toggle('status-success', !data.fawnGuardActive)

      } catch (e) {
        console.error('Failed to fetch status:', e)
      }
    }

    async refreshQueue() {
      try {
        const res = await fetch('https://p31-orchestrator.trimtab-signal.workers.dev/api/orchestrator/queue')
        const data = await res.json()
        const container = document.getElementById('queue-list')

        if (data.count === 0) {
          container.innerHTML = '<div class="empty-state">No pending actions</div>'
          return
        }

        container.innerHTML = data.items.map(item => `
          <div class="queue-item">
            <div class="queue-item-header">
              <span class="action-name">${item.action}</span>
              <span class="priority priority-${item.priority >= 7 ? 'high' : item.priority >= 4 ? 'medium' : 'low'}">P${item.priority}</span>
            </div>
            <div class="queue-item-meta">
              Scheduled: ${new Date(item.scheduled_at).toLocaleTimeString()}
              ${item.attempts > 0 ? ` | Attempts: ${item.attempts}` : ''}
            </div>
          </div>
        `).join('')

      } catch (e) {
        console.error('Failed to fetch queue:', e)
      }
    }

    async refreshManualReview() {
      try {
        const res = await fetch('https://p31-orchestrator.trimtab-signal.workers.dev/api/orchestrator/manual-review')
        const data = await res.json()
        const container = document.getElementById('review-list')

        if (data.count === 0) {
          container.innerHTML = '<div class="empty-state">No actions pending review</div>'
          return
        }

        container.innerHTML = data.items.map(item => `
          <div class="review-item">
            <div class="review-item-header">
              <span class="action-name">${item.action}</span>
              <span class="review-badge">REVIEW REQUIRED</span>
            </div>
            <div class="review-item-reason">${item.reason}</div>
            <div class="review-item-meta">
              Blocked at ${new Date(item.created_at).toLocaleString()}
            </div>
            <button 
              class="approve-btn" 
              onclick="orchestratorDashboard.approveAction('${item.id}')"
            >
              Approve & Execute
            </button>
          </div>
        `).join('')

      } catch (e) {
        console.error('Failed to fetch review queue:', e)
      }
    }

    async refreshActivity() {
      try {
        const res = await fetch('https://p31-orchestrator.trimtab-signal.workers.dev/api/orchestrator/audit-log?limit=10')
        const data = await res.json()
        const container = document.getElementById('activity-list')

        if (data.count === 0) {
          container.innerHTML = '<div class="empty-state">No recent activity</div>'
          return
        }

        container.innerHTML = data.items.map(item => `
          <div class="activity-item ${item.approved ? 'approved' : 'blocked'}">
            <div class="activity-icon">${item.approved ? '✓' : '🛡️'}</div>
            <div class="activity-content">
              <div class="activity-action">${item.action}</div>
              <div class="activity-meta">
                ${new Date(item.created_at).toLocaleString()}
                ${item.delay_ms > 0 ? ` | Delay: ${Math.round(item.delay_ms / 60000)}m` : ''}
              </div>
              <div class="activity-reason">${item.reason}</div>
            </div>
          </div>
        `).join('')

      } catch (e) {
        console.error('Failed to fetch activity:', e)
      }
    }

    async approveAction(auditId) {
      try {
        await fetch(`https://p31-orchestrator.trimtab-signal.workers.dev/api/orchestrator/approve/${auditId}`, {
          method: 'POST'
        })
        await this.refresh()
      } catch (e) {
        console.error('Failed to approve action:', e)
      }
    }
  }

  window.orchestratorDashboard = new OrchestratorDashboard()
</script>

<style>
  .orchestrator-dashboard {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .dashboard-title {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 600;
    color: #e2e8f0;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 9999px;
    color: #10b981;
    font-weight: 500;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .card {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
  }

  .card h3 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #f1f5f9;
  }

  .status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .metric {
    text-align: center;
  }

  .metric-label {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-value {
    font-size: 2rem;
    font-weight: 700;
    color: #f8fafc;
    margin-bottom: 0.5rem;
  }

  .metric-bar {
    width: 100%;
    height: 6px;
    background: rgba(148, 163, 184, 0.1);
    border-radius: 9999px;
    overflow: hidden;
  }

  .metric-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #ef4444, #f59e0b, #10b981);
    border-radius: 9999px;
    transition: width 0.3s ease;
  }

  .level-indicator {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .level-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(148, 163, 184, 0.2);
    transition: all 0.3s ease;
  }

  .level-dot.active {
    background: #10b981;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  }

  .status-success { color: #10b981; }
  .status-danger { color: #ef4444; }

  .empty-state {
    text-align: center;
    padding: 2rem;
    color: #64748b;
    font-size: 0.875rem;
  }

  .queue-item {
    padding: 1rem;
    background: rgba(148, 163, 184, 0.05);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }

  .queue-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .action-name {
    font-family: monospace;
    font-weight: 500;
    color: #e2e8f0;
  }

  .priority {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .priority-high { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
  .priority-medium { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
  .priority-low { background: rgba(148, 163, 184, 0.2); color: #94a3b8; }

  .queue-item-meta {
    font-size: 0.75rem;
    color: #64748b;
  }

  .review-item {
    padding: 1rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }

  .review-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .review-badge {
    padding: 0.25rem 0.5rem;
    background: rgba(239, 68, 68, 0.2);
    color: #ef4444;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .review-item-reason {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.5rem;
  }

  .review-item-meta {
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 0.75rem;
  }

  .approve-btn {
    width: 100%;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .approve-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
  }

  .activity-item {
    display: flex;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 8px;
    margin-bottom: 0.5rem;
  }

  .activity-item.approved {
    background: rgba(16, 185, 129, 0.05);
    border-left: 3px solid #10b981;
  }

  .activity-item.blocked {
    background: rgba(245, 158, 11, 0.05);
    border-left: 3px solid #f59e0b;
  }

  .activity-icon {
    font-size: 1.25rem;
    width: 24px;
    text-align: center;
  }

  .activity-action {
    font-weight: 500;
    color: #e2e8f0;
    margin-bottom: 0.25rem;
  }

  .activity-meta {
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 0.25rem;
  }

  .activity-reason {
    font-size: 0.875rem;
    color: #94a3b8;
  }
</style>
