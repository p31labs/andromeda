---
/**
 * Shared site footer — nonprofit identity, cross-links to static MVP hub.
 */
---

<footer class="relative z-10 border-t border-white/10 mt-20 py-10 px-6">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-6 text-sm text-white/50">
    <div class="font-mono text-xs leading-relaxed">
      <span class="text-white/70 font-semibold">P31 Labs, Inc.</span>
      · Georgia nonprofit · EIN 42-1888158
      <br />
      <span class="text-white/40">501(c)(3) application pending.</span>
    </div>
    <nav class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs uppercase tracking-wider">
      <a href="/" class="text-rose-400/90 hover:text-rose-300 transition-colors no-underline">MVP hub</a>
      <a href="/dome" class="text-[#4db8a8]/90 hover:text-[#4db8a8] transition-colors no-underline" title="Sovereign Cockpit (K₄)">/dome</a>
      <a href="/observatory.html" class="text-white/50 hover:text-white/80 transition-colors no-underline" title="Geodesic panel map">Observatory</a>
      <a href="/lattice.html" class="text-white/50 hover:text-white/80 transition-colors no-underline">Lattice</a>
      <a href="https://phosphorus31.org" target="_blank" rel="noopener noreferrer" class="text-cyan-400/90 hover:text-cyan-300 transition-colors no-underline">phosphorus31.org</a>
      <a href="/open-doc-suite.html" class="text-white/50 hover:text-white/80 transition-colors no-underline" title="Git-native office pack (letterhead, Forge)">Open Doc Suite</a>
      <a href="https://github.com/p31labs/andromeda" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white/80 transition-colors no-underline">GitHub</a>
    </nav>
  </div>
</footer>
