---
/**
 * Genesis Block — Code-themed telemetry visualization section.
 * Displays the P31 genesis event architecture as a terminal-style panel.
 */

const events = [
  { name: 'ATOM_PLACED', source: 'gameStore.endDrag()', color: 'text-phosphor' },
  { name: 'MOLECULE_COMPLETED', source: 'gameStore.endDrag()', color: 'text-amber' },
  { name: 'ACHIEVEMENT_UNLOCKED', source: 'gameStore.endDrag()', color: 'text-purple-400' },
  { name: 'PING_SENT', source: 'PingBar.handlePing()', color: 'text-blue-400' },
  { name: 'PING_RECEIVED', source: 'gameStore.addPing()', color: 'text-blue-300' },
  { name: 'DIFFICULTY_CHANGED', source: 'gameStore.setMode()', color: 'text-white/50' },
];
---

<section id="genesis" class="px-6 py-24 max-w-5xl mx-auto">
  <div class="text-center mb-16">
    <span class="font-mono text-xs text-amber/50 tracking-[0.2em] uppercase">Infrastructure</span>
    <h2 class="text-3xl md:text-4xl font-bold mt-3 text-white/90">Genesis Block</h2>
    <p class="text-white/30 mt-3 max-w-lg mx-auto">
      Every interaction emits a typed event. The telemetry layer captures engagement without surveillance.
    </p>
  </div>

  <!-- Terminal-style event bus visualization -->
  <div class="glass-panel p-6 font-mono text-sm overflow-hidden">
    <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/[0.06]">
      <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
      <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
      <span class="ml-3 text-white/20 text-xs">genesis/eventBus.ts</span>
    </div>

    <div class="space-y-2">
      <div class="text-white/20">
        <span class="text-purple-400">enum</span> <span class="text-white/60">GameEventType</span> {'{'}
      </div>

      {events.map((evt) => (
        <div class="pl-6 flex items-center gap-4">
          <span class={evt.color}>{evt.name}</span>
          <span class="text-white/10">// {evt.source}</span>
        </div>
      ))}

      <div class="text-white/20">{'}'}</div>

      <div class="mt-4 pt-3 border-t border-white/[0.04]">
        <span class="text-white/15">// eventBus → economyStore + telemetryStore</span>
      </div>
      <div>
        <span class="text-white/15">// IDB-keyval persistence · 30s flush · Cloudflare Worker relay</span>
      </div>
    </div>
  </div>
</section>
