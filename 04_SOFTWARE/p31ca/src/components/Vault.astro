---
/**
 * The Vault — Minimalist Hero.
 * "Isostatically Rigid" tagline with phosphor green accent.
 */
---

<section class="relative flex flex-col items-center justify-center min-h-[80vh] px-6 text-center">
  <div class="space-y-6 max-w-2xl">
    <!-- Sigil -->
    <div class="flex items-center justify-center gap-3 text-white/20 font-mono text-sm tracking-[0.3em] uppercase">
      <span class="w-8 h-px bg-white/10"></span>
      P31 LABS
      <span class="w-8 h-px bg-white/10"></span>
    </div>

    <!-- Tagline -->
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-none">
      <span class="text-white">Isostatically</span>
      <br />
      <span class="text-phosphor phosphor-glow">Rigid.</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-white/40 font-light max-w-md mx-auto leading-relaxed">
      Cognitively sovereign infrastructure for the neurodivergent builder.
    </p>

    <!-- CTA -->
    <div class="flex items-center justify-center gap-4 pt-4">
      <a
        href="#deployments"
        class="glass-panel glass-panel-hover px-6 py-3 font-mono text-sm text-phosphor/80 hover:text-phosphor transition-colors"
      >
        View Deployments
      </a>
      <a
        href="#methodology"
        class="px-6 py-3 font-mono text-sm text-white/30 hover:text-white/60 transition-colors"
      >
        Methodology
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/10">
    <span class="text-[10px] font-mono tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/10 to-transparent"></div>
  </div>
</section>
