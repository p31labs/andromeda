---
/**
 * Active Deployments — Status grid for live P31 projects.
 * BONDING and Spaceship Earth.
 */

const deployments = [
  {
    name: 'EDE',
    label: 'Everything Development Environment',
    description: 'Flagship cognitive IDE. Progressive disclosure (FULL/LOW/MINIMAL), Trimtab rotary, Babel/React sandbox, code entropy via PID, Fawn Guard, Layer 0 breathing mode.',
    stack: ['Babel', 'React', 'IndexedDB', 'WebAudio', 'JSZip'],
    status: 'live' as const,
    href: '/ede.html?from=hub',
    metrics: null,
  },
  {
    name: 'BONDING',
    label: 'Molecule Builder',
    description: 'Molecule-building chemistry game for children ages 6+. AuDHD-optimized haptics, sonification, and spoon-aware cognitive load management.',
    stack: ['React', 'Three.js', 'Zustand', 'Cloudflare Workers'],
    status: 'live' as const,
    href: 'https://bonding.p31ca.org?from=hub',
    metrics: { tests: 485, achievements: 12, molecules: 33 },
  },
  {
    name: 'Spaceship Earth',
    label: 'Systems Simulator',
    description: 'Environmental systems simulator. Planetary-scale resource management with real-time feedback loops.',
    stack: ['Astro', 'D3.js', 'WebGL'],
    status: 'dev' as const,
    href: 'https://spaceship-earth.pages.dev?from=hub',
    metrics: null,
  },
];
---

<section id="deployments" class="px-6 py-24 max-w-5xl mx-auto">
  <div class="text-center mb-16">
    <span class="font-mono text-xs text-phosphor/50 tracking-[0.2em] uppercase">Systems</span>
    <h2 class="text-3xl md:text-4xl font-bold mt-3 text-white/90">Active Deployments</h2>
    <p class="text-white/30 mt-3 max-w-lg mx-auto">
      Production systems built with the P31 methodology.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {deployments.map((d) => (
      <a href={d.href} class="glass-panel glass-panel-hover p-6 flex flex-col gap-4 no-underline" style="text-decoration:none">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-bold text-lg text-white/90 font-mono tracking-wide">{d.name}</h3>
            {d.label && <div class="text-[10px] font-mono text-white/25 tracking-wide mt-0.5">{d.label}</div>}
          </div>
          <span class={`text-[10px] font-mono uppercase tracking-wider px-2.5 py-1 rounded-full border ${d.status === 'live' ? 'status-live' : 'status-dev'}`}>
            {d.status}
          </span>
        </div>

        <p class="text-sm text-white/35 leading-relaxed">{d.description}</p>

        <!-- Stack tags -->
        <div class="flex flex-wrap gap-2">
          {d.stack.map((s) => (
            <span class="text-[11px] font-mono text-white/20 bg-white/[0.04] px-2 py-0.5 rounded">
              {s}
            </span>
          ))}
        </div>

        <!-- Metrics (if live) -->
        {d.metrics && (
          <div class="flex gap-6 pt-2 border-t border-white/[0.04]">
            <div class="text-center">
              <div class="font-mono text-phosphor text-lg font-bold">{d.metrics.tests}</div>
              <div class="text-[10px] text-white/20 uppercase">Tests</div>
            </div>
            <div class="text-center">
              <div class="font-mono text-amber text-lg font-bold">{d.metrics.achievements}</div>
              <div class="text-[10px] text-white/20 uppercase">Achievements</div>
            </div>
            <div class="text-center">
              <div class="font-mono text-white/60 text-lg font-bold">{d.metrics.molecules}</div>
              <div class="text-[10px] text-white/20 uppercase">Molecules</div>
            </div>
          </div>
        )}
      </a>
    ))}
  </div>

  <!-- Ops dashboards row -->
  <div class="flex gap-4 mt-6 justify-center">
    <a href="/health.html?from=hub" class="text-xs font-mono text-white/30 hover:text-phosphor transition-colors">System Health →</a>
    <span class="text-white/10">·</span>
    <a href="/telemetry.html?from=hub" class="text-xs font-mono text-white/30 hover:text-phosphor transition-colors">Telemetry →</a>
  </div>
</section>
