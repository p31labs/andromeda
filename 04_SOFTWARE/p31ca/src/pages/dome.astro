---
/**
 * Sovereign Cockpit Dome Page
 * Full 3D interactive K4 topology visualization
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="P31 Labs | Sovereign Cockpit" data-i18n-title="page.title" shellBackdrop={false}>
  <!-- Noscript fallback for JS-disabled users -->
  <noscript>
    <div class="fixed inset-0 bg-black/90 flex flex-col items-center justify-center z-50 p-6 text-center">
      <h2 class="text-2xl font-bold text-p31-cloud mb-4" data-i18n="noscript.title">JavaScript Required</h2>
      <p class="text-p31-cloud-80 mb-6" data-i18n="noscript.description">
        The Sovereign Cockpit Dome requires JavaScript to render the 3D visualization 
        and interactive elements. Please enable JavaScript in your browser settings.
      </p>
      <a href="/" class="px-6 py-3 bg-white/20 hover:bg-white/30 text-p31-cloud rounded transition-colors" data-i18n="noscript.backLink">Back to hub</a>
    </div>
    <!-- CSS-only rotating tetrahedron SVG fallback -->
    <div class="fixed inset-0 flex items-center justify-center bg-p31-void" aria-label="Fallback loading animation">
      <svg class="w-48 h-48 animate-spin text-cyan" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M50 15 L85 85 L15 85 Z"/>
      </svg>
    </div>
  </noscript>

    <!-- Three.js Import Map -->
   <script type="importmap" is:inline>
     {
       "imports": {
         "three": "https://unpkg.com/three@0.183.0/build/three.module.js",
         "three/addons/": "https://unpkg.com/three@0.183.0/examples/jsm/"
       }
     }
   </script>
   
   <!-- Dev-only: axe-core for accessibility testing -->
   <script>
    (function() {
      const isDev = location.hostname === 'localhost' || location.search.includes('dev=true');
      if (!isDev) return;
      
      const script = document.createElement('script');
      script.src = 'https://cdnjs.cloudflare.com/ajax/libs/axe-core/4.10.2/axe.min.js';
      script.integrity = 'sha512-7pGz0H1ggXYz8Y4lUYj3G01+n2xK4FukK4nYg9B1Dk+X3t0cE6zYjv3n4Ml+CKc+FL5Y5nBepzr8+fL0p5T+XQ==';
      script.crossOrigin = 'anonymous';
      script.referrerPolicy = 'no-referrer';
      document.head.appendChild(script);
    })();
   </script>

  <!-- THREE: fixed stacking context; shellBackdrop off above so EDE grid does not sit on canvas -->
  <div id="webgl-container" class="fixed inset-0 z-[20] isolate"></div>
  <div class="ambient-grid fixed inset-0 z-[21] pointer-events-none"></div>

   <!-- Boot Sequence -->
   <div id="loading-screen" class="fixed inset-0 z-[200] bg-p31-void flex flex-col items-center justify-center font-mono text-cyan" role="status" aria-live="polite">
     <svg width="64" height="64" viewBox="0 0 512 512" class="mb-8 animate-pulse"><rect width="512" height="512" rx="112" fill="#25897d"/><circle cx="390" cy="120" r="48" fill="#cc6247"/><text x="256" y="340" font-family="system-ui" font-weight="900" font-size="220" fill="#d8d6d0" text-anchor="middle">P31</text><rect x="156" y="380" width="200" height="16" rx="8" fill="#cda852"/></svg>
     <div class="text-xs tracking-[0.3em] uppercase" data-i18n="loading.title">Materializing K4 Tetrahedron</div>
     <div class="w-48 h-1 bg-surface mt-4 overflow-hidden rounded-full">
       <div id="loading-bar" class="h-full bg-cyan w-0 transition-all duration-100"></div>
     </div>
     <div id="loading-text" class="text-xs mt-2 text-p31-cloud" data-i18n="loading.initializing">Initializing...</div>
     <div id="loading-details" class="text-xs mt-1 text-p31-muted-60" data-i18n="loading.details">Loading 3D scene</div>
     <!-- Skeleton loader for tetrahedron wireframe -->
     <div id="skeleton-loader" class="mt-6 w-48 h-48 opacity-30">
       <svg class="w-full h-full" viewBox="0 0 100 100" stroke="currentColor" stroke-width="1" fill="none">
         <path d="M50 10 L90 80 L10 80 Z" stroke-dasharray="200" stroke-dashoffset="0">
           <animate attributeName="stroke-dashoffset" from="200" to="0" dur="2s" repeatCount="indefinite"/>
         </path>
       </svg>
     </div>
   </div>

   <!-- Keyboard Shortcuts Overlay -->
   <div id="keyboard-shortcuts-overlay" class="fixed inset-0 z-[900] bg-black/80 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200" role="dialog" aria-label="Keyboard shortcuts" aria-modal="true">
     <div class="glass-panel p-6 rounded-xl max-w-md w-full mx-4">
       <div class="flex justify-between items-center mb-4">
         <h2 class="text-lg font-bold text-p31-cloud" data-i18n="shortcuts.title">Keyboard Shortcuts</h2>
         <button id="close-shortcuts" class="text-p31-muted hover:text-p31-cloud p-1" data-i18n-aria-label="shortcuts.close" aria-label="Close shortcuts">✕</button>
       </div>
       <div class="space-y-3 text-sm font-mono">
         <div class="flex justify-between">
           <span class="text-p31-cloud-70" data-i18n="shortcuts.focusSearch">Focus search</span>
           <kbd class="px-2 py-1 bg-p31-void-50 border border-white/20 rounded">/</kbd>
         </div>
         <div class="flex justify-between">
           <span class="text-p31-cloud-70" data-i18n="shortcuts.toggleUI">Toggle HUD</span>
           <kbd class="px-2 py-1 bg-p31-void-50 border border-white/20 rounded">Tab</kbd>
         </div>
         <div class="flex justify-between">
           <span class="text-p31-cloud-70" data-i18n="shortcuts.activateLayer0">Activate Layer 0</span>
           <kbd class="px-2 py-1 bg-p31-void-50 border border-white/20 rounded">Esc</kbd>
         </div>
       </div>
       <div class="mt-4 text-xs text-p31-muted-60" data-i18n="shorttips.prompt">Press any key to close</div>
     </div>
   </div>

   <!-- TOP HUD: System Telemetry -->
   <nav
     class="fixed left-0 right-0 top-0 z-50 flex transform flex-col gap-3 border-b border-white/5 glass-panel pl-[max(0.75rem,env(safe-area-inset-left))] pr-[max(0.75rem,env(safe-area-inset-right))] pt-[max(0.5rem,env(safe-area-inset-top))] pb-2 text-sm font-mono text-p31-cloud transition-all duration-300 translate-y-0 md:flex-row md:items-center md:justify-between md:gap-4 md:px-4 md:py-2 md:text-xs"
     id="top-hud"
     aria-label="System telemetry and controls"
   >
     <!-- HUD Header -->
     <div class="flex items-center justify-between w-full">
       <!-- Left: Logo & Q-Factor -->
       <div class="flex items-center gap-4">
         <div class="flex items-center gap-2 font-bold text-p31-cloud tracking-widest uppercase">
            <svg width="18" height="18" viewBox="0 0 512 512" class="opacity-90"><rect width="512" height="512" rx="112" fill="#25897d"/><circle cx="390" cy="120" r="48" fill="#cc6247"/><text x="256" y="340" font-family="system-ui" font-weight="900" font-size="220" fill="#d8d6d0" text-anchor="middle">P31</text><rect x="156" y="380" width="200" height="16" rx="8" fill="#cda852"/></svg>
            <span data-i18n="hud.cockpit">Cockpit</span>
         </div>
         <div class="h-4 w-px bg-white/10"></div>
          <div class="flex items-center gap-2 cursor-help" title="Fisher-Escolà Coherence Score" data-i18n-title="hud.qFactor.title">
            <span class="w-2 h-2 rounded-full bg-emerald shadow-[0_0_8px_#3ba372] animate-pulse" id="hud-q-dot"></span>
            <span class="text-p31-muted" data-i18n="hud.qFactor.label">Q-FACTOR:</span>
            <span class="font-bold text-emerald tracking-wider" id="hud-q-val" data-i18n="hud.qFactor.value">0.925</span>
          </div>
       </div>
       
       <!-- Right: Volume Control & Status -->
       <div class="flex items-center gap-4">
          <!-- Volume Control with Mute Toggle -->
          <div class="flex items-center gap-2" data-i18n-title="hud.volume.title" title="Ambient Volume">
            <button id="volume-mute-btn" class="text-p31-muted hover:text-p31-cloud transition-colors p-1" aria-label="Toggle mute" data-i18n-aria-label="hud.volume.mute" type="button">
             <svg id="volume-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
               <path d="M11 5L6 9H2v6h4l5 4V5z"/>
               <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
             </svg>
             <svg id="mute-icon" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
               <path d="M11 5L6 9H2v6h4l5 4V5z"/>
               <line x1="23" y1="9" x2="17" y2="15"/>
             </svg>
           </button>
            <div class="relative" data-i18n-title="hud.volume.title">
              <button id="volume-slider-container" class="w-20 h-6 bg-p31-void-50 border border-white/20 rounded-lg overflow-hidden hover:bg-p31-void-70 transition-colors focus:outline-none focus:ring-2 focus:ring-cyan focus:ring-offset-2 focus:ring-offset-[var(--p31-void)]" type="button" aria-label="Volume control" data-i18n-aria-label="hud.volume.sliderLabel">
                <div class="flex items-center h-full relative">
                  <div id="volume-track" class="h-1 bg-surface rounded-full absolute inset-y-1 left-1 right-1"></div>
                  <div id="volume-fill" class="h-1 bg-cyan rounded-full absolute inset-y-1 left-1 transition-all duration-100"></div>
                  <div id="volume-thumb" class="w-3 h-3 bg-cyan rounded-full absolute top-1.5 transition-transform duration-100" style="left: calc(1px + 70% * 0.85);"></div>
                </div>
              </button>
              <div id="volume-tooltip" class="absolute top-full left-1/2 transform -translate-x-1/2 mt-2 bg-black/90 text-p31-cloud text-xs px-2 py-1 rounded opacity-0 pointer-events-none transition-opacity duration-100" data-i18n="hud.volume.tooltip">
                70%
              </div>
            </div>
         </div>
         
          <!-- Connection Status -->
          <div class="flex items-center gap-1">
            <div id="connection-status" class="w-2 h-2 rounded-full bg-emerald" title="Connection status" aria-label="Connected" data-i18n-title="hud.connection.status.title" data-i18n-aria-label="hud.connection.status.connected"></div>
            <span class="text-p31-muted text-xs hidden sm:inline" data-i18n="hud.connection.label">SYNC</span>
          </div>
         
          <!-- Dev Mode Performance Indicators -->
          <div id="performance-indicators" class="hidden md:flex items-center gap-2 text-xs text-p31-cloud-60">
            <span data-i18n="perf.render">Render: <span id="render-time">0</span>ms</span>
            <span data-i18n="perf.fps">FPS: <span id="fps-counter">60</span></span>
            <span id="webgl-status" class="text-emerald">✓</span>
            <!-- Accessibility Scan Button (dev only) -->
            <button id="a11y-scan-btn" class="ml-2 px-2 py-1 bg-white/5 hover:bg-white/10 rounded text-xs" data-i18n="a11y.scanButton" type="button">A11y Scan</button>
            <!-- Theme Variant Switcher (A/B test) -->
            <button id="theme-toggle-btn" class="ml-2 px-2 py-1 bg-white/5 hover:bg-white/10 rounded text-xs" data-i18n="theme.toggle" type="button">Theme: A</button>
          </div>

          <!-- UI Toggle -->
          <button id="ui-toggle-btn" class="text-p31-muted hover:text-p31-cloud transition-colors p-1" aria-label="Toggle heads-up display" data-i18n-aria-label="hud.toggleUI" type="button">[UI]</button>
       </div>
     </div>
     
     <!-- Collapsible HUD Content -->
     <div id="hud-content" class="w-full mt-2 space-y-2 opacity-100 transition-opacity duration-300">
       <!-- Thermodynamics & Economy -->
       <div class="flex items-center gap-6 bg-p31-void-50 px-5 py-1.5 rounded-md border border-white/5 shadow-center">
          <div class="flex items-center gap-2 cursor-help" title="Vertex A: Operator State" data-i18n-title="hud.spoons.title">
            <span class="text-p31-muted" data-i18n="hud.spoons.label">SPOONS</span>
            <div class="w-20 h-1.5 bg-surface rounded-full overflow-hidden">
              <div id="hud-spoon-fill" class="h-full bg-coral transition-all duration-500" style="width: 75%;"></div>
            </div>
            <span id="hud-spoon-val" class="text-coral font-bold w-4 text-right" data-i18n="hud.spoons.value">15</span>
          </div>
          <div class="h-3 w-px bg-white/10"></div>
          <div class="flex items-center gap-2 cursor-help" title="L.O.V.E. Ledger Balance" data-i18n-title="hud.love.title">
            <span class="text-p31-muted" data-i18n="hud.love.label">L.O.V.E.</span>
            <span id="hud-love-val" class="text-cyan font-bold" data-i18n="hud.love.value">3.28</span>
          </div>
          <div class="h-3 w-px bg-white/10 hidden md:block"></div>
          <div class="hidden md:flex items-center gap-2 cursor-help" title="Active K4 Vertices" data-i18n-title="hud.fleet.title">
            <span class="text-p31-muted" data-i18n="hud.fleet.label">FLEET:</span>
            <span class="text-p31-cloud font-bold" data-i18n="hud.fleet.value">4/4</span>
          </div>
          <div class="h-3 w-px bg-white/10 hidden lg:block"></div>
          <div
            class="hidden lg:flex items-center gap-2"
            title="As above, so below — p31ca HUD ↔ k4-personal edge"
          >
            <span class="text-p31-muted">MESH</span>
            <span id="hud-mesh-vit" class="font-bold text-lavender">—</span>
            <span class="text-p31-muted text-[10px]">L♥</span>
            <span id="hud-mesh-ve" class="text-p31-cloud text-[10px] font-mono">—</span>
            <span id="hud-mesh-detail" class="text-p31-muted text-[9px] font-mono max-w-[6rem] truncate hidden xl:inline" title=""> </span>
            <a href="/mesh-observatory/" class="text-lavender hover:text-lavender/80 hover:underline text-[10px] font-bold" title="Mesh Observatory">OBS</a>
          </div>
       </div>

      <!-- Trimtab & Actions -->
        <div class="flex items-center gap-4">
         <div class="flex items-center gap-2 cursor-pointer group" id="trimtab-trigger" title="Drag to tune frequency · Click for Layer 0 Somatic Mode" role="slider" aria-label="Trimtab frequency control" data-i18n-aria-label="hud.trimtab.label" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
           <canvas id="trimtab-canvas" width="24" height="24" class="opacity-70 group-hover:opacity-100 transition-opacity" aria-hidden="true"></canvas>
           <span id="trimtab-freq" class="text-amber font-bold w-12" data-i18n="hud.trimtab.frequency">863Hz</span>
         </div>
       </div>
     </div>
   </nav>

   <!-- LEFT HUD: Filters & Legend -->
   <aside
     class="hud-element fixed bottom-[max(1rem,env(safe-area-inset-bottom))] left-4 z-40 flex max-w-[min(100%,20rem)] flex-col gap-4 sm:left-6 md:bottom-6"
     id="left-hud"
     aria-label="Topology filters"
   >
     <!-- Controls -->
     <div class="glass-panel p-4 rounded-xl flex flex-col gap-3">
       <input type="text" id="search-input" placeholder="Search topology..." data-i18n-placeholder="search.placeholder" class="min-h-[2.75rem] w-full rounded-md border border-white/10 bg-p31-void-80 px-3 py-2 font-mono text-base text-p31-cloud outline-none transition-colors placeholder-muted focus:border-cyan md:min-h-0 md:py-1.5 md:text-xs" aria-label="Search topology nodes" data-i18n-aria-label="search.ariaLabel">

      <div class="flex flex-wrap gap-1.5 max-w-[220px]" id="axis-filters" role="group" aria-label="Filter by axis" data-i18n-aria-label="filters.groupLabel">
        <button class="px-2 py-1 text-[9px] font-mono tracking-wider uppercase rounded bg-white/10 border border-white/20 text-p31-cloud" data-axis="all" aria-label="Show all axes" aria-pressed="true" data-i18n="filters.all" data-i18n-aria-label="filters.allAria">ALL</button>
        <button class="px-2 py-1 text-[9px] font-mono tracking-wider uppercase rounded bg-p31-void border border-white/5 text-[#ff9944] hover:bg-white/5" data-axis="a" aria-label="Show Body axis only" aria-pressed="false" data-i18n="filters.body" data-i18n-aria-label="filters.bodyAria">Body</button>
        <button class="px-2 py-1 text-[9px] font-mono tracking-wider uppercase rounded bg-p31-void border border-white/5 text-[#44aaff] hover:bg-white/5" data-axis="b" aria-label="Show Mesh axis only" aria-pressed="false" data-i18n="filters.mesh" data-i18n-aria-label="filters.meshAria">Mesh</button>
        <button class="px-2 py-1 text-[9px] font-mono tracking-wider uppercase rounded bg-p31-void border border-white/5 text-[#44ffaa] hover:bg-white/5" data-axis="c" aria-label="Show Forge axis only" aria-pressed="false" data-i18n="filters.forge" data-i18n-aria-label="filters.forgeAria">Forge</button>
        <button class="px-2 py-1 text-[9px] font-mono tracking-wider uppercase rounded bg-p31-void border border-white/5 text-[#ff4466] hover:bg-white/5" data-axis="d" aria-label="Show Shield axis only" aria-pressed="false" data-i18n="filters.shield" data-i18n-aria-label="filters.shieldAria">Shield</button>
      </div>
     </div>

     <!-- Legend -->
     <div class="glass-panel p-4 rounded-xl text-[10px] font-mono">
       <div class="text-p31-muted mb-2 pb-2 border-b border-white/10" id="node-count" data-i18n="stats.nodes">-- NODES</div>
       <div class="flex flex-col gap-1.5">
         <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-emerald"></div><span data-i18n="legend.active">Active</span></div>
         <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-[#25897d]"></div><span data-i18n="legend.deployed">Deployed</span></div>
         <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-amber"></div><span data-i18n="legend.countdown">Countdown</span></div>
         <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-cyan"></div><span data-i18n="legend.research">Research</span></div>
         <div class="flex items-center gap-2"><div class="w-2 h-2 rounded-full bg-coral"></div><span data-i18n="legend.missing">Missing</span></div>
       </div>
       <a href="/geodesic-math/" class="mt-3 inline-block text-[10px] font-mono text-cyan/70 hover:text-cyan underline underline-offset-2">Geodesic math reference</a>
       <p class="mt-1 text-[9px] font-mono text-p31-muted-50 leading-snug">Strict icosa subdivision stats (vs. observatory Three helper). <span class="text-p31-cloud-40">?perf=lite</span> · <span class="text-p31-cloud-40">localStorage p31:dome:perf=lite</span></p>
     </div>
  </aside>

  <!-- RIGHT HUD: Node Inspector -->
  <aside
     id="node-detail-panel"
     class="hud-element pointer-events-none fixed left-4 right-4 top-20 z-40 mx-auto w-full max-w-sm translate-x-10 transform rounded-xl border-t border-l border-white/10 bg-p31-void-95 p-5 opacity-0 shadow-[0_10px_40px_rgba(0,0,0,0.8)] backdrop-blur-sm transition-all duration-300 sm:left-auto sm:right-6 sm:top-16 sm:mx-0 sm:max-w-none sm:w-80 sm:translate-x-10 glass-panel"
   >
     <button id="node-detail-close" class="absolute top-4 right-4 text-p31-muted hover:text-p31-cloud transition-colors pointer-events-auto" data-i18n-aria-label="nodeDetail.close" aria-label="Close node details">✕</button>
     <div class="text-cyan font-bold text-lg mb-1 tracking-tight" id="nd-title" data-i18n="nodeDetail.title">Node Name</div>
     <div class="flex items-center gap-2 text-[10px] font-mono mb-4 pb-3 border-b border-white/10">
       <span id="nd-axis" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70" data-i18n="nodeDetail.axis">Axis</span>
       <span id="nd-state" class="px-2 py-0.5 rounded border uppercase" data-i18n="nodeDetail.state">State</span>
       <span id="nd-bus" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70 uppercase" data-i18n="nodeDetail.bus">Bus</span>
     </div>
    <div id="nd-notes" class="text-sm text-p31-cloud-80 mb-5 leading-relaxed font-sans">Select a node in the geodesic dome to inspect its architectural state and entangled edges.</div>
    <div class="text-[10px] font-mono text-p31-muted mb-2 uppercase tracking-widest">Entangled Edges</div>
    <div id="nd-conns" class="flex flex-wrap gap-2 pointer-events-auto">
      <span class="text-xs text-p31-muted-50 italic">No node selected</span>
    </div>
  </aside>

   <!-- LAYER 0: Somatic Breathing Mode (Full Screen Takeover) -->
   <div id="layer0" class="fixed inset-0 z-[100] bg-p31-void-95 backdrop-blur-md flex flex-col items-center justify-center gap-6 transition-all duration-1000 opacity-0 pointer-events-none">
     <div class="absolute top-12 left-1/2 -translate-x-1/2 flex items-center gap-4 font-mono text-xs text-p31-muted glass-panel px-6 py-3 rounded-full">
       <span data-i18n="layer0.spoonsLabel">SPOONS</span>
       <div class="w-48 h-1 bg-surface rounded-full overflow-hidden">
         <div id="l0-spoon-fill" class="h-full bg-coral transition-all duration-500"></div>
       </div>
       <span id="l0-spoon-pct" class="text-coral font-bold">75%</span>
     </div>

     <!-- Central Breathing Dot -->
     <div id="l0-dot" class="w-24 h-24 rounded-full bg-coral opacity-40 transform scale-75 shadow-[0_0_60px_rgba(232,99,111,0.3)]"></div>
     <div id="l0-phase" class="text-3xl font-mono font-bold text-coral tracking-[0.3em] uppercase mt-8" data-i18n="layer0.inhale">INHALE</div>

     <div class="absolute bottom-16 flex flex-col items-center gap-4 glass-panel px-8 py-4 rounded-xl">
       <div class="w-40 h-1.5 bg-surface rounded-full overflow-hidden">
         <div id="l0-escape-fill" class="h-full w-0 bg-coral shadow-[0_0_10px_#E8636F]"></div>
       </div>
       <div class="text-[10px] font-mono text-p31-muted tracking-widest uppercase" data-i18n="layer0.escapeHint">Hold ESC for 3 seconds to disengage</div>
       <div class="text-[9px] font-mono text-cyan tracking-widest uppercase opacity-50 mt-2" data-i18n="layer0.larmorFreq">Larmor Frequency: 863Hz Active</div>
     </div>
   </div>
</BaseLayout>

<style is:global>
  body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background-color: var(--p31-void); color: var(--p31-cloud); }
  /* #webgl-container: fixed+z-index from markup — do not opacity-hide here; splash (#loading-screen) covers until JS dismisses */

  .glass-panel {
    background: rgba(12, 14, 20, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .ambient-grid {
    background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.1;
  }

   /* Custom Scrollbar */
