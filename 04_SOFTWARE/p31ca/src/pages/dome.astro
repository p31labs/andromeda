<style is:global>
  body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background-color: var(--p31-void); color: var(--p31-cloud); }
  /* #webgl-container: fixed+z-index from markup — do not opacity-hide here; splash (#loading-screen) covers until JS dismisses */

  .glass-panel {
    background: rgba(12, 14, 20, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  /*
   * Node detail panel — CSS-driven transform for two-axis show/hide.
   * Mobile: slides up from bottom (Y axis). Desktop (sm+): slides in from right (X axis).
   * Kinematics sets inline style.transform during drag; clearing it reverts to CSS.
   * No !important — translate-x-10 Tailwind class removed from HTML, so no conflict.
   */
  #node-detail-panel { transform: translateY(100%); }
  #node-detail-panel:not(.opacity-0) { transform: translateY(0); }
  @media (min-width: 640px) {
    #node-detail-panel { transform: translateX(2.5rem); }
    #node-detail-panel:not(.opacity-0) { transform: translateX(0); }
  }

  .ambient-grid {
    background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.1;
  }

   /* Custom Scrollbar */
   ::-webkit-scrollbar { width: 4px; height: 4px; }
   ::-webkit-scrollbar-track { background: transparent; }
   ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255,0.2); border-radius: 2px; }
   
   /* Reduced motion */
   @media (prefers-reduced-motion: reduce) {
     *, *::before, *::after {
       animation-duration: 0.01ms !important;
       animation-iteration-count: 1 !important;
       transition-duration: 0.01ms !important;
       scroll-behavior: auto !important;
     }
     .animate-spin {
       animation: none !important;
     }
   }
   
   /* Focus-visible styling */
   :focus-visible {
     outline: 2px solid var(--p31-cyan);
     outline-offset: 2px;
   }
   
   /* Keyboard shortcuts overlay */
   #keyboard-shortcuts-overlay {
     backdrop-filter: blur(4px);
     -webkit-backdrop-filter: blur(4px);
   }
   
   #keyboard-shortcuts-overlay kbd {
     font-family: 'JetBrains Mono', monospace;
     background: rgba(12, 14, 20, 0.8);
     border-color: rgba(255, 255, 255, 0.2);
   }

   #dock-fers-panel.fers-ok {
     border-color: rgba(59, 163, 114, 0.35);
   }
   #dock-fers-panel.fers-warn {
     border-color: rgba(205, 168, 82, 0.45);
   }
   #dock-fers-panel.fers-hot {
     border-color: rgba(232, 99, 111, 0.45);
   }
   #dock-fers-panel.fers-critical {
     border-color: rgba(232, 99, 111, 0.65);
     box-shadow: 0 0 0 1px rgba(232, 99, 111, 0.25);
   }

  /* Layer 0 Animations */
  @keyframes l0-inhale { to { transform: scale(1.4); opacity: 1; } }
  @keyframes l0-hold   { from { transform: scale(1.4); opacity: 1; } to { transform: scale(1.4); opacity: 1; } }
  @keyframes l0-exhale { to { transform: scale(0.6); opacity: 0.3; } }

  #loading-screen {
    transition: opacity 1s ease-in-out;
  }

   .hud-element {
     transition: all 0.3s ease;
   }
   
    /* Entrance animation: HUD only (#webgl-container never gated — avoids “grid-only” if body.loaded delays). */
    body:not(.loaded) .hud-element,
    body:not(.loaded) #top-hud {
      opacity: 0;
      transform: translateY(20px);
    }

    body.loaded .hud-element,
    body.loaded #top-hud {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 600ms ease-out, transform 600ms ease-out;
    }
    /* ===============================================
       A/B ACCENT PALETTES
       Variant "tm" (teal-magenta, default) - current
       Variant "cv" (cyan-violet) - alternate
       =============================================== */
    [data-palette="cv"] .text-cyan {
      color: #8b5cf6 !important; /* violet */
    }
    [data-palette="cv"] .bg-cyan {
      background-color: #8b5cf6 !important;
    }
    [data-palette="cv"] .border-cyan {
      border-color: #8b5cf6 !important;
    }
    [data-palette="cv"] #volume-fill {
      background-color: #ec4899 !important; /* magenta for volume */
    }
    [data-palette="cv"] #volume-thumb {
      background-color: #ec4899 !important;
    }
    [data-palette="cv"] .text-emerald {
      color: #a855f7 !important; /* violet alternative */
    }
    [data-palette="cv"] .bg-emerald {
      background-color: #a855f7 !important;
    }
    /* Swap amber to magenta for trimtab */
    [data-palette="cv"] #trimtab-freq,
    [data-palette="cv"] #volume-icon path[stroke="currentColor"] {
      color: #d946ef !important;
    }
    [data-palette="cv"] #trimtab-canvas {
      stroke: #d946ef !important;
    }

    /* View switcher active states */
    #dome-view-nav a[aria-current="true"][data-hash-nav="dome"]    { color:#0ea5e9; border-color:rgba(14,165,233,0.4); }
    #dome-view-nav a[aria-current="true"][data-hash-nav="spatial"] { color:#a78bfa; border-color:rgba(167,139,250,0.4); }

    /* Gray Rock — doctrine §1 / §7 (`?alive=1` skips 3D + HUD withholding in dome-cockpit.ts) */
    body.dome-gray-rock #connection-status {
      filter: grayscale(1);
      opacity: 0.65;
    }
    body.dome-gray-rock #cockpit-instrument-strip,
    body.dome-gray-rock #dome-mode-strip {
      opacity: 0.78;
    }
    body.dome-gray-rock #hud-content {
      opacity: 0.72;
    }
  </style>

<!-- Client cockpit: src/scripts/dome-cockpit.ts; geometry: src/lib/dome/
     Hash-router switches between #dome (Three.js cockpit) and #spatial (Posner physics).
     rAF loops are mutually exclusive — only the active view consumes CPU. -->
<script>
  import '../scripts/dome-cockpit.ts';
  import { mountHashRouter, type HashRouterHandle } from '../lib/hash-router';
  import { createSpatialNavigator, type SpatialHandle } from '../scripts/spatial-navigator';

  type DomeHandle = { unmount(): void; remount(): void };
  const W = window as Record<string, unknown>;

  // One spatial navigator per session (survives SPA navigations).
  if (!W['__p31Spatial']) W['__p31Spatial'] = createSpatialNavigator();
  const spatial = W['__p31Spatial'] as SpatialHandle;
  let router: HashRouterHandle | null = null;

  document.addEventListener('astro:page-load', () => {
    const svgEl = document.getElementById('spatial-svg') as SVGSVGElement | null;

    router = mountHashRouter([
      {
        id: 'dome',
        // No el — cockpit elements are fixed/global; managed via DomeHandle only.
        onEnter: () => (W['__p31Dome'] as DomeHandle | undefined)?.remount(),
        onLeave: () => (W['__p31Dome'] as DomeHandle | undefined)?.unmount(),
      },
      {
        id: 'spatial',
        el: '#spatial',
        title: 'P31 Labs | Posner Ca₉(PO₄)₆',
        onEnter: () => {
          // Stop Three.js rAF before starting physics loop.
          (W['__p31Dome'] as DomeHandle | undefined)?.unmount();
          if (svgEl) spatial.mount(svgEl);
        },
        onLeave: () => spatial.unmount(),
      },
    ], { defaultId: 'dome', navSelector: '#dome-view-nav a' });
  });

  document.addEventListener('astro:before-swap', () => {
    router?.destroy(); router = null;
    spatial.unmount();
    (W['__p31Dome'] as DomeHandle | undefined)?.unmount();
  }, { once: true });
</script>
