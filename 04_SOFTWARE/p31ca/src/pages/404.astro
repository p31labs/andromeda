---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="P31 Labs | 404 Not Found">
  <div class="min-h-screen flex flex-col items-center justify-center text-center">
    <h1 class="text-6xl font-bold mb-4 text-coral">404</h1>
    <p class="text-xl mb-8 text-cloud">Page not found</p>
    <a href="/" class="px-8 py-3 rounded-md font-bold text-white bg-coral/90 hover:bg-coral transition-colors">
      Return to Home
    </a>
  </div>
</BaseLayout>
