---
import AppShell from '../../layouts/AppShell.astro';

---
<AppShell title="Delta Hiring — P31 Labs" routeName="delta-hiring">
  <!-- This is a placeholder for the Delta Hiring interface.
       The actual React/Vite application will be mounted here via client-side routing. -->
  <div id="app" class="min-h-screen flex items-center justify-center bg-p31-void/50">
    <div class="text-center">
      <h1 class="text-2xl font-bold text-p31-cloud mb-4">Delta Hiring</h1>
      <p class="text-p31-cloud/70">Proof-based hiring system for P31 Labs.</p>
      <div class="mt-6 animate-pulse">
        <div class="w-16 h-16 rounded bg-p31-emerald/20 inline-block mr-2"></div>
        <div class="w-16 h-16 rounded bg-p31-emerald/20 inline-block mr-2"></div>
        <div class="w-16 h-16 rounded bg-p31-emerald/20 inline-block mr-2"></div>
      </div>
    </div>
  </div>
</AppShell>