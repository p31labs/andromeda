---
/**
 * P31 Labs Unified Landing Page
 * Product grid + prototypes + research: single source via hub-landing.json
 * (scripts/hub/build-landing-data.mjs from registry.mjs). CWP D2.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import hubLanding from '../data/hub-landing.json';
import groundTruth from '../../ground-truth/p31.ground-truth.json';
import docLibIndex from '../../public/doc-library/index.json';

const coreProducts = hubLanding.coreProducts;
const prototypes = hubLanding.prototypes;
const research = hubLanding.research;

const bondingTests =
  (groundTruth as { canonicalNumbering?: { bondingTestBaseline?: { tests?: number } } }).canonicalNumbering
    ?.bondingTestBaseline?.tests ?? 424;
const docCount =
  typeof (docLibIndex as { count?: unknown }).count === 'number'
    ? (docLibIndex as { count: number }).count
    : 0;
const researchPaperCount = research.length;
const doiCount = new Set(research.map((p: { doi: string }) => p.doi)).size;

/** Curated threshold “doors” — same building, different rooms (live = phosphor, warm = butter). */
const lobbyDoors: {
  title: string;
  meta: string;
  sub: string;
  href: string;
  external?: boolean;
  dot: 'live' | 'warm';
}[] = [
  {
    title: 'BONDING',
    meta: `Known molecular catalog · ${bondingTests} tests · live`,
    sub: 'Build what the body needs — together.',
    href: 'https://bonding.p31ca.org',
    external: true,
    dot: 'live',
  },
  {
    title: 'Cognitive Passport',
    meta: '8 profiles · p31.cognitivePassport/1.0.0 · live',
    sub: 'Control what the world knows about your mind.',
    href: '/passport',
    dot: 'live',
  },
  {
    title: 'Dome / Cockpit',
    meta: '16 face nodes · Q-Factor readout · live',
    sub: 'See the whole mesh at once.',
    href: '/dome/',
    dot: 'live',
  },
  {
    title: 'C.A.R.S.',
    meta: 'your people · no strangers · live',
    sub: 'Same bowl, same room.',
    href: 'https://bonding.p31ca.org/soup',
    external: true,
    dot: 'live',
  },
  {
    title: 'Document Library',
    meta: `${docCount} documents · searchable · live`,
    sub: "Everything we've written down.",
    href: '/doc-library/',
    dot: 'live',
  },
  {
    title: 'Research',
    meta: `${researchPaperCount} papers · ${doiCount} DOIs · live`,
    sub: 'The proof is public.',
    href: '#research-papers',
    dot: 'live',
  },
];

const getStatusStyles = (status: string) => {
  if (status === 'LIVE')
    return {
      text: 'text-phosphorus',
      bg: 'bg-phosphorus/10',
      border: 'border-phosphorus/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(59,163,114,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'BUILDING')
    return {
      text: 'text-butter',
      bg: 'bg-butter/10',
      border: 'border-butter/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(205,168,82,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'HARDWARE')
    return {
      text: 'text-butter',
      bg: 'bg-butter/15',
      border: 'border-butter/35',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(205,168,82,0.25),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'RESEARCH' || status === 'TOOL')
    return {
      text: 'text-teal',
      bg: 'bg-teal/10',
      border: 'border-teal/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(37,137,125,0.22),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  return {
    text: 'text-p31-muted',
    bg: 'bg-p31-muted-10',
    border: 'border-p31-muted-30',
    glow: 'group-hover:shadow-[0_12px_40px_rgba(107,114,128,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
  };
};

/** CWP D3 — filter counts from hub-landing (registry-driven) */
const FILTER_ORDER = ['LIVE', 'BUILDING', 'HARDWARE', 'RESEARCH', 'TOOL'] as const;
const countByStatus = coreProducts.reduce(
  (acc, p) => {
    acc[p.status] = (acc[p.status] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const pageDescription =
  'P31 Labs technical hub — sovereign operator surface, verify-gated mesh, Georgia nonprofit.';
---

<BaseLayout
  title="P31 Labs — Technical hub"
  description={pageDescription}
  shellBackdrop={false}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/lib/p31-starfield.css" />
    <link rel="stylesheet" href="/lib/p31-larmor-fields.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1;500;1;600&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href="https://p31ca.org/" />
    <meta property="og:site_name" content="P31 Labs" />
    <meta
      property="og:title"
      content="P31 Labs — Technical hub"
    />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://p31ca.org/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="P31 Labs — Technical hub"
    />
    <meta name="twitter:description" content={pageDescription} />
    <script is:inline>
      (function () {
        if (/[?&]alive=1(?:&|$)/.test(location.search)) {
          document.documentElement.classList.add('p31-hub-alive');
          return;
        }
        document.documentElement.classList.add('p31-hub-gray-rock');
        function wake() {
          document.documentElement.classList.remove('p31-hub-gray-rock');
          document.documentElement.classList.add('p31-hub-alive');
        }
        document.addEventListener('pointerdown', wake, { once: true, capture: true });
        document.addEventListener('keydown', wake, { once: true, capture: true });
      })();
    </script>
  </Fragment>

  <!-- Hub landing: 2D particle canvas (no WebGL — full dome lives at /dome) -->
  <div
    id="hub-gl-backdrop"
    class="pointer-events-none fixed inset-0 z-0 isolate overflow-hidden bg-[#05080c]"
    aria-hidden="true"
  >
    <canvas id="hub-particle-canvas" class="p31-starfield-canvas absolute inset-0 h-full w-full"></canvas>
    <div
      class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-[rgba(37,137,125,0.03)] via-transparent to-[rgba(204,98,71,0.035)]"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 z-[2] bg-[#05080c]/50"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Top nav: public actions always visible; operator instruments in <details> (mobile-first) -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 glass-panel border-b border-white/[0.07] flex flex-col gap-3 pt-[max(0.5rem,env(safe-area-inset-top))] pb-2 pl-[max(0.75rem,env(safe-area-inset-left))] pr-[max(0.75rem,env(safe-area-inset-right))] sm:px-5 lg:flex-row lg:items-center lg:justify-between lg:gap-4 text-sm font-mono text-p31-cloud shadow-[0_4px_30px_rgba(0,0,0,0.5)] md:text-xs"
    aria-label="Primary"
  >
    <div class="flex min-w-0 flex-wrap items-center justify-between gap-3 lg:flex-1 lg:justify-start">
      <a href="/" class="group flex min-w-0 shrink-0 items-center gap-3 no-underline" title="P31 Labs hub">
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-teal/40 bg-teal/10 font-mono text-[11px] font-bold tracking-tight text-cyan transition-all group-hover:border-teal group-hover:bg-teal group-hover:text-p31-cloud group-hover:shadow-[0_0_15px_rgba(77,184,168,0.35)]"
        >
          P31
        </div>
        <span
          class="hidden font-mono text-[11px] font-semibold uppercase leading-tight tracking-[0.2em] text-p31-cloud/70 transition-colors group-hover:text-p31-cloud sm:inline sm:max-w-[14rem]"
        >
          P31 Labs</span>
      </a>

      <details
        id="hub-instruments"
        class="group relative min-w-0 max-w-full flex-1 sm:max-w-md lg:max-w-lg [&_summary::-webkit-details-marker]:hidden"
      >
        <summary
          class="flex min-h-[2.75rem] cursor-pointer list-none items-center justify-center gap-2 rounded-lg border border-white/[0.1] bg-p31-void-50 px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-p31-muted transition-colors hover:border-teal/25 hover:text-p31-cloud lg:min-h-0 lg:py-1.5"
        >
          Instruments
          <span class="text-p31-muted/50" aria-hidden="true">▾</span>
        </summary>
        <div
          class="absolute left-0 right-0 top-full z-[60] mt-2 flex max-h-[min(70vh,28rem)] flex-col gap-4 overflow-y-auto rounded-lg border border-white/[0.08] bg-p31-void-95 p-4 shadow-[0_12px_40px_rgba(0,0,0,0.65)] backdrop-blur-md sm:left-auto sm:right-0 sm:min-w-[22rem]"
        >
          <div class="flex flex-wrap items-center gap-2" title="Fisher-Escolà Coherence Score">
            <span class="w-2 h-2 shrink-0 rounded-full bg-phosphorus shadow-[0_0_8px_rgba(59,163,114,0.55)] animate-pulse" id="nav-status-dot"></span>
            <span class="text-p31-muted">Q-FACTOR:</span>
            <span class="font-bold text-phosphorus tracking-wider" id="nav-q-factor">0.925</span>
          </div>
          <div
            class="flex flex-wrap items-center gap-x-4 gap-y-3 overflow-x-auto rounded-md border border-white/[0.07] bg-p31-void-50 px-3 py-2.5 [scrollbar-width:thin]"
          >
            <div class="flex items-center gap-2" title="Vertex A: Operator State">
              <span class="text-p31-muted">SPOONS</span>
              <div class="w-16 h-1.5 bg-surface2 rounded-full overflow-hidden">
                <div id="nav-spoon-fill" class="h-full bg-coral transition-all duration-500" style="width: 50%;"></div>
              </div>
              <span id="nav-spoon-val" class="text-coral font-bold">10</span>
            </div>
            <div class="h-3 w-px bg-white/10"></div>
            <div class="flex items-center gap-2" title="L.O.V.E. Ledger Balance">
              <span class="text-p31-muted">L.O.V.E.</span>
              <span id="nav-love-val" class="text-teal font-bold">3.28</span>
            </div>
            <div class="h-3 w-px bg-white/10 hidden sm:block"></div>
            <div class="hidden sm:flex items-center gap-2">
              <span class="text-p31-muted">FLEET:</span>
              <span id="nav-fleet-val" class="text-p31-cloud">4/4</span>
            </div>
            <div class="h-3 w-px bg-white/10 hidden lg:block"></div>
            <div
              class="hidden lg:flex flex-wrap items-center gap-2"
              title="As above, so below — p31ca HUD ↔ k4-personal edge (vitality, V/E L♥)"
            >
              <span class="text-p31-muted">MESH</span>
              <span id="nav-mesh-vit" class="text-lavender font-bold">—</span>
              <span class="text-p31-muted text-[10px]">L♥</span>
              <span id="nav-mesh-ve" class="text-p31-cloud text-[10px] font-mono">—</span>
              <span id="nav-mesh-detail" class="text-p31-muted text-[9px] font-mono max-w-[7rem] truncate hidden 2xl:inline" title=""> </span>
              <a href="/mesh-observatory/" class="text-lavender hover:text-lavender/85 hover:underline text-[10px] font-bold" title="Mesh Observatory">OBS</a>
            </div>
          </div>
          <div
            class="group inline-flex min-h-[3rem] cursor-pointer items-center gap-3 rounded-md border border-white/[0.06] px-2 py-2 md:min-h-0"
            id="trimtab-trigger"
            title="Drag to tune · Click for Layer 0"
          >
            <canvas id="trimtab-canvas" width="24" height="24" class="opacity-80 transition-opacity group-hover:opacity-100"></canvas>
            <span id="trimtab-freq" class="text-butter font-bold">863Hz</span>
            <span class="text-[9px] text-p31-muted">Trim · breath</span>
          </div>
        </div>
      </details>
    </div>

    <div
      class="flex w-full flex-wrap items-center justify-center gap-2 sm:justify-end lg:w-auto lg:flex-nowrap lg:justify-end"
    >
      <a
        href="/passport"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-phosphorus/35 bg-phosphorus/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-phosphorus hover:bg-phosphorus/25 hover:text-phosphorus md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="AI context card — free, runs in your browser">Context Card</a>
      <a
        href="/dome"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-teal/30 bg-teal/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-teal hover:bg-teal/20 hover:text-phosphorus md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Sovereign Cockpit K₄ dome">Dome</a>
      <a
        href="/demos"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-butter/35 bg-butter/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-butter hover:bg-butter/20 hover:text-butter/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Visual demos gallery — K₄ mesh, alignment graph (111 sources × 53 derivations), Larmor pulse, glass box (also at /visuals)">Demos</a>
      <a
        href="/glass-box"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-cloud/30 bg-cloud/5 px-3 py-2 text-xs font-bold uppercase tracking-widest text-cloud/80 hover:bg-cloud/10 hover:text-cloud md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Public transparency terminal — synthetic CLI playbacks + verify pulse + promoted reports (also at /glass and /transparency)">Glass</a>
      <a
        href="/journey"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-phosphorus/35 bg-phosphorus/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-phosphorus hover:bg-phosphorus/20 hover:brightness-110 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Core path — onboard, authenticate, EDE home">Journey</a>
      <a
        href="/ops/"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-lavender/35 bg-lavender/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-lavender hover:bg-lavender/20 hover:text-lavender/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="G.O.D. operator shell — glass + shift">Ops</a>
      <a
        href="/auth"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-coral/30 bg-coral/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-coral hover:bg-coral/20 hover:brightness-110 md:min-h-0 md:py-1 md:text-[10px]"
      >
        Authenticate
      </a>
    </div>
  </nav>

  <!-- Node Detail Panel -->
  <aside
    id="node-detail-panel"
    class="pointer-events-none fixed bottom-[max(1rem,env(safe-area-inset-bottom))] left-4 right-4 z-40 w-auto max-w-sm translate-y-4 transform rounded-xl border-l border-t border-white/10 bg-p31-void-95 p-5 opacity-0 shadow-[0_10px_40px_rgba(0,0,0,0.8)] backdrop-blur-sm transition-all duration-300 sm:left-6 sm:right-auto sm:w-80"
  >
    <button
      id="node-detail-close"
      class="text-p31-muted pointer-events-auto absolute right-2 top-2 inline-flex min-h-[2.75rem] min-w-[2.75rem] items-center justify-center rounded-md hover:bg-white/10 hover:text-p31-cloud"
      type="button"
      aria-label="Close details"
    >
      ✕
    </button>
    <div class="text-teal font-bold text-lg mb-1" id="nd-title">Node Name</div>
    <div class="flex items-center gap-3 text-[10px] font-mono mb-4 pb-3 border-b border-white/10">
      <span id="nd-axis" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70">Axis</span>
      <span id="nd-state" class="px-2 py-0.5 rounded border">State</span>
      <span id="nd-bus" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70">Bus</span>
    </div>
    <div id="nd-notes" class="text-sm text-p31-cloud mb-4 leading-relaxed font-sans">Node description goes here.</div>
    <div class="text-[10px] font-mono text-p31-muted mb-2 uppercase tracking-widest">Entangled Edges</div>
    <div id="nd-conns" class="flex flex-wrap gap-2 pointer-events-auto"></div>
  </aside>

  <!-- LAYER 0: Somatic Mode Overlay -->
  <div id="layer0" class="fixed inset-0 z-[100] bg-p31-void flex flex-col items-center justify-center gap-6 transition-opacity duration-1000 opacity-0 pointer-events-none">
    <!-- Hub Layer0 POVM latch — string anchor for egg-hunt; handler: activateLayer0 in landing-cockpit.ts -->
    <div class="absolute top-8 left-1/2 -translate-x-1/2 flex items-center gap-4 font-mono text-xs text-p31-muted">
      <span>SPOONS</span>
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-spoon-fill" class="h-full bg-coral transition-all duration-500"></div>
      </div>
      <span id="l0-spoon-pct">50%</span>
    </div>
    <div id="l0-dot" class="w-16 h-16 rounded-full bg-coral opacity-40 transform scale-75"></div>
    <div id="l0-phase" class="text-xl font-mono text-coral tracking-[0.2em] uppercase">INHALE</div>
    <div class="absolute bottom-12 flex flex-col items-center gap-3">
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-escape-fill" class="h-full w-0 bg-coral"></div>
      </div>
      <div class="text-[10px] font-mono text-p31-muted tracking-widest uppercase">Hold ESC to exit</div>
    </div>
  </div>

  <!-- MAIN SCROLLING CONTENT -->
  <!-- pointer-events-none allows background clicking, but we restore it on .interactive-zone -->
  <main
    id="scroll-container"
    class="pointer-events-none relative z-10 mx-auto max-w-7xl px-4 pt-28 pb-12 font-sans text-p31-cloud sm:px-6 sm:pb-20 md:pt-24"
  >
    <!-- Lobby threshold — geometry first, then nameplate (hub shell; tokens via p31-style.css) -->
    <header
      id="technical-hub-boundary"
      class="animate-fade-in-up relative z-10 mb-8 text-center sm:mb-12 md:mb-14"
      style="animation-delay: 0.08s;"
    >
      <div class="lobby-hero pointer-events-auto mx-auto max-w-xl px-4 pt-16 sm:pt-20 md:pt-24">
        <div class="lobby-k4-wrap mb-6 flex justify-center" aria-hidden="true">
          <svg
            class="lobby-k4 lobby-k4--static text-teal"
            width="120"
            height="120"
            viewBox="-100 -100 200 200"
            role="img"
            aria-label="K₄ tetrahedron wireframe — four vertices, six edges"
          >
            <!-- Schlegel-style projection: triangle + interior hub = K₄ -->
            <line x1="0" y1="-72" x2="-62" y2="52" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
            <line x1="0" y1="-72" x2="62" y2="52" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
            <line x1="-62" y1="52" x2="62" y2="52" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
            <line x1="0" y1="-8" x2="0" y2="-72" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
            <line x1="0" y1="-8" x2="-62" y2="52" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
            <line x1="0" y1="-8" x2="62" y2="52" stroke="currentColor" stroke-width="1.25" vector-effect="non-scaling-stroke" opacity="0.85" />
          </svg>
        </div>
        <h1
          id="technical-hub-heading"
          class="hub-operator-title mb-4 text-balance text-[clamp(1.85rem,4vw+0.5rem,2.85rem)] leading-[1.12] tracking-tight text-p31-cloud"
        >
          P31 Labs
        </h1>
        <p class="mx-auto mb-8 max-w-xl font-sans text-base leading-relaxed text-p31-cloud-80 sm:text-lg">
          Open-source assistive technology for neurodivergent individuals.
        </p>
        <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-p31-muted">
          <a href="#lobby-rooms" class="text-teal/90 no-underline hover:underline">Rooms</a>
          <span class="mx-2 opacity-40" aria-hidden="true">·</span>
          <a href="#core-products" class="text-p31-muted no-underline hover:text-teal/90">Full catalog</a>
          <span class="mx-2 opacity-40" aria-hidden="true">·</span>
          <button
            id="btn-explore-dome"
            type="button"
            class="border-0 bg-transparent p-0 font-mono text-[10px] uppercase tracking-[0.16em] text-p31-muted hover:text-teal/90"
          >
            Dome
          </button>
        </p>
      </div>
    </header>

    <section
      id="lobby-rooms"
      class="interactive-zone animate-fade-in-up relative z-10 mx-auto mb-12 max-w-3xl px-4 sm:mb-16"
      style="animation-delay: 0.12s;"
      aria-labelledby="lobby-rooms-heading"
    >
      <h2 id="lobby-rooms-heading" class="sr-only">Rooms</h2>
      <ul class="m-0 list-none space-y-3 p-0">
        {lobbyDoors.map((door) => (
          <li>
            <a
              href={door.href}
              {...(door.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class={`hub-door group flex min-h-[3.25rem] flex-col gap-1 rounded-lg border border-white/[0.06] border-l-4 bg-p31-void/40 py-3 pl-4 pr-3 no-underline transition-colors hover:bg-surface2/50 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:py-3.5 ${
                door.title === 'Research'
                  ? 'border-l-coral/45 hover:border-l-coral hover:border-coral/25'
                  : 'border-l-teal/55 hover:border-l-teal hover:border-teal/25'
              }`}
            >
              <div class="min-w-0 text-left">
                <div class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-p31-cloud">
                  {door.title}
                </div>
                <div class="font-mono text-[10px] leading-snug text-p31-muted">{door.meta}</div>
                <p class="mb-0 mt-1 font-sans text-sm leading-snug text-p31-cloud-75">{door.sub}</p>
              </div>
              <span
                class="mt-1 inline-flex shrink-0 items-center gap-1.5 self-end font-mono text-[10px] uppercase tracking-wider text-p31-muted sm:mt-0 sm:self-center"
                aria-hidden="true"
              >
                {door.dot === 'live' ? (
