---
/**
 * WCD-R14: P31CA.ORG — 39-vector hub landing page.
 * Rebuilt after Chromebook session lost the source.
 * Static SSG rendering — no client-side fetch, no JSON dependency.
 * Filter toggles via vanilla JS data-status attributes.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

