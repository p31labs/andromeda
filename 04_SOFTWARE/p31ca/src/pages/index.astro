const liveCount = vectors.filter(v => v.status === 'live').length;
const devCount = vectors.filter(v => v.status === 'dev').length;
const researchCount = vectors.filter(v => v.status === 'research').length;
---

<BaseLayout title="P31 Labs | Neurodivergent Cognitive Infrastructure">
  <!-- Navbar -->
  <nav style="position:sticky;top:0;z-index:50;background:rgba(5,5,5,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.05);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;">
    <div style="display:flex;align-items:center;gap:10px;">
      <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
        <rect width="512" height="512" rx="112" fill="#25897d"/>
        <circle cx="390" cy="120" r="48" fill="#cc6247"/>
        <text x="256" y="340" font-family="system-ui" font-weight="900" font-size="220" fill="#f0eee9" text-anchor="middle">P31</text>
        <rect x="156" y="380" width="200" height="16" rx="8" fill="#cda852"/>
      </svg>
      <span style="font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;opacity:0.8;">P31 Labs</span>
    </div>
    <div style="display:flex;align-items:center;gap:20px;font-family:'JetBrains Mono',monospace;font-size:12px;">
      <a href="/lattice.html" style="color:#25897d;text-decoration:none;opacity:0.7;transition:opacity 0.15s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">Lattice View</a>
      <a href="https://github.com/p31labs/andromeda" target="_blank" rel="noopener noreferrer" style="color:#d8d6d0;text-decoration:none;opacity:0.5;transition:opacity 0.15s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">GitHub</a>
      <a href="/phosphorus/support" style="color:#d8d6d0;text-decoration:none;opacity:0.5;transition:opacity 0.15s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">Support</a>
    </div>
  </nav>

  <main style="max-width:72rem;margin:0 auto;padding:2rem 1.5rem 4rem;">
    <!-- Hero -->
    <div style="padding:3rem 0 2rem;">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:#25897d;margin-bottom:1rem;opacity:0.8;">
        P31 Labs / EIN 81-2908499
      </div>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:800;line-height:1.1;color:#f0eee9;margin-bottom:1rem;">
        Autonomous Cognitive<br/>Infrastructure.
      </h1>
      <p style="font-size:1rem;color:rgba(240,238,233,0.55);max-width:540px;line-height:1.6;margin-bottom:1.5rem;">
        Building sovereign tools for neurodivergent survival. Every system is edge-deployed, offline-capable, and legally armored. No cloud dependency. No floating neutral.
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem;font-family:'JetBrains Mono',monospace;font-size:12px;color:rgba(255,255,255,0.4);">
        <span>{vectors.length} vectors / {liveCount} live deployments</span>
        <a href="/lattice.html" style="color:#25897d;text-decoration:none;">View lattice →</a>
      </div>
    </div>

    <!-- Filters -->
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:rgba(255,255,255,0.3);margin-right:0.25rem;text-transform:uppercase;letter-spacing:0.1em;">Filter:</span>
      <button data-filter="all" class="filter-btn active" onclick="setFilter('all')">All ({vectors.length})</button>
      <button data-filter="live" class="filter-btn" onclick="setFilter('live')">Live ({liveCount})</button>
      <button data-filter="dev" class="filter-btn" onclick="setFilter('dev')">In Dev ({devCount})</button>
      <button data-filter="research" class="filter-btn" onclick="setFilter('research')">Research ({researchCount})</button>
    </div>

    <!-- Vector Grid -->
    <div id="vector-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      {vectors.map((v) => (
        <a
          href={v.url}
          data-status={v.status}
          class="vector-card"
          target={v.url.startsWith('http') ? '_blank' : undefined}
          rel={v.url.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.5rem;">
            <span style="font-size:1.5rem;line-height:1;">{v.icon}</span>
            <span class:list={['status-dot', `status-dot-${v.status}`]}></span>
          </div>
          <h3 style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;font-weight:700;letter-spacing:0.05em;color:#f0eee9;margin-bottom:0.25rem;">{v.title}</h3>
          <p style="font-size:0.8rem;color:rgba(240,238,233,0.45);margin-bottom:0.75rem;line-height:1.4;">{v.subtitle}</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.25rem;">
            {v.stack.map((tag) => (
              <span class="stack-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer style="border-top:1px solid rgba(255,255,255,0.04);padding:2rem 1.5rem;text-align:center;">
    <div style="max-width:72rem;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
      <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:rgba(255,255,255,0.15);letter-spacing:0.2em;text-transform:uppercase;">P31 Labs, Inc.</span>
      <p style="font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(255,255,255,0.1);">
        Georgia nonprofit corporation · EIN 81-2908499 · SE Georgia · AGPL-3.0
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  .filter-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    background: transparent;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.05em;
  }
  .filter-btn:hover {
    border-color: rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
  }
  .filter-btn.active {
    border-color: #25897d;
    color: #25897d;
    background: rgba(37,137,125,0.08);
  }

  .vector-card {
    display: block;
    padding: 1rem;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    background: rgba(255,255,255,0.02);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .vector-card:hover {
    border-color: rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .status-dot-live     { background: #3ba372; box-shadow: 0 0 6px rgba(59,163,114,0.6); }
  .status-dot-dev      { background: #cda852; }
  .status-dot-research { background: #4db8a8; }

  .stack-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 3px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.03em;
  }
</style>

<script>
  function setFilter(filter: string) {
    const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.vector-card');
    btns.forEach(b => b.classList.remove('active'));
    const active = document.querySelector<HTMLButtonElement>(`[data-filter="${filter}"]`);
    if (active) active.classList.add('active');
    cards.forEach(card => {
      const status = card.dataset.status;
      card.style.display = (filter === 'all' || status === filter) ? '' : 'none';
    });
  }
</script>
