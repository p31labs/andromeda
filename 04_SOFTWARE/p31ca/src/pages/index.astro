const getStatusStyles = (status: string) => {
  if (status === 'LIVE') return { text: 'text-[#3ba372]', bg: 'bg-[#3ba372]/10', border: 'border-[#3ba372]/30', glow: 'group-hover:shadow-[0_12px_40px_rgba(59,163,114,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]' };
