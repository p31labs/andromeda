---
/**
 * index.astro — P31 Labs root landing page
 *
 * Ca₉(PO₄)₆ Posner Molecule: 9 Ca²⁺ ions in 3 orbital rings around a
 * K₄ tetrahedron PHOS phosphorus core.
 *
 * Layer stack:
 *   Z=0  AppShell WebGL starfield (persists across SPA navigations)
 *   Z=5  #c1 — 2D bond/tether canvas (DPR-scaled)
 *   Z=10 #node-layer — 9 DOM <a> nodes (transform3d, elliptical orbit y*0.6)
 *   Z=40 #phos-wrap — K₄ tetrahedron PHOS mascot (JS parallax + float)
 *   Z=60 #speech — speech bubble
 *   Z=100 PHOS Router (whisperpanel, chip tree)
 *   Z=9000 #akinator-overlay — Bayesian intent router
 *   Z=300 #safe-view — Gray Rock static fallback (SOULSAFE / Gray Rock Protocol)
 *
 * Orbital mechanics (p31_final/P31_TECHNICAL_BUILD_SPECIFICATION.md §Surface 01):
 *   Ring 1 (inner/family):   CW  60s period  r≈120px  y*0.6
 *   Ring 2 (middle/ops):     CCW 90s period  r≈200px  y*0.6
 *   Ring 3 (outer/creation): CW  120s period r≈280px  y*0.6
 *
 * Egg anchors (verify:egg-hunt — HUB-LAYER0):
 *   id="trimtab-trigger"  — operator Easter egg (Bucky Fuller / call me trimtab)
 *   activateLayer0()      — fn restores starfield from safe mode
 *   "Hold ESC to exit"    — safe view exit hint
 *
 * Token canon: var(--p31-*) from /p31-style.css.
 * verify:surface-canon requires routeName="home" — do not change.
 */
import AppShell from '../layouts/AppShell.astro';

const desc = 'P31 Labs — Ca₉(PO₄)₆ Posner Molecule. 9 calcium ions. 1 phosphorus core. Infinite coherence.';
---

<AppShell
  title="P31 Labs"
  description={desc}
  routeName="home"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://p31ca.org/" />
    <meta property="og:title"        content="P31 Labs" />
    <meta property="og:description"  content={desc} />
    <meta property="og:url"          content="https://p31ca.org/" />
    <meta property="og:type"         content="website" />
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content="P31 Labs" />
    <meta name="twitter:description" content={desc} />

    <style is:global>
      /* ── TETHER CANVAS (above AppShell starfield at z=0) ─────────────── */
      #c1 {
        position: fixed; top: 0; left: 0;
        width: 100vw; height: 100vh;
        pointer-events: none; z-index: 5;
        view-transition-name: none;
      }

      /* ── NODE LAYER ───────────────────────────────────────────────────── */
      #node-layer { position: fixed; inset: 0; z-index: 10; pointer-events: none; }

      .nd {
        position: absolute; top: 0; left: 0;
        width: 72px; height: 72px; margin-left: -36px; margin-top: -36px;
        border-radius: 50%; pointer-events: auto; cursor: pointer;
        text-decoration: none; display: flex; justify-content: center; align-items: center;
        will-change: transform;
        background:
          radial-gradient(circle at 30% 28%, rgba(255,255,255,0.2) 0%, transparent 38%),
          radial-gradient(circle at 66% 70%, color-mix(in srgb, var(--nc) 26%, transparent) 0%, transparent 44%),
          radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--nc) 11%, rgba(22,25,32,0.96)) 0%, rgba(11,13,16,0.97) 75%);
        border: 1px solid color-mix(in srgb, var(--nc) 58%, transparent);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.16),
          inset 0 0 22px color-mix(in srgb, var(--nc) 48%, transparent),
          inset -5px -5px 14px rgba(0,0,0,0.72),
          0 12px 28px rgba(0,0,0,0.65),
          0 0 38px color-mix(in srgb, var(--nc) 17%, transparent);
        backdrop-filter: blur(12px);
        transition: box-shadow 0.4s ease, border-color 0.35s ease;
        animation: nd-ambient 4s ease-in-out infinite;
      }
      .nd:nth-child(1) { animation-delay:  0.0s; }
      .nd:nth-child(2) { animation-delay: -0.7s; }
      .nd:nth-child(3) { animation-delay: -1.4s; }
      .nd:nth-child(4) { animation-delay: -2.1s; }
      .nd:nth-child(5) { animation-delay: -2.8s; }
      .nd:nth-child(6) { animation-delay: -0.3s; }
      .nd:nth-child(7) { animation-delay: -3.5s; }
      .nd:nth-child(8) { animation-delay: -1.8s; }
      .nd:nth-child(9) { animation-delay: -1.1s; }
      @keyframes nd-ambient {
        0%, 100% { filter: brightness(1)   saturate(1);    }
        50%       { filter: brightness(1.2) saturate(1.25); }
      }
      .nd::before {
        content: ''; position: absolute; inset: -10px; border-radius: 50%;
        border: 1px dashed color-mix(in srgb, var(--nc) 52%, transparent);
        animation: spin-cw 12s linear infinite; pointer-events: none;
      }
      .nd::after {
        content: ''; position: absolute; inset: -19px; border-radius: 50%;
        border: 1px solid color-mix(in srgb, var(--nc) 24%, transparent);
        animation: spin-ccw 20s linear infinite;
        pointer-events: none; opacity: 0; transition: opacity 0.4s;
      }
      .nd:hover {
        border-color: var(--nc); z-index: 50;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.28),
          inset 0 0 42px color-mix(in srgb, var(--nc) 85%, transparent),
          0 15px 35px rgba(0,0,0,0.72),
          0 0 72px color-mix(in srgb, var(--nc) 36%, transparent);
      }
      .nd:hover::after { opacity: 1; }
      @keyframes spin-cw  { to { transform: rotate(360deg);  } }
      @keyframes spin-ccw { to { transform: rotate(-360deg); } }

      .nd-icon {
        font-size: 1.8rem; position: relative; z-index: 2;
        filter: drop-shadow(0 2px 6px rgba(0,0,0,0.88));
        transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
      }
      .nd:hover .nd-icon { transform: scale(1.22); }
      .nd-lbl {
        position: absolute; bottom: -42px; white-space: nowrap; left: 50%;
        transform: translateX(-50%) translateY(-6px);
        background: rgba(11,13,16,0.97); border: 1px solid var(--nc);
        padding: 5px 14px; border-radius: 7px; color: #fff;
        font-family: var(--p31-font-mono); font-size: 0.75rem; font-weight: 700;
        opacity: 0; transition: all 0.32s cubic-bezier(0.34,1.56,0.64,1);
        pointer-events: none; box-shadow: 0 4px 14px rgba(0,0,0,0.65);
      }
      .nd:hover .nd-lbl { opacity: 1; transform: translateX(-50%) translateY(0); }

      /* ── PHOS CORE MASCOT ─────────────────────────────────────────────── */
      #phos-wrap {
        position: fixed; top: 50%; left: 50%;
        width: 160px; height: 160px; margin-left: -80px; margin-top: -80px;
        z-index: 40; cursor: pointer; pointer-events: auto;
        display: flex; align-items: center; justify-content: center;
      }
      #phos-wrap::before {
        content: ''; position: absolute; inset: -55px; border-radius: 50%; z-index: 0;
        background: radial-gradient(circle, rgba(77,184,168,0.2) 0%, transparent 68%);
        animation: aura 4.5s ease-in-out infinite; pointer-events: none;
      }
      #phos-wrap::after {
        content: ''; position: absolute; inset: -22px; border-radius: 50%; z-index: 0;
        border: 1px solid rgba(77,184,168,0.25);
        animation: aura-ring 3.5s ease-in-out infinite; pointer-events: none;
      }
      #phos-svg {
        width: 100%; height: 100%; position: relative; z-index: 1;
        filter: drop-shadow(0 10px 28px rgba(77,184,168,0.45));
        transition: transform 0.42s cubic-bezier(0.34,1.56,0.64,1), filter 0.42s;
      }
      #phos-wrap:hover #phos-svg {
        transform: scale(1.1) rotate(8deg);
        filter: drop-shadow(0 16px 36px rgba(77,184,168,0.75));
      }
      #phos-wrap:active #phos-svg { transform: scale(0.93); }

      .pb   { fill: rgba(22,25,32,0.96); stroke: var(--p31-teal); stroke-width: 3; stroke-linejoin: round; transition: fill 0.35s; }
      .pb-b { fill: rgba(11,13,16,0.88); stroke: rgba(37,137,125,0.25); stroke-width: 1.5; }
      .pg   { fill: rgba(255,255,255,0.14); }
      .pe   { fill: #070a0a; transition: rx 0.22s, ry 0.22s; }
      .pi   { fill: none; stroke: var(--p31-teal); stroke-width: 1.2; }
      .pp   { fill: rgba(200,255,235,0.92); transition: transform 0.12s ease-out; }
      .pbl  { fill: var(--p31-coral); opacity: 0; filter: blur(3px); transition: opacity 0.4s; }
      .pm   { stroke: var(--p31-teal); stroke-width: 2.2; fill: none; stroke-linecap: round; }
      .peg  { animation: blink 8s infinite; transform-origin: 50px 58px; }
      #phos-wrap:hover .pb  { fill: rgba(77,184,168,0.14); }
      #phos-wrap:hover .pbl { opacity: 0.68; }
      #phos-wrap:hover .pe  { rx: 6; ry: 10; }
      @keyframes aura      { 0%,100% { transform: scale(1);   opacity: 0.55; } 50% { transform: scale(1.14); opacity: 1;    } }
      @keyframes aura-ring { 0%,100% { transform: scale(1);   opacity: 0.4;  } 50% { transform: scale(1.1);  opacity: 0.78; } }
      @keyframes blink     { 0%,93%,97% { transform: scaleY(1); } 94%,96% { transform: scaleY(0.07); } }

      /* ── SPEECH BUBBLE ────────────────────────────────────────────────── */
      #speech {
        position: fixed; top: 50%; left: 50%; margin-left: 90px; margin-top: -95px;
        background: rgba(22,25,32,0.97); border: 1px solid var(--p31-teal);
        border-radius: 16px 16px 16px 2px; padding: 1.1rem 1.4rem; max-width: 270px;
        color: #fff; font-family: var(--p31-font-mono); font-size: 0.88rem; line-height: 1.55;
        box-shadow: 0 14px 36px rgba(0,0,0,0.72), 0 0 24px rgba(77,184,168,0.1);
        z-index: 60; pointer-events: none;
        opacity: 0; transform: translateY(10px) scale(0.95);
        transform-origin: bottom left;
        transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1);
      }
      #speech.on { opacity: 1; transform: translateY(0) scale(1); }

      /* ── AKINATOR OVERLAY ─────────────────────────────────────────────── */
      #akinator-overlay {
        position: fixed; inset: 0; background: rgba(5,6,8,0.88);
        backdrop-filter: blur(20px); z-index: 9000;
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
      }
      #akinator-overlay.active { opacity: 1; pointer-events: auto; }
      .aki-dialog {
        background: var(--p31-surface2); border: 1px solid var(--p31-glass-border);
        border-top: 4px solid var(--p31-teal); border-radius: 16px; padding: 3rem;
        width: 100%; max-width: 650px; box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        transform: translateY(20px); transition: transform 0.4s cubic-bezier(0.19,1,0.22,1);
        position: relative;
      }
      #akinator-overlay.active .aki-dialog { transform: translateY(0); }
      .aki-q  {
        font-size: 1.75rem; color: #fff; text-align: center;
        margin-bottom: 2.5rem; font-weight: 700; letter-spacing: -0.02em;
      }
      .aki-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .aki-btn  {
        background: rgba(255,255,255,0.03); border: 1px solid var(--p31-glass-border);
        color: var(--p31-cloud); padding: 1.25rem; border-radius: 8px;
        font-family: var(--p31-font-mono); font-size: 0.95rem; cursor: pointer;
        transition: all 0.2s; text-align: left; min-height: 44px;
        display: flex; justify-content: space-between; align-items: center;
      }
      .aki-btn:hover {
        background: rgba(77,184,168,0.1); border-color: var(--p31-teal);
        transform: translateX(5px); color: #fff;
      }
      .aki-close {
        position: absolute; top: 1.25rem; right: 1.25rem;
        background: none; border: none; color: var(--p31-muted);
        font-size: 2rem; cursor: pointer; line-height: 1; transition: color 0.2s;
        min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center;
      }
      .aki-close:hover { color: var(--p31-coral); }

      /* ── STATUS + SAFE TOGGLE ─────────────────────────────────────────── */
      #phos-ctrl {
        position: fixed; top: 3.75rem; right: 1rem; z-index: 200;
        display: flex; align-items: center; gap: 0.75rem;
      }
      #run-status {
        font-family: var(--p31-font-mono); font-size: 0.78rem;
        color: var(--p31-phosphorus); transition: color 0.3s;
      }
      #btn-safe {
        min-height: 44px; padding: 0.45rem 1rem;
        border: 1px solid rgba(204,98,71,0.42);
        border-radius: 8px; background: rgba(204,98,71,0.08); color: var(--p31-coral);
        font-family: var(--p31-font-mono); font-size: 0.72rem;
        text-transform: uppercase; letter-spacing: 0.08em;
        transition: all 0.2s; backdrop-filter: blur(8px); cursor: pointer;
      }
      #btn-safe:hover { background: rgba(204,98,71,0.2); box-shadow: 0 0 18px rgba(204,98,71,0.28); }

      /* ── TRIMTAB TRIGGER (operator Easter egg — Bucky Fuller) ─────────── */
      #trimtab-trigger {
        position: fixed; bottom: 0.5rem; left: 50%; transform: translateX(-50%);
        width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none;
        font-family: var(--p31-font-mono); font-size: 0;
      }

      /* ── SAFE VIEW (Gray Rock Protocol) ──────────────────────────────── */
      #safe-view {
        display: none; position: fixed; inset: 0; z-index: 300;
        padding: 5rem 2rem 5rem; overflow-y: auto; background: var(--p31-void);
      }
      body.safe #safe-view { display: block; }
      body.safe #c1,
      body.safe #node-layer,
      body.safe #phos-wrap,
      body.safe #speech { display: none !important; }

      .safe-hdr { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
      .safe-hdr h1 { font-size: 2rem; color: #fff; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
      .safe-hdr p  { color: var(--p31-muted); font-family: var(--p31-font-mono); font-size: 0.82rem; }
      .safe-hint {
        display: inline-block; margin-top: 0.75rem;
        color: var(--p31-muted); font-family: var(--p31-font-mono); font-size: 0.75rem;
        border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; padding: 3px 8px;
      }
      .safe-cards  { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px,1fr)); gap: 1.25rem; max-width: 1100px; margin: 0 auto; }
      .safe-card   {
        display: flex; align-items: center; gap: 1.25rem; padding: 1.4rem;
        border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
        background: rgba(255,255,255,0.025); text-decoration: none; color: inherit;
        transition: all 0.2s; min-height: 44px;
      }
      .safe-card:hover { border-color: var(--nc); background: rgba(255,255,255,0.045); transform: translateY(-2px); }
      .safe-ico  {
        width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
        border: 1px solid var(--nc); background: rgba(0,0,0,0.5);
        display: flex; align-items: center; justify-content: center; font-size: 1.7rem;
      }
      .safe-name { font-weight: 700; color: #fff; margin-bottom: 0.22rem; }
      .safe-desc { font-family: var(--p31-font-mono); font-size: 0.78rem; color: var(--p31-muted); }
      .safe-restore {
        margin-top: 2.5rem; text-align: center;
      }
      .safe-restore button {
        min-height: 44px; padding: 0.6rem 2rem;
        border: 1px solid var(--p31-teal); border-radius: 8px;
        background: rgba(77,184,168,0.08); color: var(--p31-teal);
        font-family: var(--p31-font-mono); font-size: 0.85rem; cursor: pointer;
        transition: all 0.2s;
      }
      .safe-restore button:hover { background: rgba(77,184,168,0.18); }

      @media (prefers-reduced-motion: reduce) {
        .nd, .nd::before, .nd::after,
        #phos-wrap::before, #phos-wrap::after, #phos-svg,
        .peg, #speech { animation: none !important; transition: none !important; }
      }
    </style>
  </Fragment>

  <!-- ── TETHER CANVAS (Layer 1, z=5) ──────────────────────────────────── -->
  <canvas id="c1" aria-hidden="true"></canvas>

  <!-- ── NODE LAYER (Layer 2, z=10) ────────────────────────────────────── -->
  <div id="node-layer" role="navigation" aria-label="P31 Labs orbital navigation"></div>

  <!-- ── PHOS CORE MASCOT (K₄ tetrahedron SVG, z=40) ──────────────────── -->
  <div id="phos-wrap" role="button" tabindex="0" aria-label="Open intent navigator — PHOS">
    <svg id="phos-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon class="pb-b" points="15,80 85,80 50,53"/>
      <polygon class="pb"   points="50,13 15,80 50,53"/>
      <polygon class="pb"   points="50,13 85,80 50,53"/>
      <polygon class="pg"   points="50,13 39,42 50,37"/>
      <g class="peg">
        <ellipse class="pe"  cx="38" cy="57" rx="4.5" ry="7.5"/>
        <ellipse class="pi"  cx="38" cy="57" rx="3"   ry="5"/>
        <ellipse class="pp"  id="pl" cx="38" cy="57" rx="2.2" ry="3.2"/>
        <ellipse class="pe"  cx="62" cy="57" rx="4.5" ry="7.5"/>
        <ellipse class="pi"  cx="62" cy="57" rx="3"   ry="5"/>
        <ellipse class="pp"  id="pr" cx="62" cy="57" rx="2.2" ry="3.2"/>
        <ellipse class="pbl" cx="27" cy="63" rx="5.5" ry="2.8"/>
        <ellipse class="pbl" cx="73" cy="63" rx="5.5" ry="2.8"/>
        <path class="pm" d="M 41 68 Q 50 74 59 68"/>
      </g>
    </svg>
  </div>

  <!-- ── SPEECH BUBBLE (z=60) ──────────────────────────────────────────── -->
  <div id="speech" aria-live="polite" aria-atomic="true"></div>

  <!-- ── AKINATOR OVERLAY (z=9000) ─────────────────────────────────────── -->
  <div id="akinator-overlay" role="dialog" aria-modal="true" aria-labelledby="aki-q">
    <div class="aki-dialog">
      <button class="aki-close" id="aki-close" aria-label="Close navigator">×</button>
      <div class="aki-q" id="aki-q">What do you need?</div>
      <div class="aki-grid" id="aki-opts"></div>
    </div>
  </div>

  <!-- ── GRAY ROCK — SAFE VIEW (SOULSAFE, z=300) ───────────────────────── -->
  <div id="safe-view">
    <div class="safe-hdr">
      <h1>Ca₉(PO₄)₆ Calcium Cage</h1>
      <p>Spatial fluid dynamics suspended. Executive function preserved. Geometry still holds.</p>
      <span class="safe-hint">Hold ESC to exit · Click Restore to resume</span>
    </div>
    <div class="safe-cards" id="safe-cards"></div>
    <div class="safe-restore">
      <button id="btn-restore" type="button" onclick="activateLayer0()">
        Restore — Hold ESC to exit safe mode
      </button>
    </div>
  </div>

  <!-- ── STATUS + SAFE TOGGLE ──────────────────────────────────────────── -->
  <div id="phos-ctrl" aria-label="System status">
    <span id="run-status" aria-live="polite">● RUNNING</span>
    <button id="btn-safe" type="button">Safe Mode</button>
  </div>

  <!-- ── TRIMTAB TRIGGER (operator Easter egg) ─────────────────────────── -->
  <!-- ³¹P Larmor precession: 863Hz (Larmor coherence anchor) -->
  <span id="trimtab-trigger" aria-hidden="true" tabindex="-1"
        data-larmor="863Hz" data-nucleus="P-31">
    Call me trimtab. — R. Buckminster Fuller
  </span>

  <!-- ── NOSCRIPT FALLBACK ──────────────────────────────────────────────── -->
  <noscript>
    <div style="position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;background:#0f1115;font-family:monospace;color:#4db8a8;padding:2rem;text-align:center">
      <p style="font-size:14px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin:0">P31 Labs</p>
      <a href="/passport"      style="color:#8b7cc9">Cognitive Passport</a>
      <a href="https://bonding.p31ca.org/soup" style="color:#cc6247">C.A.R.S.</a>
      <a href="/garden/"       style="color:#cda852">Garden</a>
      <a href="/god"           style="color:#4db8a8">Ops Desk</a>
      <a href="/god#buffer"    style="color:#cc6247">Buffer</a>
      <a href="/dome#glass"    style="color:var(--p31-teal)">Transparency</a>
      <a href="/dome#geodesic" style="color:#4db8a8">Geodesic</a>
      <a href="/god"           style="color:var(--p31-phosphorus)">Vibe IDE</a>
      <a href="/doc-library/"  style="color:#8b7cc9">Library</a>
    </div>
  </noscript>

  <!-- ── CA₉(PO₄)₆ POSNER MOLECULE ENGINE ─────────────────────────────── -->
  <script>
    // ── ORBITAL DATA ───────────────────────────────────────────────────────
    // Orbital periods per spec: Ring1=60s CW, Ring2=90s CCW, Ring3=120s CW
    // At ~60fps: Δθ = 2π / (period * 60)
    // Elliptical compression: y *= 0.6

    interface NodeDef {
      id: string; label: string; icon: string; hex: string;
      ring: 1|2|3; a0: number; href: string; prompt: string; ext?: boolean;
    }

    const NODES: NodeDef[] = [
      { id:'cog',  label:'Passport',     icon:'🧠', hex:'var(--p31-lavender)', ring:1, a0:0,                       href:'/passport',                      prompt:'Identity accommodations' },
      { id:'soup', label:'C.A.R.S.',     icon:'🍲', hex:'var(--p31-coral)',    ring:1, a0:Math.PI*2/3,             href:'https://bonding.p31ca.org/soup', prompt:'Relational substrate', ext:true },
      { id:'grd',  label:'Garden',       icon:'👶', hex:'var(--p31-amber)',    ring:1, a0:Math.PI*4/3,             href:'/garden/',                       prompt:'Kid-safe operations' },
      { id:'ops',  label:'Ops Desk',     icon:'🌐', hex:'var(--p31-cyan)',     ring:2, a0:Math.PI/6,              href:'/god',                           prompt:'Triad fleet status' },
      { id:'buf',  label:'Buffer',       icon:'🛡️', hex:'var(--p31-coral)',   ring:2, a0:Math.PI/6+Math.PI*2/3,  href:'/god#buffer',                    prompt:'Fawn-guard proxy' },
      { id:'gls',  label:'Transparency', icon:'📊', hex:'var(--p31-teal)',     ring:2, a0:Math.PI/6+Math.PI*4/3,  href:'/dome#glass',                    prompt:'System telemetry' },
      { id:'forg', label:'Geodesic',     icon:'⚒️', hex:'var(--p31-cyan)',    ring:3, a0:Math.PI/3,              href:'/dome#geodesic',                 prompt:'Spatial architecture' },
      { id:'vibe', label:'Vibe IDE',     icon:'🔮', hex:'var(--p31-phosphorus)',ring:3, a0:Math.PI/3+Math.PI*2/3, href:'/god',                           prompt:'Coding substrate' },
      { id:'lib',  label:'Library',      icon:'📚', hex:'var(--p31-lavender)', ring:3, a0:Math.PI/3+Math.PI*4/3,  href:'/doc-library/',                  prompt:'Architectural canon' },
    ];

    // Δθ per animation frame (60fps assumption) — 2π / (period_s * 60fps)
    const RING_SPEED: Record<1|2|3, number> = {
      1:  (2 * Math.PI) / (60  * 60),   // CW, 60s period
      2: -(2 * Math.PI) / (90  * 60),   // CCW, 90s period
      3:  (2 * Math.PI) / (120 * 60),   // CW, 120s period
    };

    interface AkiNode { q: string; opts: AkiOpt[]; }
    interface AkiOpt  { label: string; href?: string; next?: AkiNode; }

    const AKI_TREE: AkiNode = {
      q: 'What do you need?',
      opts: [
        { label: 'Family Mesh', next: { q: 'Which node?', opts: [
          { label: 'Cognitive Passport', href: '/passport' },
          { label: 'C.A.R.S. Molecule',  href: 'https://bonding.p31ca.org/soup' },
          { label: 'The Garden (Kids)',  href: '/garden/' },
        ]}},
        { label: 'Infrastructure', next: { q: 'Which layer?', opts: [
          { label: 'Command Center', href: '/god' },
          { label: 'Buffer',     href: '/god#buffer' },
          { label: 'Transparency',   href: '/dome#glass' },
        ]}},
        { label: 'Build / Create', next: { q: 'Build what?', opts: [
          { label: 'Geodesic Builder', href: '/dome#geodesic' },
          { label: 'Vibe IDE',         href: '/god' },
        ]}},
        { label: 'Documentation', href: '/doc-library/' },
      ],
    };

    // ── DOM REFS ───────────────────────────────────────────────────────────
    const nlayer     = document.getElementById('node-layer')       as HTMLElement;
    const scards     = document.getElementById('safe-cards')       as HTMLElement;
    const phosEl     = document.getElementById('phos-wrap')        as HTMLElement;
    const speechEl   = document.getElementById('speech')           as HTMLElement;
    const pl         = document.getElementById('pl')               as SVGEllipseElement | null;
    const pr         = document.getElementById('pr')               as SVGEllipseElement | null;
    const akiOverlay = document.getElementById('akinator-overlay') as HTMLElement;
    const akiQ       = document.getElementById('aki-q')            as HTMLElement;
    const akiOpts    = document.getElementById('aki-opts')         as HTMLElement;
    const c1         = document.getElementById('c1')               as HTMLCanvasElement;
    const ctx1       = c1.getContext('2d')!;

    // ── NODE STATE ─────────────────────────────────────────────────────────
    interface NS {
      data: NodeDef; el: HTMLAnchorElement;
      angle: number; hovered: boolean; x: number; y: number; packets: Packet[];
    }
    const state: NS[] = [];

    NODES.forEach(n => {
      const a = document.createElement('a') as HTMLAnchorElement;
      a.href = n.href; a.className = 'nd';
      a.style.setProperty('--nc', n.hex);
      a.setAttribute('aria-label', n.label);
      if (n.ext) { a.target = '_blank'; a.rel = 'noopener'; }
      a.innerHTML = `<div class="nd-icon">${n.icon}</div><div class="nd-lbl">${n.label}</div>`;

      let dragX = 0, dragY = 0, wasDrag = false;
      a.addEventListener('pointerdown', (e) => { dragX = e.clientX; dragY = e.clientY; wasDrag = false; });
      a.addEventListener('pointermove', (e) => { if (Math.hypot(e.clientX - dragX, e.clientY - dragY) > 6) wasDrag = true; });
      a.addEventListener('click', (e) => { if (wasDrag) { e.preventDefault(); e.stopPropagation(); } });

      const s: NS = { data: n, el: a, angle: n.a0, hovered: false, x: 0, y: 0, packets: [] };
      a.addEventListener('mouseenter', () => { speak(`Ca-Ion: ${n.prompt}`, n.hex); s.hovered = true; });
      a.addEventListener('mouseleave', () => { quieten(); s.hovered = false; });
      nlayer.appendChild(a);
      state.push(s);

      const c = document.createElement('a') as HTMLAnchorElement;
      c.href = n.href; c.className = 'safe-card';
      c.style.setProperty('--nc', n.hex);
      if (n.ext) { c.target = '_blank'; c.rel = 'noopener'; }
      c.innerHTML = `<div class="safe-ico">${n.icon}</div><div><div class="safe-name">${n.label}</div><div class="safe-desc">${n.prompt}</div></div>`;
      scards.appendChild(c);
    });

    // ── SPEECH ─────────────────────────────────────────────────────────────
    let speakTimer: ReturnType<typeof setTimeout>;
    function speak(txt: string, color = 'var(--p31-teal)') {
      speechEl.textContent = txt;
      speechEl.style.borderColor = color;
      speechEl.classList.add('on');
      clearTimeout(speakTimer);
    }
    function quieten(delay = 0) {
      clearTimeout(speakTimer);
      speakTimer = setTimeout(() => speechEl.classList.remove('on'), delay);
    }
    phosEl.addEventListener('mouseenter', () => speak('I am the bond at the center. The Phosphorus.', 'var(--p31-amber)'));
    phosEl.addEventListener('mouseleave', () => quieten(400));

    // ── EYE TRACKING ───────────────────────────────────────────────────────
    let mx = 0, my = 0;
    window.addEventListener('mousemove', (e) => {
      if (document.body.classList.contains('safe')) return;
      mx = e.clientX; my = e.clientY;
      const r   = phosEl.getBoundingClientRect();
      const ex  = r.left + r.width  / 2;
      const ey  = r.top  + r.height / 2;
      const ang = Math.atan2(e.clientY - ey, e.clientX - ex);
      const d   = Math.min(3, Math.hypot(e.clientX - ex, e.clientY - ey) * 0.014);
      const ox  = Math.cos(ang) * d, oy = Math.sin(ang) * d;
      if (pl) pl.style.transform = `translate(${ox}px,${oy}px)`;
      if (pr) pr.style.transform = `translate(${ox}px,${oy}px)`;
    }, { passive: true });

    // ── CANVAS SETUP ────────────────────────────────────────────────────────
    let W = 0, H = 0, CX = 0, CY = 0, R1 = 0, R2 = 0, R3 = 0, raf = 0;
    const dpr = window.devicePixelRatio || 1;

    function resize() {
      W = window.innerWidth; H = window.innerHeight;
      CX = W / 2; CY = H / 2;
      c1.width  = W * dpr; c1.height = H * dpr;
      c1.style.width  = W + 'px'; c1.style.height = H + 'px';
      ctx1.setTransform(dpr, 0, 0, dpr, 0, 0);
      const m = Math.min(W, H);
      // Spec radii: 120/200/280 — scale to viewport
      R1 = Math.max(110, m * 0.22);
      R2 = Math.max(185, m * 0.35);
      R3 = Math.max(260, m * 0.48);
    }

    // ── DATA PACKETS (light streaks flowing along tethers toward core) ─────
    class Packet {
      t: number; speed: number; len: number;
      constructor(ring: number) {
        this.t     = Math.random();
        this.speed = (0.003 + (4 - ring) * 0.001) * (0.7 + Math.random() * 0.6);
        this.len   = 8 + Math.random() * 12;
      }
      tick(x1: number, y1: number, x2: number, y2: number, cpx: number, cpy: number) {
        this.t += this.speed;
        if (this.t > 1) this.t = 0;
        const tm = 1 - this.t;
        const x  = tm*tm*x1 + 2*tm*this.t*cpx + this.t*this.t*x2;
        const y  = tm*tm*y1 + 2*tm*this.t*cpy + this.t*this.t*y2;
        const dx = 2*tm*(cpx - x1) + 2*this.t*(x2 - cpx);
        const dy = 2*tm*(cpy - y1) + 2*this.t*(y2 - cpy);
        ctx1.save();
        ctx1.translate(x, y);
        ctx1.rotate(Math.atan2(dy, dx));
        const g = ctx1.createLinearGradient(-this.len/2, 0, this.len/2, 0);
        g.addColorStop(0,   'rgba(255,255,255,0)');
        g.addColorStop(0.5, 'rgba(255,255,255,0.88)');
        g.addColorStop(1,   'rgba(255,255,255,0)');
        ctx1.fillStyle = g;
        ctx1.fillRect(-this.len/2, -1.5, this.len, 3);
        ctx1.restore();
      }
    }
    state.forEach(s => {
      s.packets = [new Packet(s.data.ring), new Packet(s.data.ring), new Packet(s.data.ring)];
    });

    // ── MOLECULE DRAW ───────────────────────────────────────────────────────
    function drawMolecule(t: number) {
      ctx1.clearRect(0, 0, W, H);
      const px = (mx - CX) * 0.02;
      const py = (my - CY) * 0.02;

      // Orbital shell rings (dashed, counter-rotating, elliptical)
      ([R1, R2, R3] as const).forEach((r, i) => {
        ctx1.beginPath();
        ctx1.ellipse(CX, CY, r, r * 0.6, 0, 0, Math.PI * 2);
        ctx1.strokeStyle = `rgba(77,184,168,${0.042 + i * 0.016})`;
        ctx1.lineWidth   = 0.8;
        ctx1.setLineDash([4, 12]);
        ctx1.lineDashOffset = -t * 8 * (i % 2 === 0 ? 1 : -1);
        ctx1.stroke();
        ctx1.setLineDash([]);
      });

      // Node orbits + tethers + packets (elliptical: y *= 0.6)
      state.forEach((s, i) => {
        if (!s.hovered) s.angle += RING_SPEED[s.data.ring];
        const R   = [R1, R2, R3][s.data.ring - 1] + Math.sin(t * 1.6 + i) * 4;
        const dep = s.data.ring;
        s.x = CX + Math.cos(s.angle) * R - px * dep;
        s.y = CY + Math.sin(s.angle) * R * 0.6 - py * dep;
        s.el.style.transform = `translate3d(${s.x}px,${s.y}px,0)`;

        // Organic quadratic bezier tether: node → PHOS core
        const dx  = s.x - CX, dy = s.y - CY;
        const dl  = Math.hypot(dx, dy) || 1;
        const dir = i % 2 === 0 ? 1 : -1;
        const cpx = (CX + s.x) / 2 + (-dy / dl * 50 * dir);
        const cpy = (CY + s.y) / 2 + ( dx / dl * 50 * dir);

        ctx1.beginPath();
        ctx1.moveTo(CX, CY);
        ctx1.quadraticCurveTo(cpx, cpy, s.x, s.y);
        const g = ctx1.createLinearGradient(CX, CY, s.x, s.y);
        g.addColorStop(0, 'rgba(77,184,168,0.55)');
        g.addColorStop(1, 'rgba(77,184,168,0)');
        ctx1.strokeStyle = g; ctx1.lineWidth = 2;
        ctx1.setLineDash([6, 8]); ctx1.lineDashOffset = -t * 26;
        ctx1.stroke(); ctx1.setLineDash([]);

        s.packets.forEach(p => p.tick(s.x, s.y, CX, CY, cpx, cpy));
      });

      // PHOS parallax + float (JS-driven)
      const floatY = Math.sin(t * (Math.PI / 3)) * 14;
      phosEl.style.transform = `translate3d(${-px}px,${-(floatY + py)}px,0)`;
    }

    // ── RENDER LOOP ─────────────────────────────────────────────────────────
    function loop() {
      if (document.body.classList.contains('safe')) return;
      if (!c1.isConnected) return;
      drawMolecule(Date.now() * 0.001);
      raf = requestAnimationFrame(loop);
    }

    // ── AKINATOR ────────────────────────────────────────────────────────────
    function openAkinator() { renderAki(AKI_TREE); akiOverlay.classList.add('active'); quieten(); }
    function closeAkinator() { akiOverlay.classList.remove('active'); }

    function renderAki(node: AkiNode) {
      akiQ.textContent = node.q;
      akiOpts.innerHTML = '';
      node.opts.forEach(o => {
        const b = document.createElement('button');
        b.className = 'aki-btn';
        b.innerHTML = `<span>${o.label}</span><span style="color:var(--p31-teal)">→</span>`;
        b.onclick = () => o.href ? (window.location.href = o.href) : renderAki(o.next!);
        akiOpts.appendChild(b);
      });
    }

    phosEl.addEventListener('click', openAkinator);
    phosEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openAkinator(); }
    });
    document.getElementById('aki-close')?.addEventListener('click', closeAkinator);
    akiOverlay.addEventListener('click', (e) => { if (e.target === akiOverlay) closeAkinator(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAkinator(); });

    // ── SAFE MODE ────────────────────────────────────────────────────────────
    function setSafe(on: boolean) {
      document.body.classList.toggle('safe', on);
      const statusEl = document.getElementById('run-status') as HTMLElement;
      const btnEl    = document.getElementById('btn-safe')   as HTMLButtonElement;
      statusEl.textContent = on ? '○ SUSPENDED' : '● RUNNING';
      statusEl.style.color = on ? 'var(--p31-muted)' : 'var(--p31-phosphorus)';
      btnEl.textContent    = on ? 'Restore' : 'Safe Mode';
      if (on) {
        cancelAnimationFrame(raf);
        ctx1.clearRect(0, 0, W, H);
        quieten();
        phosEl.style.transform = '';
        localStorage.setItem('p31_safe_mode', 'true');
      } else {
        localStorage.removeItem('p31_safe_mode');
        resize(); loop();
        speak('Ca₉(PO₄)₆ coherence rebuilding.', 'var(--p31-teal)');
        quieten(4000);
      }
    }

    // activateLayer0 — restores Layer 0 (starfield) from safe mode
    // Required anchor: verify:egg-hunt HUB-LAYER0
    function activateLayer0() { setSafe(false); }

    document.getElementById('btn-safe')?.addEventListener('click', () =>
      setSafe(!document.body.classList.contains('safe'))
    );
    document.getElementById('btn-restore')?.addEventListener('click', activateLayer0);

    // Hold ESC for 1s to exit safe mode
    let escTimer: ReturnType<typeof setTimeout> | null = null;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.body.classList.contains('safe')) {
        if (!escTimer) {
          escTimer = setTimeout(() => { activateLayer0(); escTimer = null; }, 1000);
        }
      }
    });
    document.addEventListener('keyup', (e) => {
      if (e.key === 'Escape' && escTimer) { clearTimeout(escTimer); escTimer = null; }
    });

    // ── INIT ─────────────────────────────────────────────────────────────────
    try {
      const pass = JSON.parse(localStorage.getItem('p31_cognitive_passport') || '{}');
      if (pass.preferences?.screenComfort === 0 || localStorage.getItem('p31_safe_mode') === 'true') {
        setSafe(true);
      }
    } catch (_) {}
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) setSafe(true);
    if (new URLSearchParams(location.search).get('safe') === '1') setSafe(true);

    window.addEventListener('resize', resize, { passive: true });
    resize();

    if (!document.body.classList.contains('safe')) {
      loop();
      speak('Ca₉(PO₄)₆ coherence stabilized. PHOS is listening.', 'var(--p31-teal)');
      quieten(5000);
    }
  </script>
</AppShell>
