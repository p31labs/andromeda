---
/**
 * P31 Labs Unified Landing Page
 * Product grid + prototypes + research: single source via hub-landing.json
 * (scripts/hub/build-landing-data.mjs from registry.mjs). CWP D2.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import hubLanding from '../data/hub-landing.json';

const coreProducts = hubLanding.coreProducts;
const prototypes = hubLanding.prototypes;
const research = hubLanding.research;

const getStatusStyles = (status: string) => {
  if (status === 'LIVE')
    return {
      text: 'text-phosphorus',
      bg: 'bg-phosphorus/10',
      border: 'border-phosphorus/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(59,163,114,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'BUILDING')
    return {
      text: 'text-butter',
      bg: 'bg-butter/10',
      border: 'border-butter/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(205,168,82,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'RESEARCH' || status === 'TOOL')
    return {
      text: 'text-teal',
      bg: 'bg-teal/10',
      border: 'border-teal/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(37,137,125,0.22),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  return {
    text: 'text-muted',
    bg: 'bg-muted/10',
    border: 'border-muted/30',
    glow: 'group-hover:shadow-[0_12px_40px_rgba(107,114,128,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
  };
};

/** CWP D3 — filter counts from hub-landing (registry-driven) */
const FILTER_ORDER = ['LIVE', 'BUILDING', 'RESEARCH', 'TOOL'] as const;
const countByStatus = coreProducts.reduce(
  (acc, p) => {
    acc[p.status] = (acc[p.status] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const pageDescription =
  'P31 Labs — edge-native mesh for families and builders: K₄ co-presence, geodesic stack, glass-box ops. Verify-gated ship bar, accessibility-minded UI, no engagement dark patterns.';
---

<BaseLayout
  title="P31 Labs | Sovereign technical hub"
  description={pageDescription}
>
  <Fragment slot="head">
    <link rel="canonical" href="https://p31ca.org/" />
    <meta property="og:site_name" content="P31 Labs" />
    <meta
      property="og:title"
      content="P31 Labs — Build, create, connect on the edge"
    />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://p31ca.org/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="P31 Labs — Sovereign technical hub"
    />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>

  <Fragment slot="importmaps">
    <!-- Import Map for Three.js -->
    <script type="importmap" is:inline>
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.183.0/build/three.module.js",
          "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.183.0/examples/jsm/"
        }
      }
    </script>
  </Fragment>
  

  
  <!-- 3D Canvas Background -->
  <div id="webgl-container" class="fixed inset-0 z-5 bg-void"></div>

  <!-- FIXED SOVEREIGN HUD (Top Nav) -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 glass-panel border-b border-white/[0.07] flex flex-col gap-3 pt-[max(0.5rem,env(safe-area-inset-top))] pb-2 pl-[max(0.75rem,env(safe-area-inset-left))] pr-[max(0.75rem,env(safe-area-inset-right))] sm:px-5 md:flex-row md:items-center md:justify-between md:gap-4 text-sm font-mono text-cloud shadow-[0_4px_30px_rgba(0,0,0,0.5)] md:text-xs"
    aria-label="Primary"
  >
    
    <!-- Logo & Q-Factor -->
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 font-bold text-white tracking-widest uppercase">
        <svg width="18" height="18" viewBox="0 0 512 512" class="opacity-90"><rect width="512" height="512" rx="112" fill="#25897d"/><circle cx="390" cy="120" r="48" fill="#cc6247"/><text x="256" y="340" font-family="system-ui" font-weight="900" font-size="220" fill="#d8d6d0" text-anchor="middle">P31</text><rect x="156" y="380" width="200" height="16" rx="8" fill="#cda852"/></svg>
        <span>Cockpit</span>
      </div>
      <div class="h-4 w-px bg-white/10"></div>
      <div class="flex items-center gap-2" title="Fisher-Escolà Coherence Score">
        <span class="w-2 h-2 rounded-full bg-phosphorus shadow-[0_0_8px_rgba(59,163,114,0.55)] animate-pulse" id="nav-status-dot"></span>
        <span class="text-muted">Q-FACTOR:</span>
        <span class="font-bold text-phosphorus tracking-wider" id="nav-q-factor">0.925</span>
      </div>
    </div>

    <!-- Central Telemetry: Spoons & Fleet -->
    <div
      class="flex max-w-full items-center gap-4 overflow-x-auto overflow-y-visible overscroll-x-contain bg-void/50 px-3 py-2 [scrollbar-width:thin] sm:gap-6 sm:px-4 rounded-md border border-white/[0.07] md:max-w-none md:overflow-visible"
    >
      <div class="flex items-center gap-2" title="Vertex A: Operator State">
        <span class="text-muted">SPOONS</span>
        <div class="w-16 h-1.5 bg-surface2 rounded-full overflow-hidden">
          <div id="nav-spoon-fill" class="h-full bg-coral transition-all duration-500" style="width: 50%;"></div>
        </div>
        <span id="nav-spoon-val" class="text-coral font-bold">10</span>
      </div>
      <div class="h-3 w-px bg-white/10"></div>
      <div class="flex items-center gap-2" title="L.O.V.E. Ledger Balance">
        <span class="text-muted">L.O.V.E.</span>
        <span id="nav-love-val" class="text-teal font-bold">3.28</span>
      </div>
      <div class="h-3 w-px bg-white/10 hidden md:block"></div>
      <div class="hidden md:flex items-center gap-2">
        <span class="text-muted">FLEET:</span>
        <span id="nav-fleet-val" class="text-cloud">4/4</span>
      </div>
      <div class="h-3 w-px bg-white/10 hidden xl:block"></div>
      <div
        class="hidden xl:flex items-center gap-2"
        title="As above, so below — p31ca HUD ↔ k4-personal edge (vitality, V/E L♥)"
      >
        <span class="text-muted">MESH</span>
        <span id="nav-mesh-vit" class="text-lavender font-bold">—</span>
        <span class="text-muted text-[10px]">L♥</span>
        <span id="nav-mesh-ve" class="text-cloud text-[10px] font-mono">—</span>
        <span id="nav-mesh-detail" class="text-muted text-[9px] font-mono max-w-[7rem] truncate hidden 2xl:inline" title=""> </span>
        <a href="/mesh-observatory/" class="text-lavender hover:text-lavender/85 hover:underline text-[10px] font-bold" title="Mesh Observatory">OBS</a>
      </div>
    </div>

    <!-- Trimtab & Actions: mobile-first touch targets, dense labels on md+ -->
    <div
      class="flex w-full flex-wrap items-center justify-center gap-2 sm:justify-end md:w-auto md:justify-end"
    >
      <div
        class="group inline-flex min-h-[2.75rem] min-w-[2.75rem] cursor-pointer items-center gap-2 rounded-md px-1 md:min-h-0 md:min-w-0"
        id="trimtab-trigger"
        title="Drag to tune · Click for Layer 0"
      >
        <canvas id="trimtab-canvas" width="24" height="24" class="opacity-80 transition-opacity group-hover:opacity-100"></canvas>
        <span id="trimtab-freq" class="text-butter font-bold">863Hz</span>
      </div>
      <div class="h-4 w-px bg-white/10 max-md:hidden" aria-hidden="true"></div>
      <a
        href="/dome"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-teal/30 bg-teal/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-teal hover:bg-teal/20 hover:text-phosphorus md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Sovereign Cockpit K₄ dome">Dome</a>
      <a
        href="/demos"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-butter/35 bg-butter/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-butter hover:bg-butter/20 hover:text-butter/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Static demo labs — fleet map, canon, onboarding">Demos</a>
      <a
        href="/journey"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-phosphorus/35 bg-phosphorus/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-phosphorus hover:bg-phosphorus/20 hover:brightness-110 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Core path — onboard, authenticate, EDE home">Journey</a>
      <a
        href="/ops/"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-lavender/35 bg-lavender/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-lavender hover:bg-lavender/20 hover:text-lavender/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="G.O.D. operator shell — glass + shift">Ops</a>
      <a
        href="/auth"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-coral/30 bg-coral/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-coral hover:bg-coral/20 hover:brightness-110 md:min-h-0 md:py-1 md:text-[10px]"
      >
        Authenticate
      </a>
    </div>
  </nav>

  <!-- Node Detail Panel -->
  <aside
    id="node-detail-panel"
    class="pointer-events-none fixed bottom-[max(1rem,env(safe-area-inset-bottom))] left-4 right-4 z-40 w-auto max-w-sm translate-y-4 transform rounded-xl border-l border-t border-white/10 bg-void/95 p-5 opacity-0 shadow-[0_10px_40px_rgba(0,0,0,0.8)] backdrop-blur-sm transition-all duration-300 sm:left-6 sm:right-auto sm:w-80"
  >
    <button
      id="node-detail-close"
      class="text-muted pointer-events-auto absolute right-2 top-2 inline-flex min-h-[2.75rem] min-w-[2.75rem] items-center justify-center rounded-md hover:bg-white/10 hover:text-white"
      type="button"
      aria-label="Close details"
    >
      ✕
    </button>
    <div class="text-teal font-bold text-lg mb-1" id="nd-title">Node Name</div>
    <div class="flex items-center gap-3 text-[10px] font-mono mb-4 pb-3 border-b border-white/10">
      <span id="nd-axis" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-white/70">Axis</span>
      <span id="nd-state" class="px-2 py-0.5 rounded border">State</span>
      <span id="nd-bus" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-white/70">Bus</span>
    </div>
    <div id="nd-notes" class="text-sm text-cloud mb-4 leading-relaxed font-sans">Node description goes here.</div>
    <div class="text-[10px] font-mono text-muted mb-2 uppercase tracking-widest">Entangled Edges</div>
    <div id="nd-conns" class="flex flex-wrap gap-2 pointer-events-auto"></div>
  </aside>

  <!-- LAYER 0: Somatic Mode Overlay -->
  <div id="layer0" class="fixed inset-0 z-[100] bg-void flex flex-col items-center justify-center gap-6 transition-opacity duration-1000 opacity-0 pointer-events-none">
    <div class="absolute top-8 left-1/2 -translate-x-1/2 flex items-center gap-4 font-mono text-xs text-muted">
      <span>SPOONS</span>
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-spoon-fill" class="h-full bg-coral transition-all duration-500"></div>
      </div>
      <span id="l0-spoon-pct">50%</span>
    </div>
    <div id="l0-dot" class="w-16 h-16 rounded-full bg-coral opacity-40 transform scale-75"></div>
    <div id="l0-phase" class="text-xl font-mono text-coral tracking-[0.2em] uppercase">INHALE</div>
    <div class="absolute bottom-12 flex flex-col items-center gap-3">
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-escape-fill" class="h-full w-0 bg-coral"></div>
      </div>
      <div class="text-[10px] font-mono text-muted tracking-widest uppercase">Hold ESC to exit</div>
    </div>
  </div>

  <!-- MAIN SCROLLING CONTENT -->
  <!-- pointer-events-none allows background clicking, but we restore it on .interactive-zone -->
  <main
    id="scroll-container"
    class="pointer-events-none relative z-10 mx-auto max-w-7xl px-4 pt-40 pb-16 font-sans text-cloud sm:px-6 sm:pb-24 md:pt-32"
  >
    <div
      class="pointer-events-none absolute left-1/2 top-0 -z-10 h-[min(60vh,28rem)] w-[min(100%,90rem)] -translate-x-1/2 hub-hero-aura"
      aria-hidden="true"
    >
    </div>
    <a
      href="#core-products"
      class="skip-to-content focus:pointer-events-auto interactive-zone"
    >
      Skip to architecture grid
    </a>

    <!-- 1. Hero — editorial type, ethical signals, CTAs -->
    <header
      class="animate-fade-in-up relative z-[1] mb-16 text-center sm:mb-20 md:mb-28 md:pt-4 interactive-zone"
      style="animation-delay: 0.08s;"
    >
      <p
        class="mb-3 font-mono text-[10px] font-semibold uppercase tracking-[0.35em] text-cyan/90 sm:text-[11px] sm:tracking-[0.4em]"
      >
        Technical hub
      </p>
      <h1
        class="mx-auto mb-4 max-w-[18ch] bg-gradient-to-b from-white via-white to-cloud/85 bg-clip-text text-balance text-[clamp(2.5rem,5.5vw+0.5rem,4.25rem)] font-bold leading-[0.95] tracking-[-0.04em] text-transparent drop-shadow-[0_1px_40px_rgba(0,0,0,0.45)] sm:mb-5"
      >
        P31 Labs
      </h1>
      <p
        class="mx-auto mb-2 max-w-2xl font-mono text-base font-medium leading-snug tracking-tight text-cloud/90 sm:text-lg md:text-xl"
      >
        Isostatically rigid. Cognitively sovereign.
      </p>
      <p
        class="mx-auto mb-8 max-w-xl text-sm leading-relaxed text-muted sm:mb-10 sm:text-base"
      >
        <span class="text-cloud/90">Build, create, connect</span> — family-scale mesh, verify-gated releases, and
        interfaces that respect attention.
      </p>

      <ul
        class="mb-10 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 font-mono text-[10px] uppercase tracking-wider text-muted sm:mb-12 sm:gap-x-4 sm:text-[11px]"
        role="list"
        aria-label="Ship and ethics signals"
      >
        <li
          class="inline-flex items-center gap-2 rounded-full border border-teal/25 bg-teal/5 px-3 py-1.5 text-teal/95"
        >
          <span
            class="h-1.5 w-1.5 rounded-full bg-phosphorus shadow-[0_0_8px_rgba(59,163,114,0.5)]"
            aria-hidden="true"
          />
          Verify-gated
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-cyan/80" aria-hidden="true" />
          A11y-minded
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-butter/20 bg-butter/5 px-3 py-1.5 text-butter/95"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-butter/90" aria-hidden="true" />
          No dark patterns
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-lavender/20 bg-lavender/5 px-3 py-1.5 text-lavender/90"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-lavender/80" aria-hidden="true" />
          Open core
        </li>
      </ul>

      <div
        class="flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center sm:gap-4"
      >
        <button
          id="btn-explore-dome"
          type="button"
          class="hub-cta-primary w-full min-h-[3.25rem] rounded-lg px-7 py-3.5 text-center text-base font-bold tracking-tight text-white sm:w-auto"
          title="Sovereign Cockpit K₄ dome"
        >
          Explore Dome
        </button>
        <a
          href="#core-products"
          class="hub-cta-secondary glass-panel inline-flex w-full min-h-[3.25rem] items-center justify-center gap-2 rounded-lg border border-white/12 px-7 py-3.5 text-center text-base font-bold tracking-tight text-cloud transition-all duration-300 hover:border-white/20 hover:bg-white/5 sm:w-auto"
        >
          View architecture
          <span class="text-cyan" aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    <!-- 1a. Operator shell (G.O.D.) -->
    <div class="mb-10 interactive-zone animate-fade-in-up" style="animation-delay: 0.14s;">
      <a href="/ops/" class="group flex flex-col gap-4 rounded-[12px] border border-lavender/35 p-5 no-underline transition-all duration-300 hover:border-lavender/55 hover:bg-surface2/90 sm:flex-row sm:items-center sm:justify-between glass-panel">
        <div>
          <div class="mb-2 font-mono text-xs uppercase tracking-widest text-lavender sm:text-[10px]">/ operator</div>
          <h2 class="font-bold text-white text-lg mb-1 group-hover:text-lavender/90 transition-colors">G.O.D. — operator shell</h2>
          <p class="text-sm text-cloud/70 max-w-xl leading-relaxed">Glass-box probes from <span class="font-mono text-cloud/90">p31-ecosystem.json</span>, system pulse, density dial, and edge shift readout. Pair with <span class="font-mono text-teal/90">npm run command-center</span> on your machine.</p>
        </div>
        <span class="inline-flex min-h-[2.75rem] flex-shrink-0 items-center justify-center rounded-[6px] bg-lavender/90 px-5 py-2.5 text-sm font-bold tracking-wide text-white sm:min-h-0">Open /ops →</span>
      </a>
    </div>

    <!-- 1b. Wye→Delta Entry Banner -->
    <div class="mb-16 interactive-zone animate-fade-in-up" style="animation-delay: 0.18s;">
      <a href="/delta.html" class="group flex flex-col gap-4 rounded-[12px] border border-teal/30 p-6 no-underline transition-all duration-300 hover:border-teal/60 hover:bg-surface2/90 sm:flex-row sm:items-center sm:justify-between glass-panel">
        <div>
          <div class="mb-2 font-mono text-xs uppercase tracking-widest text-teal sm:text-[10px]">/ new_here</div>
          <h2 class="font-bold text-white text-lg mb-1 group-hover:text-teal transition-colors">Why a mesh instead of an app?</h2>
          <p class="text-sm text-cloud/70 max-w-lg leading-relaxed">P31 runs on a K₄ tetrahedron — four vertices, six edges, zero central authority. The Wye→Delta story explains why that matters.</p>
        </div>
        <div class="flex gap-3 shrink-0 pointer-events-none">
          <span class="px-5 py-2.5 bg-teal/90 text-white font-bold rounded-[6px] text-sm tracking-wide whitespace-nowrap">Wye → Delta</span>
          <span class="px-5 py-2.5 border border-white/10 text-cloud font-bold rounded-[6px] text-sm tracking-wide whitespace-nowrap">Join the mesh →</span>
        </div>
      </a>
    </div>

    <!-- 2. Core Products Grid (CWP D3 — client filter by status) -->
    <section id="core-products" class="mb-24 pt-12 animate-fade-in-up interactive-zone" style="animation-delay: 0.22s;" aria-label="Core architecture products">
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-sm uppercase tracking-widest font-bold text-muted font-mono">/ core_architecture</h2>
        <div class="h-px bg-white/10 flex-grow"></div>
      </div>
      <div
        class="mb-6 flex flex-wrap items-stretch gap-2 font-mono text-sm uppercase tracking-wider sm:items-center md:text-[11px]"
        role="toolbar"
        aria-label="Filter products by status"
        id="hub-core-filters"
      >
        <span class="mr-1 hidden self-center text-muted sm:inline">Filter</span>
        <button
          type="button"
          data-filter="all"
          class="hub-filter-btn rounded border border-teal/50 bg-teal/10 px-4 py-2.5 text-teal transition-colors md:px-3 md:py-1.5"
          aria-pressed="true"
        >All ({coreProducts.length})</button>
        {FILTER_ORDER.map((st) => {
          const n = countByStatus[st] || 0;
          if (n === 0) return null;
          return (
            <button
              type="button"
              data-filter={st.toLowerCase()}
              class="hub-filter-btn rounded border border-white/10 px-4 py-2.5 text-muted transition-colors hover:border-white/20 hover:text-cloud md:px-3 md:py-1.5"
              aria-pressed="false"
            >
              {st} ({n})
            </button>
          );
        })}
      </div>
      <div id="hub-core-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {coreProducts.map((product) => {
          const styles = getStatusStyles(product.status);
          return (
            <a
              href={product.url}
              target="_blank"
              rel="noopener noreferrer"
              data-product-status={product.status}
              class={`hub-product-card glass-panel p-6 rounded-[12px] flex flex-col group hover:bg-surface2/98 transition-all duration-200 hover:-translate-y-3 hover:translate-z-12 border-t border-l border-white/15 hover:border-white/30 ${styles.glow} transform-gpu shadow-[0_8px_32px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.06)] hover:shadow-[0_20px_60px_rgba(0,0,0,0.6),inset_0_1px_0_rgba(255,255,255,0.1)]`}
            >
              <div class="flex justify-between items-start mb-4">
                <h3 class="font-bold text-white text-lg transition-colors">{product.title}</h3>
                <span class={`text-[9px] font-mono px-2 py-1 rounded-[4px] border uppercase tracking-wider ${styles.text} ${styles.bg} ${styles.border}`}>
                  {product.status}
                </span>
              </div>
              <p class="text-sm text-cloud opacity-80 mb-8 leading-relaxed flex-grow">{product.desc}</p>
              <div class="flex gap-2 flex-wrap mt-auto">
                {product.tags.map(tag => (
                  <span class="text-[10px] font-mono text-muted bg-white/5 border border-white/5 px-2 py-1 rounded-[4px]">{tag}</span>
                ))}
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <script is:inline>
      (function () {
        var root = document.getElementById("hub-core-grid");
        var bar = document.getElementById("hub-core-filters");
        if (!root || !bar) return;
        var cards = root.querySelectorAll("[data-product-status]");
        var buttons = bar.querySelectorAll(".hub-filter-btn");
        function apply(filter) {
          var f = (filter || "all").toLowerCase();
          cards.forEach(function (el) {
            var st = (el.getAttribute("data-product-status") || "").toLowerCase();
            var show = f === "all" || st === f;
            if (show) {
              el.classList.remove("hidden");
              el.removeAttribute("aria-hidden");
            } else {
              el.classList.add("hidden");
              el.setAttribute("aria-hidden", "true");
            }
          });
          buttons.forEach(function (btn) {
            var isAll = f === "all" && (btn.getAttribute("data-filter") || "") === "all";
            var isSt = f !== "all" && (btn.getAttribute("data-filter") || "").toLowerCase() === f;
            var active = isAll || isSt;
            btn.setAttribute("aria-pressed", active ? "true" : "false");
            if (active) {
              btn.className =
                "hub-filter-btn rounded border border-teal/50 bg-teal/10 px-4 py-2.5 text-teal transition-colors md:px-3 md:py-1.5";
            } else {
              btn.className =
                "hub-filter-btn rounded border border-white/10 px-4 py-2.5 text-muted transition-colors hover:border-white/20 hover:text-cloud md:px-3 md:py-1.5";
            }
          });
        }
        buttons.forEach(function (btn) {
          btn.addEventListener("click", function () {
            apply(btn.getAttribute("data-filter"));
          });
        });
      })();
    </script>

