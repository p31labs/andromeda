  { title: "Genesis Gate", status: "BUILDING", desc: "Authentication and entry node", tags: ["JWT", "WebAuthn"], url: "/genesis-gate-about.html" },
  { title: "K4 Market", status: "LIVE", desc: "Tomography marketplace", tags: ["Market", "Token"], url: "/k4market-about.html" },
  { title: "Kenosis Mesh", status: "BUILDING", desc: "Distributed network protocol layer", tags: ["Libp2p", "WebRTC"], url: "/kenosis-about.html" },
  { title: "Larmor", status: "LIVE", desc: "Decentralized offline-first credential vault", tags: ["WebCrypto", "IndexedDB"], url: "/larmor-about.html" },
  { title: "Liminal", status: "LIVE", desc: "Transition space simulator", tags: ["Animation", "UX"], url: "/liminal-about.html" },
  { title: "P31 Mesh", status: "LIVE", desc: "Local-first SQLite syncing and replication", tags: ["CRDT", "PGLite"], url: "/mesh-about.html" },
