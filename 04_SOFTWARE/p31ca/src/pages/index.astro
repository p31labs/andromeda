---
/**
 * P31 Labs Unified Landing Page
 * Product grid + prototypes + research: single source via hub-landing.json
 * (scripts/hub/build-landing-data.mjs from registry.mjs). CWP D2.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import hubLanding from '../data/hub-landing.json';
import missionTrio from '../data/p31-mission-trio.json';

const coreProducts = hubLanding.coreProducts;
const prototypes = hubLanding.prototypes;
const research = hubLanding.research;

const getStatusStyles = (status: string) => {
  if (status === 'LIVE')
    return {
      text: 'text-phosphorus',
      bg: 'bg-phosphorus/10',
      border: 'border-phosphorus/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(59,163,114,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'BUILDING')
    return {
      text: 'text-butter',
      bg: 'bg-butter/10',
      border: 'border-butter/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(205,168,82,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'HARDWARE')
    return {
      text: 'text-butter',
      bg: 'bg-butter/15',
      border: 'border-butter/35',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(205,168,82,0.25),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  if (status === 'RESEARCH' || status === 'TOOL')
    return {
      text: 'text-teal',
      bg: 'bg-teal/10',
      border: 'border-teal/30',
      glow: 'group-hover:shadow-[0_12px_40px_rgba(37,137,125,0.22),inset_0_1px_0_rgba(255,255,255,0.08)]',
    };
  return {
    text: 'text-p31-muted',
    bg: 'bg-p31-muted-10',
    border: 'border-p31-muted-30',
    glow: 'group-hover:shadow-[0_12px_40px_rgba(107,114,128,0.2),inset_0_1px_0_rgba(255,255,255,0.08)]',
  };
};

/** CWP D3 — filter counts from hub-landing (registry-driven) */
const FILTER_ORDER = ['LIVE', 'BUILDING', 'HARDWARE', 'RESEARCH', 'TOOL'] as const;
const countByStatus = coreProducts.reduce(
  (acc, p) => {
    acc[p.status] = (acc[p.status] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const pageDescription =
  'Free tools that adapt to how your brain works — AI context card, open-source hub, no login. Georgia nonprofit.';
---

<BaseLayout
  title="P31 Labs | Tools that adapt to your brain"
  description={pageDescription}
>
  <Fragment slot="head">
    <link rel="canonical" href="https://p31ca.org/" />
    <meta property="og:site_name" content="P31 Labs" />
    <meta
      property="og:title"
      content="P31 Labs — Tools that adapt to your brain"
    />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://p31ca.org/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="P31 Labs — Tools that adapt to your brain"
    />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>

  <Fragment slot="importmaps">
    <!-- Import Map for Three.js -->
    <script type="importmap" is:inline>
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.183.0/build/three.module.js",
          "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.183.0/examples/jsm/"
        }
      }
    </script>
  </Fragment>
  

  
  <!-- 3D Canvas Background -->
  <div id="webgl-container" class="fixed inset-0 z-5 bg-p31-void"></div>

  <!-- FIXED SOVEREIGN HUD (Top Nav) -->
  <nav
    class="fixed top-0 left-0 right-0 z-50 glass-panel border-b border-white/[0.07] flex flex-col gap-3 pt-[max(0.5rem,env(safe-area-inset-top))] pb-2 pl-[max(0.75rem,env(safe-area-inset-left))] pr-[max(0.75rem,env(safe-area-inset-right))] sm:px-5 md:flex-row md:items-center md:justify-between md:gap-4 text-sm font-mono text-p31-cloud shadow-[0_4px_30px_rgba(0,0,0,0.5)] md:text-xs"
    aria-label="Primary"
  >
    
    <!-- Logo & Q-Factor — EDE: mono cluster + instrument readout -->
    <div class="flex min-w-0 flex-1 flex-wrap items-center gap-4">
      <a href="/" class="group flex min-w-0 shrink-0 items-center gap-3 no-underline" title="P31 Labs hub">
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded border border-teal/40 bg-teal/10 font-mono text-[11px] font-bold tracking-tight text-cyan transition-all group-hover:border-teal group-hover:bg-teal group-hover:text-p31-cloud group-hover:shadow-[0_0_15px_rgba(77,184,168,0.35)]"
        >
          P31
        </div>
        <span
          class="hidden font-mono text-[11px] font-semibold uppercase leading-tight tracking-[0.2em] text-p31-cloud/70 transition-colors group-hover:text-p31-cloud sm:inline sm:max-w-[14rem]"
        >
          P31 Labs — Cockpit</span>
      </a>
      <div class="h-4 w-px bg-white/10 max-sm:hidden"></div>
      <div class="flex items-center gap-2" title="Fisher-Escolà Coherence Score">
        <span class="w-2 h-2 rounded-full bg-phosphorus shadow-[0_0_8px_rgba(59,163,114,0.55)] animate-pulse" id="nav-status-dot"></span>
        <span class="text-p31-muted">Q-FACTOR:</span>
        <span class="font-bold text-phosphorus tracking-wider" id="nav-q-factor">0.925</span>
      </div>
    </div>

    <!-- Central Telemetry: Spoons & Fleet -->
    <div
      class="flex max-w-full items-center gap-4 overflow-x-auto overflow-y-visible overscroll-x-contain bg-p31-void-50 px-3 py-2 [scrollbar-width:thin] sm:gap-6 sm:px-4 rounded-md border border-white/[0.07] md:max-w-none md:overflow-visible"
    >
      <div class="flex items-center gap-2" title="Vertex A: Operator State">
        <span class="text-p31-muted">SPOONS</span>
        <div class="w-16 h-1.5 bg-surface2 rounded-full overflow-hidden">
          <div id="nav-spoon-fill" class="h-full bg-coral transition-all duration-500" style="width: 50%;"></div>
        </div>
        <span id="nav-spoon-val" class="text-coral font-bold">10</span>
      </div>
      <div class="h-3 w-px bg-white/10"></div>
      <div class="flex items-center gap-2" title="L.O.V.E. Ledger Balance">
        <span class="text-p31-muted">L.O.V.E.</span>
        <span id="nav-love-val" class="text-teal font-bold">3.28</span>
      </div>
      <div class="h-3 w-px bg-white/10 hidden md:block"></div>
      <div class="hidden md:flex items-center gap-2">
        <span class="text-p31-muted">FLEET:</span>
        <span id="nav-fleet-val" class="text-p31-cloud">4/4</span>
      </div>
      <div class="h-3 w-px bg-white/10 hidden xl:block"></div>
      <div
        class="hidden xl:flex items-center gap-2"
        title="As above, so below — p31ca HUD ↔ k4-personal edge (vitality, V/E L♥)"
      >
        <span class="text-p31-muted">MESH</span>
        <span id="nav-mesh-vit" class="text-lavender font-bold">—</span>
        <span class="text-p31-muted text-[10px]">L♥</span>
        <span id="nav-mesh-ve" class="text-p31-cloud text-[10px] font-mono">—</span>
        <span id="nav-mesh-detail" class="text-p31-muted text-[9px] font-mono max-w-[7rem] truncate hidden 2xl:inline" title=""> </span>
        <a href="/mesh-observatory/" class="text-lavender hover:text-lavender/85 hover:underline text-[10px] font-bold" title="Mesh Observatory">OBS</a>
      </div>
    </div>

    <!-- Trimtab & Actions: mobile-first touch targets, dense labels on md+ -->
    <div
      class="flex w-full flex-wrap items-center justify-center gap-2 sm:justify-end md:w-auto md:justify-end"
    >
      <div
        class="group inline-flex min-h-[2.75rem] min-w-[2.75rem] cursor-pointer items-center gap-2 rounded-md px-1 md:min-h-0 md:min-w-0"
        id="trimtab-trigger"
        title="Drag to tune · Click for Layer 0"
      >
        <canvas id="trimtab-canvas" width="24" height="24" class="opacity-80 transition-opacity group-hover:opacity-100"></canvas>
        <span id="trimtab-freq" class="text-butter font-bold">863Hz</span>
      </div>
      <div class="h-4 w-px bg-white/10 max-md:hidden" aria-hidden="true"></div>
      <a
        href="/passport"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-phosphorus/35 bg-phosphorus/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-phosphorus hover:bg-phosphorus/25 hover:text-phosphorus md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="AI context card — free, runs in your browser">Context Card</a>
      <a
        href="/dome"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-teal/30 bg-teal/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-teal hover:bg-teal/20 hover:text-phosphorus md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Sovereign Cockpit K₄ dome">Dome</a>
      <a
        href="/demos"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-butter/35 bg-butter/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-butter hover:bg-butter/20 hover:text-butter/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Static demo labs — fleet map, canon, onboarding">Demos</a>
      <a
        href="/journey"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-phosphorus/35 bg-phosphorus/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-phosphorus hover:bg-phosphorus/20 hover:brightness-110 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="Core path — onboard, authenticate, EDE home">Journey</a>
      <a
        href="/ops/"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-lavender/35 bg-lavender/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-lavender hover:bg-lavender/20 hover:text-lavender/90 md:min-h-0 md:px-2 md:py-1 md:text-[10px]"
        title="G.O.D. operator shell — glass + shift">Ops</a>
      <a
        href="/auth"
        class="inline-flex min-h-[2.75rem] items-center justify-center rounded border border-coral/30 bg-coral/10 px-3 py-2 text-xs font-bold uppercase tracking-widest text-coral hover:bg-coral/20 hover:brightness-110 md:min-h-0 md:py-1 md:text-[10px]"
      >
        Authenticate
      </a>
    </div>
  </nav>

  <!-- Node Detail Panel -->
  <aside
    id="node-detail-panel"
    class="pointer-events-none fixed bottom-[max(1rem,env(safe-area-inset-bottom))] left-4 right-4 z-40 w-auto max-w-sm translate-y-4 transform rounded-xl border-l border-t border-white/10 bg-p31-void-95 p-5 opacity-0 shadow-[0_10px_40px_rgba(0,0,0,0.8)] backdrop-blur-sm transition-all duration-300 sm:left-6 sm:right-auto sm:w-80"
  >
    <button
      id="node-detail-close"
      class="text-p31-muted pointer-events-auto absolute right-2 top-2 inline-flex min-h-[2.75rem] min-w-[2.75rem] items-center justify-center rounded-md hover:bg-white/10 hover:text-p31-cloud"
      type="button"
      aria-label="Close details"
    >
      ✕
    </button>
    <div class="text-teal font-bold text-lg mb-1" id="nd-title">Node Name</div>
    <div class="flex items-center gap-3 text-[10px] font-mono mb-4 pb-3 border-b border-white/10">
      <span id="nd-axis" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70">Axis</span>
      <span id="nd-state" class="px-2 py-0.5 rounded border">State</span>
      <span id="nd-bus" class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-p31-cloud-70">Bus</span>
    </div>
    <div id="nd-notes" class="text-sm text-p31-cloud mb-4 leading-relaxed font-sans">Node description goes here.</div>
    <div class="text-[10px] font-mono text-p31-muted mb-2 uppercase tracking-widest">Entangled Edges</div>
    <div id="nd-conns" class="flex flex-wrap gap-2 pointer-events-auto"></div>
  </aside>

  <!-- LAYER 0: Somatic Mode Overlay -->
  <div id="layer0" class="fixed inset-0 z-[100] bg-p31-void flex flex-col items-center justify-center gap-6 transition-opacity duration-1000 opacity-0 pointer-events-none">
    <div class="absolute top-8 left-1/2 -translate-x-1/2 flex items-center gap-4 font-mono text-xs text-p31-muted">
      <span>SPOONS</span>
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-spoon-fill" class="h-full bg-coral transition-all duration-500"></div>
      </div>
      <span id="l0-spoon-pct">50%</span>
    </div>
    <div id="l0-dot" class="w-16 h-16 rounded-full bg-coral opacity-40 transform scale-75"></div>
    <div id="l0-phase" class="text-xl font-mono text-coral tracking-[0.2em] uppercase">INHALE</div>
    <div class="absolute bottom-12 flex flex-col items-center gap-3">
      <div class="w-32 h-1 bg-surface2 rounded-full overflow-hidden">
        <div id="l0-escape-fill" class="h-full w-0 bg-coral"></div>
      </div>
      <div class="text-[10px] font-mono text-p31-muted tracking-widest uppercase">Hold ESC to exit</div>
    </div>
  </div>

  <!-- MAIN SCROLLING CONTENT -->
  <!-- pointer-events-none allows background clicking, but we restore it on .interactive-zone -->
  <main
    id="scroll-container"
    class="pointer-events-none relative z-10 mx-auto max-w-7xl px-4 pt-40 pb-16 font-sans text-p31-cloud sm:px-6 sm:pb-24 md:pt-32"
  >
    <!-- Tier 0 — stranger-first (above the cockpit / lab) -->
    <section
      id="stranger-hero"
      class="pointer-events-auto interactive-zone relative z-[2] mx-auto mb-10 max-w-[42rem] px-2 pt-4 text-center md:mb-12 md:pt-6"
      aria-labelledby="stranger-hero-heading"
    >
      <h2
        id="stranger-hero-heading"
        class="mb-4 text-xl font-bold tracking-tight text-p31-cloud md:text-2xl"
      >
        Technology that adapts to your brain — not the other way around.
      </h2>
      <p class="mb-6 text-sm leading-relaxed text-p31-muted md:text-base">
        P31 Labs builds free, open-source tools for people whose brains work differently. No logins on these surfaces.
        No tracking on the context card. Start with your AI context card — or scroll down to explore what we ship in
        public.
      </p>
      <div class="mb-4 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center">
        <a
          href="/passport"
          class="hub-cta-primary inline-flex min-h-[3rem] w-full items-center justify-center rounded-lg px-7 py-3 text-center text-base font-bold tracking-tight text-p31-cloud sm:w-auto"
          title="Free AI context card"
        >
          Create your context card →
        </a>
        <a
          href="#technical-hub-boundary"
          class="glass-panel inline-flex min-h-[3rem] w-full items-center justify-center rounded-lg border border-white/12 px-7 py-3 text-center text-base font-bold tracking-tight text-p31-cloud transition-all duration-300 hover:border-white/20 hover:bg-white/5 sm:w-auto"
        >
          Explore the lab ↓
        </a>
      </div>
      <p class="font-mono text-[11px] uppercase tracking-wider text-p31-muted">
        Free · Open source · Georgia nonprofit (EIN 42-1888158)
      </p>
    </section>

    <div class="mx-auto mb-10 max-w-xl border-t border-white/10 opacity-90" role="presentation"></div>
    <p class="pointer-events-auto interactive-zone mx-auto mb-12 max-w-xl px-2 text-center text-xs leading-relaxed text-p31-muted md:text-sm">
      Below here is the technical lab — dozens of tools, probes, and experiments. Built in public. Verified in production.
    </p>

    <div
      class="pointer-events-none absolute left-1/2 top-0 -z-10 h-[min(50vh,22rem)] w-[min(100%,90rem)] -translate-x-1/2 hub-hero-aura"
      aria-hidden="true"
    >
    </div>
    <a
      href="#core-products"
      class="skip-to-content focus:pointer-events-auto interactive-zone"
    >
      Skip to lab grid
    </a>

    <!-- 1. Hero — editorial type, ethical signals, CTAs -->
    <header
      id="technical-hub-boundary"
      class="animate-fade-in-up relative z-[1] mb-16 text-center sm:mb-20 md:mb-28 md:pt-4 interactive-zone"
      style="animation-delay: 0.08s;"
    >
      <p
        class="mb-3 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-teal/80 sm:text-[11px]"
      >
        Technical hub
      </p>
      <div class="mx-auto mb-5 flex max-w-[42rem] flex-col items-center gap-4 sm:mb-6 sm:flex-row sm:items-start sm:justify-center sm:text-left">
        <div
          class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-white/[0.06] bg-surface2/50 shadow-[0_4px_20px_rgba(0,0,0,0.45)] backdrop-blur-md sm:h-[4.75rem] sm:w-[4.75rem]"
          aria-hidden="true"
        >
          <svg
            width="44"
            height="44"
            viewBox="0 0 100 100"
            fill="none"
            class="wye-delta-spin text-cyan"
          >
            <polygon
              points="50,10 90,80 10,80"
              stroke="rgba(255,255,255,0.1)"
              stroke-width="1"
              fill="rgba(37, 137, 125, 0.02)"
            />
            <path
              class="hub-wye-path"
              d="M50,50 L50,10"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-dasharray="2 4"
            />
            <path
              class="hub-wye-path"
              d="M50,50 L90,80"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-dasharray="2 4"
            />
            <path
              class="hub-wye-path"
              d="M50,50 L10,80"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-dasharray="2 4"
            />
            <circle cx="50" cy="50" r="3" fill="currentColor" class="hub-wye-node" />
            <circle cx="50" cy="10" r="2" fill="currentColor" />
            <circle cx="90" cy="80" r="2" fill="currentColor" />
            <circle cx="10" cy="80" r="2" fill="currentColor" />
          </svg>
        </div>
        <div class="min-w-0 text-center sm:text-left">
          <h1
            class="mb-4 max-w-[18ch] text-balance font-sans text-[clamp(2rem,4vw+0.85rem,3.35rem)] font-bold uppercase leading-[1.08] tracking-tight text-p31-cloud drop-shadow-[0_1px_24px_rgba(0,0,0,0.35)] sm:mb-3"
          >
            P31 Labs
          </h1>
        </div>
      </div>
      <p
        class="mx-auto mb-2 max-w-2xl font-mono text-base font-medium leading-snug tracking-tight text-p31-cloud-90 sm:text-lg md:text-xl"
      >
        Isostatically rigid. Cognitively sovereign.
      </p>
      <p
        class="mx-auto mb-8 max-w-xl text-sm leading-relaxed text-p31-muted sm:mb-10 sm:text-base"
      >
        <span class="text-p31-cloud-90">Build, create, connect</span> — family-scale mesh, verify-gated releases, and
        interfaces that respect attention.
      </p>

      <nav
        class="p31-mission-trio p31-mission-trio--hub interactive-zone mx-auto mb-8 flex max-w-2xl flex-wrap justify-center gap-2"
        aria-label={missionTrio.ariaLabel}
      >
        {missionTrio.pillOrder.map((key: 'build' | 'create' | 'connect') => {
          const pill = missionTrio.pills[key];
          return (
            <a
              href={pill.href}
              class={`p31-mission-trio__link p31-mission-trio__link--${key} inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md border border-white/10 px-4 py-2 font-mono text-xs text-p31-cloud-90 transition hover:border-teal/40 hover:text-p31-cloud`}
              title={pill.title}
            >
              {pill.label}
            </a>
          );
        })}
      </nav>

      <ul
        class="mb-10 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 font-mono text-[10px] uppercase tracking-wider text-p31-muted sm:mb-12 sm:gap-x-4 sm:text-[11px]"
        role="list"
        aria-label="Ship and ethics signals"
      >
        <li
          class="inline-flex items-center gap-2 rounded-full border border-teal/25 bg-teal/5 px-3 py-1.5 text-teal/95"
        >
          <span
            class="h-1.5 w-1.5 rounded-full bg-phosphorus shadow-[0_0_8px_rgba(59,163,114,0.5)]"
            aria-hidden="true"
          />
          Verify-gated
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-cyan/80" aria-hidden="true" />
          A11y-minded
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-butter/20 bg-butter/5 px-3 py-1.5 text-butter/95"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-butter/90" aria-hidden="true" />
          No dark patterns
        </li>
        <li
          class="inline-flex items-center gap-2 rounded-full border border-lavender/20 bg-lavender/5 px-3 py-1.5 text-lavender/90"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-lavender/80" aria-hidden="true" />
          Open core
        </li>
      </ul>

      <div
        class="flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center sm:gap-4"
      >
        <button
          id="btn-explore-dome"
          type="button"
          class="hub-cta-primary w-full min-h-[3.25rem] rounded-lg px-7 py-3.5 text-center text-base font-bold tracking-tight text-p31-cloud sm:w-auto"
          title="Sovereign Cockpit K₄ dome"
        >
          Explore Dome
        </button>
        <a
          href="#core-products"
          class="hub-cta-secondary glass-panel inline-flex w-full min-h-[3.25rem] items-center justify-center gap-2 rounded-lg border border-white/12 px-7 py-3.5 text-center text-base font-bold tracking-tight text-p31-cloud transition-all duration-300 hover:border-white/20 hover:bg-white/5 sm:w-auto"
        >
          View architecture
          <span class="text-cyan" aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    <!-- 1a. Operator shell (G.O.D.) -->
    <div class="mb-10 interactive-zone animate-fade-in-up" style="animation-delay: 0.14s;">
