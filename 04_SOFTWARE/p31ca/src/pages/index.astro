    <script is:inline>
      (function () {
        var root = document.getElementById("hub-core-grid");
        var bar = document.getElementById("hub-core-filters");
        if (!root || !bar) return;
        var cards = root.querySelectorAll("[data-product-status]");
        var buttons = bar.querySelectorAll(".hub-filter-btn");
        function apply(filter) {
          var f = (filter || "all").toLowerCase();
          cards.forEach(function (el) {
            var st = (el.getAttribute("data-product-status") || "").toLowerCase();
            var show = f === "all" || st === f;
            if (show) {
              el.classList.remove("hidden");
              el.removeAttribute("aria-hidden");
            } else {
              el.classList.add("hidden");
              el.setAttribute("aria-hidden", "true");
            }
          });
          buttons.forEach(function (btn) {
            var isAll = f === "all" && (btn.getAttribute("data-filter") || "") === "all";
            var isSt = f !== "all" && (btn.getAttribute("data-filter") || "").toLowerCase() === f;
            var active = isAll || isSt;
            btn.setAttribute("aria-pressed", active ? "true" : "false");
            if (active) {
              btn.className =
                "hub-filter-btn rounded border border-teal/50 bg-teal/10 px-4 py-2.5 text-teal transition-colors md:px-3 md:py-1.5";
            } else {
              btn.className =
                "hub-filter-btn rounded border border-white/10 px-4 py-2.5 text-p31-muted transition-colors hover:border-white/20 hover:text-p31-cloud md:px-3 md:py-1.5";
            }
          });
        }
        buttons.forEach(function (btn) {
          btn.addEventListener("click", function () {
            apply(btn.getAttribute("data-filter"));
          });
        });
      })();
    </script>

