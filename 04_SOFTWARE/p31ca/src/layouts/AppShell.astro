---
/**
 * AppShell.astro — Production AppShell layout.
 *
 * One persistent WebGL2 canvas survives all ClientRouter navigations via
 * `transition:persist`. `starfield-singleton.ts` owns the GL context and
 * lerps camera Z, hue, particle count, and speed per route (~600ms half-life).
 *
 * PHOS bus bar load order MUST NOT change — see BaseLayout / CWP-PHOS-2026-01.
 * Garden isolation: `routeName="garden"` strips molecular field + EBC footer.
 */
import { ClientRouter } from 'astro:transitions';
import type { RouteId } from '../lib/starfield-singleton';
import { PHOS_FAMILIAR_SVG } from '../lib/phos-assets';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  routeName: RouteId;
  phosPage?: string;
  suppressEbc?: boolean;
  preserveSW?: boolean;
}

const {
  title = 'P31 Labs',
  description = 'P31 Labs — Isostatically Rigid. Cognitively Sovereign.',
  routeName,
  phosPage,
  suppressEbc = false,
  preserveSW = false,
} = Astro.props;

const isGarden = routeName === 'garden';
---

<!doctype html>
<html
  lang="en"
  class="dark"
  data-p31-appearance="hub"
  data-p31-route={routeName}
  style="color-scheme: dark;"
>
  <head>
    <!-- Unregister stale service workers from old hearing-ops deployment (skipped on routes with own SW) -->
    {!preserveSW && (
      <script is:inline>
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.getRegistrations().then(function (regs) {
            regs.forEach(function (reg) { reg.unregister(); });
          });
          if (navigator.serviceWorker.controller) window.location.reload(true);
        }
      </script>
    )}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/p31-style.css" />
    <link rel="stylesheet" href="/lib/p31-qmu-tokens.css" />
    {!isGarden && <link rel="stylesheet" href="/lib/p31-molecular-field.css" />}

    <!-- Fonts: Atkinson (UI) + JetBrains Mono (data/code) — EDE canon -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=JetBrains+Mono:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <ClientRouter />

    <!--
      PHOS bus bar (CWP-PHOS-2026-01 §4) — load order is load-bearing.
      1. p31-subject-prefs.js  — sync before-paint accessibility axes
      2. p31-theme-engine.mjs  — defines window.p31Theme
      3. p31-cogpass-reader.mjs — configures prefs + theme from stored cogpass
      4. p31-phos-guide.mjs    — pre-empts window.p31ThemeSwitcher before 100ms
      5. p31-theme-switcher.mjs — sees slot taken, self-suppresses cleanly
    -->
    <script is:inline src="/lib/p31-subject-prefs.js"></script>
    <script type="module" src="/lib/p31-theme-engine.mjs"></script>
    <script type="module" src="/lib/p31-cogpass-reader.mjs"></script>
    <script type="module" src="/lib/p31-phos-guide.mjs"></script>
    <script type="module" src="/lib/p31-theme-switcher.mjs"></script>

    <slot name="head" />

    <style is:global>
      /*
       * Persistent canvas — fixed full-viewport, z=0, never captures pointer events.
       * `view-transition-name: none` opts it out of the View Transitions snapshot so
       * the browser does not rasterise the canvas to a ghost image on navigation,
       * which on SwiftShader (headless Chromium) reliably triggers WebGL context loss.
       */
      canvas[data-p31-appshell-canvas] {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        display: block;
        z-index: 0;
        pointer-events: none;
        view-transition-name: none;
      }
      /* Slot content sits above the canvas. */
      .p31-shell-content {
        position: relative;
        z-index: 1;
      }
    </style>
  </head>

  <body
    class="bg-p31-void min-h-screen text-base leading-relaxed text-p31-cloud font-sans antialiased p31-root [padding-bottom:env(safe-area-inset-bottom,0px)]"
    data-p31-phos-page={phosPage}
  >
    <!-- Ambient radial backdrop -->
    <div class="ambient-radial-fixed" aria-hidden="true"></div>

    <!--
      THE PERSISTENT CANVAS.
      transition:persist keeps this exact DOM node across every ClientRouter navigation.
      canvasAttachCount in window.__p31AppShell must stay at 1 — if it grows, the
      transition:persist contract broke and the architecture needs investigation.
    -->
    <canvas
      data-p31-appshell-canvas
      transition:persist="appshell-canvas"
      aria-hidden="true"
    ></canvas>

    <!-- Top nav — suppressed on garden for isolation -->
    {!isGarden && (
      <nav id="p31-bottom-ribbon" class="nav">
        <div class="nav-inner">
          <a href="/" class="nav-brand" title="P31 Labs hub">
            <span class="nav-mark" aria-hidden="true" style="display:inline-flex;width:28px;height:20px;align-items:center;image-rendering:pixelated;">
              <Fragment set:html={PHOS_FAMILIAR_SVG} />
            </span>
            <span class="nav-brand-label">P31 Labs</span>
          </a>
          <div class="nav-links">
            <span class="nav-prompt" aria-hidden="true">..</span>
            <a href="/"         class="nav-link" aria-current={routeName === 'home'     ? 'page' : undefined}>Hub</a>
            <a href="/dome"     class="nav-link" aria-current={routeName === 'dome'     ? 'page' : undefined}>Dome</a>
            <a href="/research" class="nav-link" aria-current={routeName === 'research' ? 'page' : undefined}>Research</a>
            <a href="/ops"      class="nav-link" aria-current={routeName === 'ops'      ? 'page' : undefined}>Ops</a>
            <a href="/connect"  class="nav-link" aria-current={routeName === 'connect'  ? 'page' : undefined}>Mesh</a>
            <a href="https://github.com/p31labs/andromeda" target="_blank" rel="noopener" class="nav-link" aria-label="GitHub">GH↗</a>
          </div>
        </div>
      </nav>
    )}

    <!-- Page content -->
    <div class="p31-shell-content">
      <slot />
    </div>

    <!-- EBC footer: Build · Create · Connect — suppressed on garden or when suppressEbc is set -->
    {!isGarden && !suppressEbc && (
      <footer
        id="ebc"
        class="p31-mission-trio p31-mission-trio--ebc"
        role="contentinfo"
        aria-label="Mission — build, create, connect"
      >
        <a
          class="p31-mission-trio__link p31-mission-trio__link--build p31-mesh-tap"
          id="ebc-build"
          href="/build"
          title="Initial Build — intake, subject scope, verify-gated bake"
        >
          <span class="p31-mission-trio__head">
            <span class="p31-mission-trio__dot" aria-hidden="true"></span>
            <span class="p31-mission-trio__verb">Build</span>
          </span>
          <span class="p31-mission-trio__desc">
            Intake and bake on the same verify chain—not a decoupled mock.
          </span>
        </a>
        <a
          class="p31-mission-trio__link p31-mission-trio__link--create p31-mesh-tap"
          id="ebc-create"
          href="/geodesic.html"
          title="GEODESIC — snap grid, Maxwell rigidity, scene export"
        >
          <span class="p31-mission-trio__head">
            <span class="p31-mission-trio__dot" aria-hidden="true"></span>
            <span class="p31-mission-trio__verb">Create</span>
          </span>
          <span class="p31-mission-trio__desc">
            One lab surface, honest rigidity—generate or prove; don't fork the same truth twice.
          </span>
        </a>
        <a
          class="p31-mission-trio__link p31-mission-trio__link--connect p31-mesh-tap"
          id="ebc-connect"
          href="/mesh"
          title="Mesh navigator — K₄ cage and product graph"
        >
          <span class="p31-mission-trio__head">
            <span class="p31-mission-trio__dot" aria-hidden="true"></span>
            <span class="p31-mission-trio__verb">Connect</span>
          </span>
          <span class="p31-mission-trio__desc">
            <span class="p31-mission-trio__now">Now</span> — live cage and edges: mesh, hubs,
            and money follow the same published contracts (ethical monetization).
          </span>
        </a>
      </footer>
    )}

    <!-- Quantum grandfather boot -->
    <script type="module" is:inline>
      import { startGrandfatherPhaseVar } from "/lib/p31-quantum-grandfather-boot.mjs";
      startGrandfatherPhaseVar();
    </script>

    <!-- Return ribbon -->
    <script src="/lib/p31-return-ribbon.js" defer></script>

    <!-- Molecular field — suppressed on garden -->
    {!isGarden && <script type="module" src="/lib/p31-molecular-field.js"></script>}

    <!-- Starfield singleton + fleet telemetry (both survive SPA navigations) -->
    <script>
      import type { RouteId } from '../lib/starfield-singleton';
      import { startStarfield, setStarfieldRoute, suspendStarfield, resumeStarfield } from '../lib/starfield-singleton';
      import { startFleetTelemetry } from '../lib/fleet-telemetry';

      const canvas = document.querySelector<HTMLCanvasElement>('canvas[data-p31-appshell-canvas]');
      if (canvas) {
        startStarfield(canvas);
        const route = document.documentElement.getAttribute('data-p31-route') as RouteId | null;
        if (route) setStarfieldRoute(route);
        if (route === 'dome') suspendStarfield();
      }

      /* Re-wire route on every ClientRouter navigation.
       * The canvas DOM node is the same instance (transition:persist), but
       * data-p31-route on <html> reflects the new page's routeName prop.
       * Dome page: suspend the starfield entirely — the Three.js dome overlays it at z=20
       * and the starfield canvas at z=0 just burns GPU for nothing. Resume on any other route. */
      document.addEventListener('astro:after-swap', () => {
        const newRoute = document.documentElement.getAttribute('data-p31-route') as RouteId | null;
        if (newRoute) setStarfieldRoute(newRoute);
        if (newRoute === 'dome') {
          suspendStarfield();
        } else {
          resumeStarfield();
        }
      });

      /* Fleet telemetry — start once per session. Survives SPA navigations.
       * Garden route is intentionally isolated (telemetry suppressed for low-stim).
       * Exposed on window.__p31Fleet for console inspection:
       *   window.__p31Fleet.snapshot()  → Map<id, { status, latencyMs, lastChecked }>
       *   window.__p31Fleet.stop()      → graceful teardown */
      const W = window as Record<string, unknown>;
      if (!W['__p31Fleet']) {
        const currentRoute = document.documentElement.getAttribute('data-p31-route');
        if (currentRoute !== 'garden') {
          const handle = startFleetTelemetry();
          W['__p31Fleet'] = handle;

          /* Pause telemetry when navigating to/from garden (low-stim isolation). */
          document.addEventListener('astro:after-swap', () => {
            const route = document.documentElement.getAttribute('data-p31-route');
            const stored = W['__p31Fleet'] as typeof handle | null;
            if (route === 'garden' && stored) {
              stored.stop();
              W['__p31Fleet'] = null;
            } else if (route !== 'garden' && !W['__p31Fleet']) {
              W['__p31Fleet'] = startFleetTelemetry();
            }
          });
        }
      }
    </script>
  </body>
</html>
