# Cloudflare Pages Headers
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Clear-Site-Data: "cache", "storage", "executionContexts"
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://unpkg.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https: wss: blob: data:; worker-src 'self' blob:; frame-ancestors 'none';

# Disable directory listing
/indexes/
  X-Robots-Tag: noindex, nofollow

# Static assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
