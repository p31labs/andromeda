{
  "schema": "p31.universalCanon/1.0.0",
  "version": "1.0.0",
  "title": "P31 universal design canon — shared tokens, ring-local appearance",
  "description": "Single source for typography, spacing, motion, and brand palette. Ring A (p31ca hub) defaults to appearance \"hub\" (dark). Ring D (phosphorus31.org) uses appearance \"org\" (light) via data-p31-appearance on <html> — same brand colors, inverted surfaces so it feels related but not identical. BONDING (bonding.p31ca.org) stays out of this file by operator policy.",
  "rings": {
    "hub": {
      "hosts": ["p31ca.org", "www.p31ca.org", "*.p31ca.pages.dev"],
      "defaultAppearance": "hub",
      "notes": "Technical hub, static tools, Astro + Tailwind CDN pages."
    },
    "org": {
      "hosts": ["phosphorus31.org", "www.phosphorus31.org", "api.phosphorus31.org"],
      "defaultAppearance": "org",
      "notes": "Public org narrative + MAP surfaces. Opt in with data-p31-appearance=\"org\" (or server-render default)."
    }
  },
  "palette": {
    "comment": "Brand anchors — appearances should keep these identical for cross-ring recognition.",
    "coral": "#cc6247",
    "teal": "#25897d",
    "cyan": "#4db8a8",
    "butter": "#cda852",
    "lavender": "#8b7cc9",
    "phosphorus": "#3ba372",
    "phosphor": "#00FF88"
  },
  "typography": {
    "fontFamilies": {
      "sans": ["Atkinson Hyperlegible", "sans-serif"],
      "mono": ["JetBrains Mono", "monospace"]
    },
    "scaleRem": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "md": "1.0625rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "lineHeight": {
      "tight": "1.25",
      "snug": "1.4",
      "normal": "1.6",
      "relaxed": "1.75"
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.08em",
      "caps": "0.12em"
    }
  },
  "space": {
    "px": "1px",
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "radius": {
    "none": "0",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "1.25rem",
    "full": "9999px"
  },
  "shadow": {
    "none": "none",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.06)",
    "md": "0 4px 14px rgba(0, 0, 0, 0.08)",
    "lg": "0 12px 40px rgba(0, 0, 0, 0.12)",
    "glowTeal": "0 0 24px rgba(37, 137, 125, 0.25)"
  },
  "motion": {
    "durationMs": {
      "instant": "100",
      "fast": "150",
      "normal": "250",
      "slow": "400",
      "glacial": "800"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
  "zIndex": {
    "base": "0",
    "dropdown": "50",
    "sticky": "100",
    "overlay": "200",
    "modal": "300",
    "toast": "400"
  },
  "focus": {
    "ringWidth": "2px",
    "ringOffset": "2px",
    "hubRingColor": "rgba(77, 184, 168, 0.55)",
    "orgRingColor": "rgba(37, 137, 125, 0.45)"
  },
  "appearances": {
    "hub": {
      "colorScheme": "dark",
      "themeColor": "#0f1115",
      "colors": {
        "void": "#0f1115",
        "surface": "#161920",
        "surface2": "#1c2028",
        "coral": "#cc6247",
        "teal": "#25897d",
        "cyan": "#4db8a8",
        "cloud": "#d8d6d0",
        "butter": "#cda852",
        "lavender": "#8b7cc9",
        "phosphorus": "#3ba372",
        "paper": "#f4f4f5",
        "ink": "#1e293b",
        "muted": "#6b7280",
        "phosphor": "#00FF88"
      },
      "semantic": {
        "borderSubtle": "rgba(255, 255, 255, 0.06)"
      },
      "glass": {
        "border": "rgba(255, 255, 255, 0.08)",
        "surface": "rgba(255, 255, 255, 0.04)"
      }
    },
    "org": {
      "colorScheme": "light",
      "themeColor": "#f5f4f0",
      "comment": "Light, warm paper field; ink-forward text. Brand hues MUST match palette.* — only neutrals (void/surface/cloud/ink/muted/paper) differ from hub.",
      "colors": {
        "void": "#f5f4f0",
        "surface": "#ffffff",
        "surface2": "#ebeae4",
        "coral": "#cc6247",
        "teal": "#25897d",
        "cyan": "#4db8a8",
        "cloud": "#1e293b",
        "butter": "#cda852",
        "lavender": "#8b7cc9",
        "phosphorus": "#3ba372",
        "paper": "#fdfcfa",
        "ink": "#0f172a",
        "muted": "#64748b",
        "phosphor": "#00FF88"
      },
      "semantic": {
        "borderSubtle": "rgba(15, 23, 42, 0.09)"
      },
      "glass": {
        "border": "rgba(15, 23, 42, 0.07)",
        "surface": "rgba(255, 255, 255, 0.82)"
      }
    }
  }
}
