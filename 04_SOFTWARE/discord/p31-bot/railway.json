{
  "$schema": "https://railway.app/schema.json",
  "name": "discord-bot",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx tsc --project tsconfig.json",
    "startCommand": "node dist/index.js"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}