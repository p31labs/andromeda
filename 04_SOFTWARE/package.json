{
  "name": "p31-software",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "bonding",
    "spaceship-earth",
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "manifest:workers": "node scripts/generate-worker-manifest.mjs",
    "turbo": "turbo",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "vitest": "^4.1.2"
  }
}
