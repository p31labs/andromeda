# P31 Spaceship Earth — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Relay ────────────────────────────────────────────────────────────────
# WebSocket URL for the sovereign relay (Cloudflare Worker).
# Omit or leave empty to run fully offline (relay features are no-ops).
# Live relay: wss://bonding-relay.trimtab-signal.workers.dev
VITE_RELAY_URL=

# ── Centaur Engine (optional) ─────────────────────────────────────────────
# LLM API key for the Centaur Brain overlay.
# Can also be set at runtime via the Dev Menu (stored in localStorage only).
# VITE_LLM_KEY=

# ── Dev tools ─────────────────────────────────────────────────────────────
# Enable stats.js FPS overlay: add ?stats=1 to the dev server URL.
# No env var needed — controlled by URL param (never ships in prod build).
