# P31 Spaceship Earth — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Relay ────────────────────────────────────────────────────────────────
# WebSocket URL for the sovereign relay (Cloudflare Worker).
# Omit or leave empty to run fully offline (relay features are no-ops).
# Live relay: wss://bonding-relay.trimtab-signal.workers.dev
VITE_RELAY_URL=

# ── Centaur Engine (optional) ─────────────────────────────────────────────
# LLM API key for the Centaur Brain overlay.
# Can also be set at runtime via the Dev Menu (stored in localStorage only).
# VITE_LLM_KEY=

# ── Dev tools ─────────────────────────────────────────────────────────────
# Enable stats.js FPS overlay: add ?stats=1 to the dev server URL.
# No env var needed — controlled by URL param (never ships in prod build).

# --- Auto-synced from .env.canonical CONSTANTS ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
IMAP_PORT=993
BOT_PREFIX=p31
ENABLE_FAWN_DETECTION=true
MAX_SPOON_DISPLAY=12
NODE_ONE_WEBHOOK_PORT=3000
RESPONSE_TIMEOUT_MS=5000
TURBO_TEAM=p31labs
HCB_ORG_SLUG=p31-labs
GITHUB_REPO=p31labs/andromeda
NODE_ENV=production
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
CORS_ORIGIN=https://p31ca.org
BONDING_API_URL=https://bonding.p31ca.org/api
SPOON_API_URL=https://phosphorus31.org/api/spoons
