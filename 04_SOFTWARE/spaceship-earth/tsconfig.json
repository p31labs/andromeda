{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "@webgpu/types", "@types/web-bluetooth"],
    "lib": ["DOM", "ES2020"],
    "paths": {
      "@p31/shared": ["../packages/shared/src"],
      "@p31/shared/*": ["../packages/shared/src/*"],
      "@p31/node-zero": ["../packages/node-zero/src"],
      "@p31/node-zero/*": ["../packages/node-zero/src/*"],
      "@p31/love-ledger": ["../packages/love-ledger/src"],
      "@p31/love-ledger/*": ["../packages/love-ledger/src/*"],
      "@p31/game-engine": ["../packages/game-engine/src"],
      "@p31/game-engine/*": ["../packages/game-engine/src/*"],
      "@p31/sovereign": ["../packages/sovereign/src"],
      "@p31/sovereign/*": ["../packages/sovereign/src/*"]
    }
  },
  "include": ["src", "src/types/**/*.d.ts"],
  "exclude": ["src/services/webgpu/**/*"]
}
