{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@p31/shared": ["../packages/shared/src"],
      "@p31/shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
