---
export interface Props { status?: string }
const { status } = Astro.props
---
<style>
  header { padding: 12px 16px; font-family: var(--font-display); font-size: 1.25rem; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--neon-ghost); }
  nav a { margin: 0 8px; color: var(--cyan); text-decoration: none; }
  main { padding: 20px; font-family: var(--font-body); }
  .status { padding: 6px 12px; font-size: 12px; background: rgba(0,255,136,.08); border: 1px solid rgba(0,255,136,.3); border-radius: 6px; display:inline-block; }
</style>
<header>
  <div>GO-KC Navigator</div>
  <nav>
    <a href="/start">Start</a>
    <a href="/learn">Learn</a>
    <a href="/rights">Rights</a>
    <a href="/recognize">Recognize</a>
  </nav>
</header>
<section style="padding:8px 16px; display:flex; justify-content:flex-end;">
  <span class="status" aria-label="go-kc-status">GO-KC: {status ?? 'Active'}</span>
</section>
<main>
  <slot />
</main>
<footer style="text-align:center; padding:16px; color:var(--dim)"></footer>
