{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "WebWorker"],
    "types": ["@cloudflare/workers-types", "vitest/importMeta"]
  },
  "include": ["src/**/*", "test/**/*"]
}