{
  "name": "@p31/k4-mesh-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared K4 mesh logic, vertex types, edge interfaces, and pure functions for k4-cage and k4-personal",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vertices": "./src/vertices/index.ts",
    "./edges": "./src/edges/index.ts",
    "./logic": "./src/logic/index.ts",
    "./types": "./src/types/index.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}