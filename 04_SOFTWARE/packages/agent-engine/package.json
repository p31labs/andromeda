{
  "name": "@p31/agent-engine",
  "version": "0.1.0-alpha.0",
  "description": "Core engine for creating and managing personalized AI agents in the P31 ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./personality": {
      "types": "./dist/personality.d.ts",
      "import": "./dist/personality.js"
    },
    "./skills": {
      "types": "./dist/skills.d.ts",
      "import": "./dist/skills.js"
    },
    "./deployment": {
      "types": "./dist/deployment.d.ts",
      "import": "./dist/deployment.js"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "p31",
    "ai-agent",
    "personality-engine",
    "skill-tree",
    "multi-platform",
    "discord-bot",
    "agent-creator"
  ],
  "author": "P31 Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/p31labs/agent-engine"
  },
  "homepage": "https://github.com/p31labs/agent-engine#readme",
  "bugs": {
    "url": "https://github.com/p31labs/agent-engine/issues"
  },
  "sideEffects": false,
  "dependencies": {
    "@p31/shared": "workspace:*",
    "uuid": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "vite": "^8.0.1"
  }
}