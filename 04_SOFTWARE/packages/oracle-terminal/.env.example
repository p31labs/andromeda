# P31 Oracle Terminal Environment Configuration
# Copy this file to .env and fill in your actual values

# === Server Configuration ===
PORT=3001
NODE_ENV=development

# === Redis Configuration (Upstash) ===
UPSTASH_REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_TOKEN=your-redis-token-here

# === Upstash Vector Configuration ===
UPSTASH_VECTOR_REST_URL=https://your-vector-db.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your-vector-token-here

# === Ollama Configuration ===
OLLAMA_BASE_URL=http://localhost:11434/api
CHAT_MODEL=phi3
EMBEDDING_MODEL=nomic-embed-text

# === CORS Configuration ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# === Security Configuration ===
JWT_SECRET=your-jwt-secret-key-here
API_KEY=your-api-key-here

# === Logging Configuration ===
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# === Medical Device Compliance ===
# These settings ensure compliance with 21 CFR §890.3710
CLINICAL_SAFETY_MODE=true
DAILY_SPOON_LIMIT=5
DAILY_SEARCH_LIMIT=20
IDEMPOTENCY_LOCK_TIMEOUT=300
COGNITIVE_REST_PERIOD=86400

# === IPFS Configuration ===
IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API_ENDPOINT=http://localhost:5001/api/v0

# === Discord Integration ===
DISCORD_WEBHOOK_URL=your-discord-webhook-url
DISCORD_BOT_TOKEN=your-discord-bot-token

# === Monitoring & Analytics ===
ENABLE_METRICS=true
METRICS_ENDPOINT=/metrics
HEALTH_CHECK_ENDPOINT=/health

# === Development & Testing ===
ENABLE_DEBUG_MODE=false
ENABLE_TEST_ENDPOINTS=false
MOCK_AI_RESPONSES=false