# Copy to .env and fill in values before running deploy.sh
# NEVER commit .env

# Matrix identity — determines @will:p31ca.org format
SYNAPSE_SERVER_NAME=p31ca.org
DOMAIN=matrix.p31ca.org

# TLS email for Let's Encrypt
LETSENCRYPT_EMAIL=will@p31ca.org

# Postgres (generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=REPLACE_generate_with_openssl_rand_hex_32
POSTGRES_DB=synapse
POSTGRES_USER=synapse

# Synapse signing key (auto-generated on first run — back this up)
# After first deploy: cat data/synapse/homeserver.signing.key

# Backblaze B2 backup credentials
B2_APPLICATION_KEY_ID=REPLACE_from_backblaze_dashboard
B2_APPLICATION_KEY=REPLACE_from_backblaze_dashboard
B2_BUCKET=p31-matrix-backup

# Bridge shared secrets (generate each with: openssl rand -hex 32)
BRIDGE_GMESSAGES_AS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_GMESSAGES_HS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_WHATSAPP_AS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_WHATSAPP_HS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_SIGNAL_AS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_SIGNAL_HS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_META_AS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
BRIDGE_META_HS_TOKEN=REPLACE_generate_with_openssl_rand_hex_32
