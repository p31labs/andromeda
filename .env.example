# P31 LABS — Environment Configuration
# Copy to .env and fill in values. Rotate secrets every 24h.
# Last updated: 2026-04-24

# ── Cloudflare API ──
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=

# ── Status / Command Center ──
STATUS_TOKEN=
COMMAND_CENTER_KV_ID=
DEPLOY_WEBHOOK_SECRET=

# ── OAuth / Identity ──
CF_TEAM_DOMAIN=trimtab-signal
CF_ACCESS_AUDIENCE=

# ── External Services ──
GENESIS_GATE_URL=https://genesis-gate.trimtab-signal.workers.dev
FORGE_API_KEY=
DISCORD_WEBHOOK_URL=
STRIPE_WEBHOOK_SECRET=

# ── Database ──
D1_DATABASE_ID=

# ── Secrets Management (24-hour rotation policy) ──
# Rotate all *_KEY and *_SECRET values every 24 hours.
# Use Vault (https://vault.trimtab-signal.workers.dev) for production secret storage.
ENCRYPTION_KEY=
SECRET_ROTATION_INTERVAL=24h
KV_NAMESPACE_ID=
VAULT_ADDR=https://vault.trimtab-signal.workers.dev

# ── Entity ──
P31_EIN=42-1888158
MERCURY_ACCOUNT_ID=

# ── Feature Flags ──
ENABLE_GUARDRAILS=true
ENABLE_SSO=true
ENABLE_AUDIT_LOG=true

# ── Telemetry ──
TELEMETRY_QFACTOR_THRESHOLD=0.3
SPOON_COUNT_THRESHOLD=3
