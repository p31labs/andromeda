# P31 Social Content Engine - Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# TWITTER/X Developer Portal Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Callback URL: https://p31ca.org/oauth/callback
# Website URL: https://p31ca.org

# ═══════════════════════════════════════════════════════════════════════════════
# MASTODON
# ═══════════════════════════════════════════════════════════════════════════════
MASTODON_ACCESS_TOKEN=
MASTODON_API_URL=https://mastodon.social/api/v1/

# ═══════════════════════════════════════════════════════════════════════════════
# BLUESKY
# ═══════════════════════════════════════════════════════════════════════════════
BLUESKY_IDENTIFIER=
BLUESKY_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# TWITTER/X
# ═══════════════════════════════════════════════════════════════════════════════
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
# DISCORD
# ═══════════════════════════════════════════════════════════════════════════════
DISCORD_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# BONDING RELAY (Cross-post)
# ═══════════════════════════════════════════════════════════════════════════════
BONDING_WEBHOOK_URL=https://webhook.p31ca.org/webhook/bonding

# ═══════════════════════════════════════════════════════════════════════════════
# SCE CONFIG
# ═══════════════════════════════════════════════════════════════════════════════
DATABASE_PATH=./data/sce.db
DEFAULT_PLATFORMS=discord,mastodon,bluesky,twitter
SCE_BASE_URL=https://p31ca.org
