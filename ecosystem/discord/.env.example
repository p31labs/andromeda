# P31 Oracle Discord Bot Configuration
# Copy this file to .env and fill in your actual credentials

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
DISCORD_GUILD_ID=your_discord_server_guild_id_here

# Redis Configuration (Upstash)
UPSTASH_REDIS_URL=your_upstash_redis_url_here
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# IPFS Configuration
IPFS_GATEWAY=https://ipfs.io
ENS_DOMAIN=andromeda.p31.eth

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username_here
GITHUB_REPO_NAME=your_repository_name_here

# Zenodo Configuration
ZENODO_API_TOKEN=your_zenodo_api_token_here
ZENODO_SANDBOX=false

# Ko-fi Configuration
KOFI_WEBHOOK_SECRET=your_kofi_webhook_secret_here
KOFI_API_TOKEN=your_kofi_api_token_here

# Environment
NODE_ENV=production

# Logging
LOG_LEVEL=info
# --- Auto-synced from .env.canonical CONSTANTS ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
IMAP_PORT=993
BOT_PREFIX=p31
ENABLE_FAWN_DETECTION=true
MAX_SPOON_DISPLAY=12
NODE_ONE_WEBHOOK_PORT=3000
RESPONSE_TIMEOUT_MS=5000
TURBO_TEAM=p31labs
HCB_ORG_SLUG=p31-labs
GITHUB_REPO=p31labs/andromeda
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
CORS_ORIGIN=https://p31ca.org
BONDING_API_URL=https://bonding.p31ca.org/api
SPOON_API_URL=https://phosphorus31.org/api/spoons
