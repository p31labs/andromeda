# Copy to a local, gitignored file (e.g. .dev.vars) — never commit.
# Google Cloud / Workspace OAuth (web or worker client)

# OAuth 2.0 "Desktop" or "Web application" client (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# If using web flow with fixed redirect, e.g. https://p31-integrations.p31ca.org/oauth/callback
GOOGLE_REDIRECT_URI=

# Optional: path to service account JSON (local only) — prefer Workload Identity / secret manager in production
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Workspace admin subject for domain-wide delegation (if using a service account with impersonation)
# GOOGLE_WORKSPACE_ADMIN=admin@p31ca.org
