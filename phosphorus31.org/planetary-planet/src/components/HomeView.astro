---
---

<main class="animate-[fadeIn_0.4s_ease-out]">
  {/* HERO SECTION */}
  <section class="relative max-w-7xl mx-auto px-6 py-20 md:py-32 flex flex-col-reverse md:flex-row items-center gap-16">
    <div class="flex-1 space-y-8 z-10">
      <div class="inline-block bg-lavender/40 text-espresso font-bold text-xs px-4 py-1.5 rounded-full border border-lavender">
        Evidence-Based Assistive Technology
      </div>
      <h1 class="text-5xl md:text-7xl font-heading font-black leading-[1.1] text-espresso">
        Technology that moves at the <span class="text-teal-600">speed of your child's brain.</span>
      </h1>
      <p class="text-lg md:text-xl text-espresso/70 max-w-xl">
        <strong class="text-teal-600">Bottom Line Up Front:</strong> We build free, open-source tools for neurodivergent families to manage energy, facilitate co-parenting, and foster connection without sensory overload.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <a href="/products" class="bg-coral-500 hover:bg-coral-600 text-white font-bold text-lg py-4 px-8 rounded-2xl shadow-lg transition-transform hover:-translate-y-1 text-center no-underline">
          Find Tools for My Family
        </a>
        <a href="https://discord.gg/uYW5rTCuZ" target="_blank" rel="noopener noreferrer" class="bg-white hover:bg-cloud text-espresso font-bold text-lg py-4 px-8 rounded-2xl border-2 border-espresso/10 transition-colors text-center no-underline">
          Join Discord
        </a>
      </div>
    </div>

    {/* Organic Illustration */}
    <div class="flex-1 relative w-full h-[400px] flex items-center justify-center">
      <div class="absolute w-[80%] h-[80%] bg-teal-600/20 organic-blob mix-blend-multiply"></div>
      <div class="absolute w-[70%] h-[70%] bg-butter/30 organic-blob mix-blend-multiply" style="animation-delay: -2s"></div>
      <div class="absolute w-[60%] h-[60%] bg-coral-500/20 organic-blob mix-blend-multiply" style="animation-delay: -4s"></div>

      <div class="relative z-10 glass-box p-8 rounded-3xl shadow-xl border border-white/40 transform rotate-[-3deg] max-w-sm">
        <div class="w-16 h-16 bg-gradient-to-br from-teal-600 via-coral-500 to-butter rounded-full mx-auto mb-6 relative overflow-hidden">
          <div class="w-4 h-4 bg-cloud rounded-full absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 shadow-inner"></div>
          <div class="absolute inset-0 border-2 border-teal-600/60 rounded-full animate-orbit-slow"></div>
          <div class="absolute inset-1 border-2 border-coral-500/60 rounded-full animate-orbit-fast" style="animation-delay: 0.5s"></div>
          <div class="absolute inset-2 border-2 border-butter/60 rounded-full animate-orbit-medium" style="animation-delay: 1s"></div>
          <div class="absolute top-0 left-1/2 w-3 h-3 bg-teal-600 rounded-full transform -translate-x-1/2 -translate-y-1/2 animate-orbit-slow"></div>
          <div class="absolute bottom-0 right-1/2 w-3 h-3 bg-coral-500 rounded-full transform translate-x-1/2 translate-y-1/2 animate-orbit-fast" style="animation-delay: 0.5s"></div>
          <div class="absolute left-0 top-1/2 w-3 h-3 bg-butter rounded-full transform -translate-x-1/2 -translate-y-1/2 animate-orbit-medium" style="animation-delay: 1s"></div>
        </div>
        <h3 class="font-heading font-bold text-xl text-center mb-2">BONDING App</h3>
        <p class="text-sm text-espresso/70 text-center mb-4">Build molecules with your kids across the country in real-time.</p>
        <div class="h-3 w-full bg-cloud rounded-full overflow-hidden">
          <div class="h-full bg-coral-500 w-3/4"></div>
        </div>
      </div>
    </div>
  </section>

  {/* METRICS BAR */}
  <section class="bg-teal-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 divide-x divide-teal-700/50">
      <div class="text-center">
        <div class="text-4xl font-black font-heading text-butter mb-2">659+</div>
        <div class="text-sm font-medium text-cloud/80 uppercase tracking-widest">Passing Tests</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-black font-heading text-lavender mb-2">100%</div>
        <div class="text-sm font-medium text-cloud/80 uppercase tracking-widest">Open Source</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-black font-heading text-coral-500 mb-2">12+</div>
        <div class="text-sm font-medium text-cloud/80 uppercase tracking-widest">Live Products</div>
      </div>
      <div class="text-center">
        <div class="text-4xl font-black font-heading text-teal-500 mb-2">$0</div>
        <div class="text-sm font-medium text-cloud/80 uppercase tracking-widest">Cost to Families</div>
      </div>
    </div>
  </section>

  {/* FAMILY NEEDS GRID */}
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-black text-espresso mb-4">What does your family need today?</h2>
      <p class="text-lg text-espresso/60 max-w-2xl mx-auto">We organize our tools by the actual challenges neurodivergent families face, not by clinical terminology.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a href="https://bonding.p31ca.org" target="_blank" rel="noopener noreferrer" class="glass-box p-8 rounded-3xl border-t-4 border-t-teal-600 hover:shadow-xl transition-shadow cursor-pointer group no-underline block">
        <div class="w-14 h-14 bg-teal-600/10 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">&#x269B;&#xFE0F;</div>
        <h3 class="font-heading font-bold text-2xl mb-3 text-espresso">Remote Connection</h3>
        <p class="text-espresso/70 mb-6 text-sm">Tools for co-parents and families separated by distance. Build meaningful memories when you can't be in the same room.</p>
        <div class="text-teal-600 font-bold flex items-center gap-2">Launch BONDING <span class="text-xl">&#x2192;</span></div>
      </a>

      <a href="https://p31ca.org/ede-about.html" target="_blank" rel="noopener noreferrer" class="glass-box p-8 rounded-3xl border-t-4 border-t-coral-500 hover:shadow-xl transition-shadow cursor-pointer group no-underline block">
        <div class="w-14 h-14 bg-coral-500/10 rounded-2xl flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform">&#x2B21;</div>
        <h3 class="font-heading font-bold text-2xl mb-3 text-espresso">Cognitive Prosthetics</h3>
        <p class="text-espresso/70 mb-6 text-sm">The EDE: a browser-native IDE with Jitterbug Compiler, spoon tracking, Samson's Law entropy linter, and 4-tier progressive disclosure. Zero npm. Works offline.</p>
        <div class="text-coral-500 font-bold flex items-center gap-2">Explore EDE <span class="text-xl">&#x2192;</span></div>
      </a>

      <div class="glass-box p-8 rounded-3xl border-t-4 border-t-butter hover:shadow-xl transition-shadow cursor-pointer group">
        <div class="w-14 h-14 bg-butter/20 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">&#x1F6E1;&#xFE0F;</div>
        <h3 class="font-heading font-bold text-2xl mb-3 text-espresso">Communication Shields</h3>
        <p class="text-espresso/70 mb-6 text-sm">AI-powered tools that strip emotional hostility from high-conflict emails and texts. The Fawn Guard Buffer detects passive-aggression, scores voltage, activates protective protocols.</p>
        <div class="text-yellow-600 font-bold flex items-center gap-2">See The Buffer <span class="text-xl">&#x2192;</span></div>
      </div>
    </div>
  </section>

  {/* RESEARCH / ZENODO DOIs */}
  <section class="bg-gradient-to-br from-teal-900 via-espresso to-teal-900 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="inline-block bg-cyan-500/20 text-cyan-400 font-bold text-sm px-4 py-1.5 rounded-full border border-cyan-500/30 mb-4">
          Peer-Reviewed Publications
        </div>
        <h2 class="text-3xl md:text-4xl font-heading font-black text-white mb-4">Published Research</h2>
        <p class="text-white/60 max-w-2xl mx-auto">
          Mathematical frameworks grounding the P31 ecosystem. Both publications open-access on Zenodo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-cyan-400/30 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-cyan-500 text-espresso text-xs font-bold px-3 py-1 rounded-full">DOI</span>
            <span class="text-white/40 text-xs font-mono">10.5281/zenodo.18627420</span>
          </div>
          <h3 class="text-xl font-heading font-bold text-white mb-3">Tetrahedron Protocol (K4)</h3>
          <p class="text-white/60 text-sm mb-4 leading-relaxed">
            Geometric proof that decentralized K4 topology is inherently more stable than centralized systems. 280+ views, 240+ downloads. Includes open-source implementation.
          </p>
          <a href="https://doi.org/10.5281/zenodo.18627420" target="_blank" rel="noopener noreferrer" class="text-cyan-400 text-sm font-bold hover:text-cyan-300">
            Read on Zenodo &#x2192;
          </a>
        </div>

        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-cyan-400/30 transition-colors">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-cyan-500 text-espresso text-xs font-bold px-3 py-1 rounded-full">DOI</span>
            <span class="text-white/40 text-xs font-mono">10.5281/zenodo.19411363</span>
          </div>
          <h3 class="text-xl font-heading font-bold text-white mb-3">Genesis Whitepaper v1.1</h3>
          <p class="text-white/60 text-sm mb-4 leading-relaxed">
            SIC-POVM measurement framework, EDE architecture, Q Distribution spoon tracking, Samson's Law entropy formalization. Six implemented systems.
          </p>
          <a href="https://doi.org/10.5281/zenodo.19411363" target="_blank" rel="noopener noreferrer" class="text-cyan-400 text-sm font-bold hover:text-cyan-300">
            Read on Zenodo &#x2192;
          </a>
        </div>
      </div>

      <div class="text-center">
        <a href="/research" class="inline-flex items-center gap-2 bg-teal-600 hover:bg-teal-500 text-white font-bold py-3 px-6 rounded-xl transition-colors no-underline">
          All Publications & White Papers &#x2192;
        </a>
      </div>
    </div>
  </section>

  {/* COMMUNITY */}
  <section class="bg-white py-20 border-y border-cloud/50">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-heading font-black text-espresso mb-4">Join the Community</h2>
      <p class="text-espresso/70 max-w-xl mx-auto mb-10">
        Discord server for neurodivergent builders, parents, and researchers. Ko-fi for those who want to fund the work directly.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://discord.gg/uYW5rTCuZ" target="_blank" rel="noopener noreferrer" class="bg-[#5865F2] hover:bg-[#4752c4] text-white font-bold py-3 px-8 rounded-xl transition-colors no-underline">
          Join Discord
        </a>
        <a href="https://ko-fi.com/trimtab69420" target="_blank" rel="noopener noreferrer" class="bg-[#FF5E5B] hover:bg-[#e64e4b] text-white font-bold py-3 px-8 rounded-xl transition-colors no-underline">
          Support on Ko-fi
        </a>
        <a href="https://github.com/p31labs" target="_blank" rel="noopener noreferrer" class="bg-espresso hover:bg-teal-900 text-white font-bold py-3 px-8 rounded-xl transition-colors no-underline">
          GitHub
        </a>
      </div>
    </div>
  </section>

  {/* GLASS BOX ETHOS */}
  <section class="bg-cloud/30 py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-heading font-black text-espresso mb-8">The Glass Box Ethos</h2>
      <p class="text-xl text-espresso/80 leading-relaxed mb-10">
        Modern assistive tech is often locked behind expensive medical paywalls and proprietary black boxes. <strong class="text-teal-600">We believe accessibility is a human right.</strong> P31 Labs operates with absolute transparency. You can see our code, our bank accounts, and our physical hardware blueprints.
      </p>
      <a href="/transparency" class="inline-block bg-espresso text-cloud font-bold py-3 px-8 rounded-xl shadow-md hover:bg-teal-900 transition-colors no-underline">
        Open the Glass Box
      </a>
    </div>
  </section>

  {/* DONATE CTA */}
  <section class="bg-gradient-to-br from-teal-600 via-teal-700 to-teal-900 py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="text-butter font-bold tracking-widest uppercase text-sm mb-4">Support P31 Labs</div>
      <h2 class="text-3xl md:text-4xl font-heading font-black text-white mb-6">Every atom placed is a connection.</h2>
      <p class="text-lg text-white/80 max-w-2xl mx-auto mb-10">
        Your donation directly funds free, open-source assistive technology for neurodivergent families. No middleman. No paywall. Just tools that work.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donate" class="bg-coral-500 hover:bg-coral-600 text-white font-bold text-lg py-4 px-10 rounded-2xl shadow-lg transition-transform hover:-translate-y-1 no-underline">
          Donate via Stripe
        </a>
        <a href="https://ko-fi.com/trimtab69420" target="_blank" rel="noopener noreferrer" class="bg-white/10 hover:bg-white/20 text-white font-bold text-lg py-4 px-10 rounded-2xl border-2 border-white/20 transition-colors no-underline">
          Ko-fi (0% fee)
        </a>
      </div>
    </div>
  </section>
</main>
