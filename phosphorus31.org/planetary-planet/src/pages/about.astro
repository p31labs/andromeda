---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="animate-[fadeIn_0.4s_ease-out] bg-white min-h-screen pb-24">
    {/* Header */}
    <div class="bg-espresso text-cloud pt-32 pb-20 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-butter font-bold tracking-widest uppercase text-sm mb-4">About P31 Labs</div>
        <h1 class="text-5xl font-heading font-black mb-6">Building tools that don't exist yet.</h1>
        <p class="text-xl opacity-80 max-w-2xl">
          P31 Labs is a 501(c)(3) nonprofit creating free, open-source assistive technology for neurodivergent families.
        </p>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 -mt-10">
      {/* Founder Section */}
      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-cloud mb-16">
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-shrink-0 w-24 h-24 bg-gradient-to-br from-teal-600 via-coral-500 to-butter rounded-2xl flex items-center justify-center">
            <span class="text-4xl font-heading font-black text-white">WJ</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-heading font-black text-espresso mb-2">Will Johnson</h2>
            <p class="text-teal-600 font-bold mb-6">Founder & Executive Director</p>

            <div class="space-y-4 text-espresso/80 leading-relaxed">
              <p>
                16 years of civilian electrical engineering for the Department of Defense. Specialized in power systems, control theory, and safety-critical infrastructure. That background — grounding floating neutrals, building redundancy into systems that cannot fail — is exactly what P31 Labs applies to assistive technology.
              </p>
              <p>
                Diagnosed with AuDHD (autism + ADHD) at age 39. That late diagnosis reframed everything: why standard productivity tools never worked, why sensory environments that other people tolerate are genuinely disabling, why the existing assistive technology market either infantilizes its users or prices them out.
              </p>
              <p>
                P31 Labs exists because the tools neurodivergent families need don't exist yet. Not in the app store, not behind a $200/month subscription, not locked in a clinician's office. So we build them — free, open-source, designed for brains that work differently.
              </p>
            </div>
          </div>
        </div>
      </div>

      {/* Mission Section */}
      <div class="mb-16">
        <h2 class="text-3xl font-heading font-black text-espresso mb-8">Our Mission</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="glass-box p-8 rounded-2xl border-l-4 border-l-teal-600">
            <h3 class="font-heading font-bold text-xl text-espresso mb-3">For Families</h3>
            <p class="text-espresso/70">
              Free tools that help neurodivergent families manage energy, communicate safely, and stay connected across distance. No accounts, no tracking, no ads. Your data stays on your device.
            </p>
          </div>
          <div class="glass-box p-8 rounded-2xl border-l-4 border-l-coral-500">
            <h3 class="font-heading font-bold text-xl text-espresso mb-3">For Kids</h3>
            <p class="text-espresso/70">
              Educational technology designed for how kids actually learn — through play, discovery, and building things together. Difficulty modes that adapt to each child's age and ability.
            </p>
          </div>
          <div class="glass-box p-8 rounded-2xl border-l-4 border-l-butter">
            <h3 class="font-heading font-bold text-xl text-espresso mb-3">For Co-Parents</h3>
            <p class="text-espresso/70">
              Documented engagement tools that timestamp every interaction. When proximity isn't possible, technology can prove that a parent showed up — to the millisecond.
            </p>
          </div>
          <div class="glass-box p-8 rounded-2xl border-l-4 border-l-lavender">
            <h3 class="font-heading font-bold text-xl text-espresso mb-3">Open Source</h3>
            <p class="text-espresso/70">
              Every line of code is public. Every design decision is documented. We build in a glass box because accessibility is a human right, not a business model.
            </p>
          </div>
        </div>
      </div>

      {/* Organizational Status */}
      <div class="bg-cloud/50 rounded-3xl p-8 md:p-12 mb-16">
        <h2 class="text-3xl font-heading font-black text-espresso mb-8">Organization</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-xl border border-cloud">
            <div class="text-sm font-bold text-espresso/50 uppercase mb-2">Legal Status</div>
            <div class="text-lg font-bold text-espresso">501(c)(3) Nonprofit</div>
            <div class="text-sm text-espresso/60 mt-1">Fiscal sponsorship via Hack Club (The Hack Foundation)</div>
          </div>
          <div class="bg-white p-6 rounded-xl border border-cloud">
            <div class="text-sm font-bold text-espresso/50 uppercase mb-2">EIN</div>
            <div class="text-lg font-bold text-espresso">81-2908499</div>
            <div class="text-sm text-espresso/60 mt-1">The Hack Foundation (fiscal sponsor)</div>
          </div>
          <div class="bg-white p-6 rounded-xl border border-cloud">
            <div class="text-sm font-bold text-espresso/50 uppercase mb-2">Founded</div>
            <div class="text-lg font-bold text-espresso">2025</div>
            <div class="text-sm text-espresso/60 mt-1">SE Georgia</div>
          </div>
          <div class="bg-white p-6 rounded-xl border border-cloud">
            <div class="text-sm font-bold text-espresso/50 uppercase mb-2">Source Code</div>
            <a href="https://github.com/p31labs" target="_blank" rel="noopener noreferrer" class="text-lg font-bold text-teal-600 hover:underline">github.com/p31labs</a>
            <div class="text-sm text-espresso/60 mt-1">All repositories public</div>
          </div>
        </div>
      </div>

      {/* Contact */}
      <div class="text-center">
        <h2 class="text-2xl font-heading font-black text-espresso mb-4">Contact</h2>
        <p class="text-espresso/70 mb-2">
          <a href="mailto:will@p31ca.org" class="text-teal-600 font-bold hover:underline">will@p31ca.org</a>
        </p>
        <p class="text-espresso/50 text-sm">SE Georgia</p>
      </div>
    </div>
  </main>
</Layout>
