---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="animate-[fadeIn_0.4s_ease-out] bg-white min-h-screen pb-24">
    {/* Header */}
    <div class="bg-espresso text-cloud pt-32 pb-20 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-butter font-bold tracking-widest uppercase text-sm mb-4">What We Build</div>
        <h1 class="text-5xl font-heading font-black mb-6">Products</h1>
        <p class="text-xl opacity-80 max-w-2xl">
          Free, open-source assistive technology. Every tool is designed for neurodivergent families and built to work offline, on any device, with zero accounts required.
        </p>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 -mt-10">
      {/* BONDING — Live */}
      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-cloud mb-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-teal-600/10 rounded-2xl flex items-center justify-center text-3xl">⚛️</div>
          <div>
            <div class="flex items-center gap-3">
              <h2 class="text-3xl font-heading font-black text-espresso">BONDING</h2>
              <span class="bg-teal-600 text-white text-xs font-bold px-3 py-1 rounded-full">LIVE</span>
            </div>
            <p class="text-espresso/60">Multiplayer Chemistry Education Game</p>
          </div>
        </div>

        <p class="text-espresso/80 leading-relaxed mb-6">
          A multiplayer chemistry game where players drag atoms, snap bonds, and build molecules together — even when they're apart. Designed so a parent can play alongside their kids from any distance. Every atom placed, every molecule completed, every message sent gets timestamped and logged as evidence of engagement.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-cloud/50 p-4 rounded-xl text-center">
            <div class="text-2xl font-heading font-black text-teal-600">11+2</div>
            <div class="text-xs text-espresso/60 mt-1">Elements</div>
          </div>
          <div class="bg-cloud/50 p-4 rounded-xl text-center">
            <div class="text-2xl font-heading font-black text-coral-500">82</div>
            <div class="text-xs text-espresso/60 mt-1">Molecules</div>
          </div>
          <div class="bg-cloud/50 p-4 rounded-xl text-center">
            <div class="text-2xl font-heading font-black text-butter">5</div>
            <div class="text-xs text-espresso/60 mt-1">Quest Chains</div>
          </div>
          <div class="bg-cloud/50 p-4 rounded-xl text-center">
            <div class="text-2xl font-heading font-black text-lavender">41</div>
            <div class="text-xs text-espresso/60 mt-1">Achievements</div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://bonding.p31ca.org" target="_blank" rel="noopener noreferrer" class="bg-coral-500 hover:bg-coral-600 text-white font-bold text-lg py-4 px-8 rounded-2xl shadow-lg transition-transform hover:-translate-y-1 text-center">
            Play BONDING
          </a>
          <a href="https://p31ca.org" target="_blank" rel="noopener noreferrer" class="bg-white hover:bg-cloud text-espresso font-bold text-lg py-4 px-8 rounded-2xl border-2 border-espresso/10 transition-colors text-center">
            View Platform
          </a>
        </div>
      </div>

      {/* Spaceship Earth */}
      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-cloud mb-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-coral-500/10 rounded-2xl flex items-center justify-center text-3xl">🚀</div>
          <div>
            <div class="flex items-center gap-3">
              <h2 class="text-3xl font-heading font-black text-espresso">Spaceship Earth</h2>
              <span class="bg-butter text-espresso text-xs font-bold px-3 py-1 rounded-full">IN DEVELOPMENT</span>
            </div>
            <p class="text-espresso/60">Cognitive Dashboard & Sovereign Cockpit</p>
          </div>
        </div>

        <p class="text-espresso/80 leading-relaxed mb-6">
          A 9-room cognitive dashboard built for neurodivergent adults. Includes a geodesic observatory for data visualization, a voltage processor that analyzes incoming communication for emotional load, a breathing exercise triggered by biometric stress, a text-to-music engine, and real-time energy tracking using spoon theory. Built for brains that need the cockpit to be beautiful or they won't sit in the chair.
        </p>

        <a href="https://p31ca.org" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-coral-500 hover:bg-coral-600 text-white font-bold py-3 px-6 rounded-xl shadow-md transition-transform hover:-translate-y-0.5 text-sm"
          style="text-decoration:none;">
          Open Spaceship Earth ↗
        </a>
      </div>

      {/* The Buffer */}
      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-cloud mb-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-butter/20 rounded-2xl flex items-center justify-center text-3xl">🛡️</div>
          <div>
            <div class="flex items-center gap-3">
              <h2 class="text-3xl font-heading font-black text-espresso">The Buffer</h2>
              <span class="bg-espresso/10 text-espresso text-xs font-bold px-3 py-1 rounded-full">COMING SOON</span>
            </div>
            <p class="text-espresso/60">Communication Shield for High-Conflict Situations</p>
          </div>
        </div>

        <p class="text-espresso/80 leading-relaxed">
          An AI-powered communication processor that detects passive-aggressive language patterns, scores incoming messages for emotional voltage, and activates protective breathing exercises when biometric stress exceeds safe thresholds. Designed for co-parents, caregivers, and anyone navigating high-conflict communication.
        </p>
      </div>

      {/* Node One */}
      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-cloud">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 bg-lavender/20 rounded-2xl flex items-center justify-center text-3xl">📡</div>
          <div>
            <div class="flex items-center gap-3">
              <h2 class="text-3xl font-heading font-black text-espresso">Node One</h2>
              <span class="bg-espresso/10 text-espresso text-xs font-bold px-3 py-1 rounded-full">PROTOTYPE</span>
            </div>
            <p class="text-espresso/60">Biometric Hardware Bridge</p>
          </div>
        </div>

        <p class="text-espresso/80 leading-relaxed">
          An ESP32-based hardware device that connects wearable biometric sensors (heart rate, HRV) to P31 software via Bluetooth Low Energy. Enables the somatic tether — real-time stress detection that triggers protective responses in The Buffer and Spaceship Earth.
        </p>
      </div>
    </div>
  </main>
</Layout>
