# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,mjs,cjs,jsx,ts,tsx,mts,cts,vue,astro,css,scss,json,yml,yaml,md,mdx}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{py,rst}]
indent_size = 4

[Makefile]
indent_style = tab
